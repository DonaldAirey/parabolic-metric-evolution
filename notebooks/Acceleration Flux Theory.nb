Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"G", "=", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{
     RowBox[{"Quantity", "[", "\"\<GravitationalConstant\>\"", "]"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"(", "\"\<Meters\>\"", ")"}], "^", "3"}], "/", 
      RowBox[{"(", 
       RowBox[{"\"\<Kilograms\>\"", " ", 
        RowBox[{
         RowBox[{"(", "\"\<Seconds\>\"", ")"}], "^", "2"}]}], ")"}]}]}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"Msun", "=", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Entity", "[", 
       RowBox[{"\"\<Star\>\"", ",", "\"\<Sun\>\""}], "]"}], 
      "[", "\"\<Mass\>\"", "]"}], ",", "\"\<Kilograms\>\""}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"km", "=", 
   RowBox[{"Quantity", "[", 
    RowBox[{"1", ",", "\"\<Kilometers\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"massScale", "=", 
   RowBox[{
    RowBox[{"10.", "^", "9"}], "*", "Msun"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"logBtfrData", "=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"mb", ",", "v", ",", "emb", ",", "ev"}], "}"}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"mb", ",", "v", ",", "emb", ",", "ev"}], "}"}], "=", "#"}],
          ";", "\[IndentingNewLine]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"Log10", "[", "mb", "]"}], ",", 
           RowBox[{"Log10", "[", "v", "]"}], ",", 
           RowBox[{"emb", "/", 
            RowBox[{"(", 
             RowBox[{"mb", "*", 
              RowBox[{"Log", "[", "10", "]"}]}], ")"}]}], ",", 
           RowBox[{"ev", "/", 
            RowBox[{"(", 
             RowBox[{"v", "*", 
              RowBox[{"Log", "[", "10", "]"}]}], ")"}]}]}], "}"}]}], ")"}], 
       "&"}], "/@", "btfrData"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"modelMass", "[", 
    RowBox[{
     RowBox[{"Ak_", "?", "QuantityQ"}], ",", 
     RowBox[{"v_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "m", "}"}], ",", 
     RowBox[{
      RowBox[{"m", "=", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"Quantity", "[", 
           RowBox[{"v", ",", 
            RowBox[{"\"\<Kilometers\>\"", "/", "\"\<Seconds\>\""}]}], "]"}], "^",
           "4"}], ")"}], "/", 
        RowBox[{"(", 
         RowBox[{"4", " ", "Ak", " ", "G"}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"QuantityMagnitude", "[", 
       RowBox[{"UnitConvert", "[", 
        RowBox[{
         RowBox[{"m", "/", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"10.", "^", "9"}], " ", "Msun"}], ")"}]}], ",", "1"}], 
        "]"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"logModelMass", "[", 
    RowBox[{
     RowBox[{"Ak_", "?", "QuantityQ"}], ",", 
     RowBox[{"logv_", "?", "NumericQ"}]}], "]"}], ":=", 
   RowBox[{"Log10", "[", 
    RowBox[{"modelMass", "[", 
     RowBox[{"Ak", ",", 
      RowBox[{"10.", "^", "logv"}]}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"chiSquareLog", "[", 
    RowBox[{"Ak_", "?", "QuantityQ"}], "]"}], ":=", 
   RowBox[{"Total", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Module", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "logmb", ",", "logv", ",", "slogmb", ",", "slogv", ",", "model", ",",
           "sigmaEff2"}], "}"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"logmb", ",", "logv", ",", "slogmb", ",", "slogv"}], "}"}],
           "=", "#"}], ";", "\[IndentingNewLine]", 
         RowBox[{"model", "=", 
          RowBox[{"logModelMass", "[", 
           RowBox[{"Ak", ",", "logv"}], "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"sigmaEff2", "=", 
          RowBox[{
           RowBox[{"slogmb", "^", "2"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"4", "*", "slogv"}], ")"}], "^", "2"}]}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"logmb", "-", "model"}], ")"}], "^", "2"}], "/", 
          "sigmaEff2"}]}]}], "]"}], "&"}], "/@", "logBtfrData"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"chiSquareLogFromLogA", "[", 
    RowBox[{"aLog_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "Ak", "}"}], ",", 
     RowBox[{
      RowBox[{"Ak", "=", 
       RowBox[{"Quantity", "[", 
        RowBox[{
         RowBox[{"10.", "^", "aLog"}], ",", 
         RowBox[{"\"\<Meters\>\"", "/", 
          RowBox[{"\"\<Seconds\>\"", "^", "2"}]}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"chiSquareLog", "[", "Ak", "]"}]}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"minimum", "=", 
   RowBox[{"FindMinimum", "[", 
    RowBox[{
     RowBox[{"chiSquareLogFromLogA", "[", "aLog", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"aLog", ",", 
       RowBox[{"Log10", "[", 
        RowBox[{"3.", "*", 
         RowBox[{"10", "^", 
          RowBox[{"-", "11"}]}]}], "]"}]}], "}"}], ",", 
     RowBox[{"WorkingPrecision", "->", "30"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  InterpretationBox[
   StyleBox["\[ScriptCapitalA]",
    FontFamily->"Times"],
   $CellContext`accelerationSI], "=", 
  RowBox[{"Quantity", "[", 
   RowBox[{
    RowBox[{"10.", "^", 
     RowBox[{"(", 
      RowBox[{"aLog", "/.", " ", 
       RowBox[{"minimum", "[", 
        RowBox[{"[", "2", "]"}], "]"}]}], ")"}]}], ",", 
    RowBox[{"\"\<Meters\>\"", "/", 
     RowBox[{"\"\<Seconds\>\"", "^", "2"}]}]}], "]"}]}]}], "Input",
 CellChangeTimes->{{3.9838737702211266`*^9, 3.9838737918874454`*^9}, 

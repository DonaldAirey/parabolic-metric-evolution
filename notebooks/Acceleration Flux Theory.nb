 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["d", "ch"],
    $CellContext`causalityHorizon], "[", "t_", "]"}], "=", 
  RowBox[{"FullSimplify", "[", 
   RowBox[{
    InterpretationBox[
     SubsuperscriptBox["\[CapitalDelta]x", "o", "1"],

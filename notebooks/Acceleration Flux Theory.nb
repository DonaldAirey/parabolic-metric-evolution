Cell["\<\
Figure 5. Pantheon+SH0ES distance moduli with PME (red) and spatially flat \
FLRW (blue) predictions evaluated on the same absolute calibration. Lower \
panel shows residuals relative to each model.\
\>", "Text",
 CellChangeTimes->{{3.977172140406496*^9, 3.977172254488617*^9}, {
   3.9772253833017445`*^9, 3.977225383509161*^9}, {3.979309471220091*^9, 
   3.9793094806696377`*^9}, {3.979664455277586*^9, 3.9796644991519127`*^9}, {
   3.9796711345121365`*^9, 3.979671165267954*^9}, 3.979719316678856*^9, {
   3.980022489844864*^9, 3.9800224982021885`*^9}, 3.980023385392914*^9, {
   3.9816598902755985`*^9, 3.9816598903712883`*^9}, {3.983976346540407*^9, 
   3.983976347029026*^9}},ExpressionUUID->"479a0203-ec14-6d43-86fd-\
e7dc158d1914"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"chi2FromResiduals", "[", "res_", "]"}], ":=", 
   RowBox[{"res", ".", 
    RowBox[{"LinearSolve", "[", 
     RowBox[{"supernovaCovarianceMatrix", ",", "res"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"chi2PME", "=", 
   RowBox[{"chi2FromResiduals", "[", "pmeResiduals", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"chi2FLRW", "=", 
   RowBox[{"chi2FromResiduals", "[", "flrwResiduals", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"redChi2PME", "=", 
   RowBox[{"chi2PME", "/", 
    RowBox[{"Length", "[", "supernovaRedshifts", "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"redChi2FLRW", "=", 
   RowBox[{"chi2FLRW", "/", 
    RowBox[{"Length", "[", "supernovaRedshifts", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Grid", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"\"\<Model\>\"", 
       ",", "\"\<\!\(\*SuperscriptBox[\(\[Chi]\), \(2\)]\)\>\"", 
       ",", "\"\<\!\(\*SubsuperscriptBox[\(\[Chi]\), \(red\), \(2\)]\)\>\""}],
       "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<PME\>\"", ",", "chi2PME", ",", "redChi2PME"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\"\<FLRW\>\"", ",", "chi2FLRW", ",", "redChi2FLRW"}], "}"}]}], 
    "}"}], ",", 
   RowBox[{"Frame", "->", "All"}], ",", 
   RowBox[{"ItemStyle", "->", "12"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9770818421702595`*^9, 3.9770818421702595`*^9}, {
   3.9770819104448185`*^9, 3.977081933825239*^9}, 3.9771343749621506`*^9, {
   3.977134412661524*^9, 3.9771344273694763`*^9}, {3.9771406033904114`*^9, 
   3.977140604214319*^9}, 3.977140690761402*^9, {3.9771407263696156`*^9, 

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"numericVisibilityFunction", "[", 
    RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
   RowBox[{"QuantityMagnitude", "[", 
    RowBox[{
     RowBox[{"g", "[", 
      RowBox[{"Quantity", "[", 
       RowBox[{"t", ",", "\"\<Seconds\>\""}], "]"}], "]"}], "/.", 
     "\[VeryThinSpace]", "initialConditions"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"tmin", "=", 
   RowBox[{"QuantityMagnitude", "[", 
    RowBox[{
     RowBox[{
      InterpretationBox[
       SubscriptBox["t", "z"],
       $CellContext`timeFromRedshift], "[", "redshiftMax", "]"}], "/.", 
     "\[VeryThinSpace]", "initialConditions"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"tmax", "=", 
   RowBox[{"QuantityMagnitude", "[", 
    RowBox[{
     RowBox[{
      InterpretationBox[
       SubscriptBox["t", "z"],
       $CellContext`timeFromRedshift], "[", "redshiftMin", "]"}], "/.", 
     "\[VeryThinSpace]", "initialConditions"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["t", "*"],
    $CellContext`timeOfRecombination], "=", 
   RowBox[{"Quantity", "[", 
    RowBox[{
     RowBox[{"NArgMax", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"numericVisibilityFunction", "[", "t", "]"}], ",", 
         RowBox[{"tmin", "<", "t", "<", "tmax"}]}], "}"}], ",", "t", ",", 
       RowBox[{"Method", "\[Rule]", "\"\<NelderMead\>\""}], ",", 
       RowBox[{"WorkingPrecision", "\[Rule]", "15"}]}], "]"}], 
     ",", "\"\<Seconds\>\""}], "]"}]}], ";"}], "\n", 

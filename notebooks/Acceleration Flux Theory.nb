   3.9815628163612995`*^9, 3.9815628264673576`*^9}, {3.9815642879686584`*^9, 
   3.9815642903117332`*^9}, {3.9815644334073906`*^9, 3.9815644831542377`*^9}, 
   3.987607366450279*^9, 3.9877053119016876`*^9},

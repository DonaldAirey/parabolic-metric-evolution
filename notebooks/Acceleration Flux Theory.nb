   3.9796646328453064`*^9, 3.979664641279888*^9}, {3.9796773429051895`*^9, 
   3.979677369186594*^9}, {3.979677633444153*^9, 3.979677640199831*^9}, {
   3.9830184066507683`*^9, 3.9830184178390465`*^9}},

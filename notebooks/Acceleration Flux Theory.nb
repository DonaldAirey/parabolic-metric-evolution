Cell["\<\
The Thomson scattering rate is expressed in terms of the local particle \
density, cross section, and local geometric scale,\
\>", "Text",
 CellChangeTimes->{
  3.9876045941137657`*^9},ExpressionUUID->"a4d44d14-de66-3d42-8b24-\
95b4b0bc7565"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalGamma]", 
          StyleBox["T", "TI"]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["e", "TI"]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], " ", 
         SubscriptBox["\[Sigma]", 
          StyleBox["T", "TI"]], " ", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["V", "TI"], "0"], "-", 
             StyleBox["A", "TI"], 
             StyleBox["t", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "$\\Gamma_T(t)=n_e(t)\\,\\sigma_T\\,(V_0 - At)$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876046053024616`*^9, 3.9876046086302433`*^9}, {
  3.987706079308092*^9, 

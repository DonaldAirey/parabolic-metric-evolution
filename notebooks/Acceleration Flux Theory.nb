Cell[TextData[{
 "Figure 3. PME fundamental plane defined by equation (37). The baryonic mass \
surface ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["M", "TI"], "(", 
         RowBox[{
           StyleBox["v", "TI"], ",", 
           StyleBox["r", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$M(v,r)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c99b788b-0e11-3c4e-8c64-86553d76eed5"],
 " is shown as a function of orbital speed ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["v", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$v$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b9d0d15d-5d6e-a242-bac3-cec2cdee18ac"],
 " and orbital radius ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$r$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "badfc3d3-7ad4-3d4b-a408-c2d82c550d5a"],
 " for an illustrative manifold acceleration scale ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["A", "TI"], "\[LongEqual]", 
         SuperscriptBox["10", "-11"], 
         StyleBox["m", "TI"], " ", 
         SuperscriptBox[
          StyleBox["s", "TI"], "-2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$A = 10^{-11} m\\,s^{-2}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "77d14e5e-1604-6d4e-bea3-0bcdd3a98a49"],
 ". The red ridge marks the locus ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["M", "TI"], "max"], "(", 
         StyleBox["v", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$M_{\\max}(v)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "498693a0-225d-f34c-a7f2-bc8168fa6c7c"],
 " corresponding to the maximum baryonic mass permitted by the manifold \
kinematics at each orbital speed. Galaxies populating this ridge reproduce \
the baryonic Tully-Fisher relation."
}], "Text",
 CellChangeTimes->{{3.9800058728531036`*^9, 3.980005952860935*^9}, {
   3.980006090516197*^9, 3.980006119709055*^9}, {3.9800063426269226`*^9, 
   3.9800063464106216`*^9}, {3.980006718065256*^9, 3.9800067332168217`*^9}, {
   3.981659870041153*^9, 3.981659870184204*^9}, {3.9874477043067474`*^9, 
   3.9874477377648907`*^9}, {3.9874477698992004`*^9, 3.987447789861788*^9}, 
   3.987447891114628*^9, 
   3.9875899808626785`*^9},ExpressionUUID->"28dd026c-286e-bf47-bb2b-\
2daa7d141fc0"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Baryonic Tully-Fisher Relation", "Subsection",
 CellChangeTimes->{{3.975926923007534*^9, 3.9759269671046143`*^9}, 
   3.9759270608007984`*^9, 3.9765672182635574`*^9, 3.9874479228712444`*^9, 
   3.987590014252014*^9},ExpressionUUID->"b9dec3de-0602-b647-8cd3-\
d1368a023360"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["M", "TI"], "max"], "(", 
         StyleBox["v", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$M_{\\max}(v)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a17d224b-cbbd-c341-8d62-a2160951daa9"],
 " defines the scaling ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["M", "TI"], "\[Proportional]", 
         SuperscriptBox[
          StyleBox["v", "TI"], "4"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$M \\propto v^4$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "593c43e0-84a9-fb49-9756-30658e4b85c3"],
 ", consistent with the observed baryonic Tully--Fisher relation [",
 ButtonBox["12",
  BaseStyle->"Hyperlink",
  ButtonData->"McGaugh2016"],
 "]."
}], "Text",
 CellChangeTimes->{{3.9874479367825394`*^9, 3.9874479780783215`*^9}, {
  3.987448036248453*^9, 
  3.987448036248453*^9}},ExpressionUUID->"d8d6facb-0483-8d4b-a7cf-\
1baad1217f09"],

Cell[TextData[{
 "A characteristic acceleration scale in galaxy dynamics has previously been \
emphasized in frameworks such as MOND [",
 ButtonBox["10",
  BaseStyle->"Hyperlink",
  ButtonData->"Milgrom1983"],
 "], in which the force law is modified to reproduce Tully-Fisher-type \
scaling."
}], "Text",
 CellChangeTimes->{{3.9874482157287273`*^9, 3.9874482535787907`*^9}, 
   3.9874485914014416`*^9},ExpressionUUID->"184422d1-3a1e-bb45-95e4-\
b60f8cdd832b"],

Cell[TextData[{
 "The manifold acceleration ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6b8fcf46-02a5-8447-9614-d375dccd1e73"],
 " is determined empirically by fitting the circular-orbit envelope (equation \
(40)) to the SPARC galaxy sample of McGaugh, Lelli and Schombert [18], using \
the assumptions ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalUpsilon]", "\[FivePointedStar]"], 
         "\[LongEqual]", "0.5"}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\Upsilon_\\star=0.5$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "97d5183d-2b56-cf4a-966b-43b6a7cdbcc1"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["f", "TI"], 
          StyleBox["gas", FontSlant -> "Plain"]], "\[LongEqual]", "1.33"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "$f_{\\mathrm{gas}}=1.33$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cbd75d4a-1d6e-a84a-8957-686d066be507"],
 ", zero intrinsic mass-to-light uncertainty, and the quality cut ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["Qual", FontSlant -> "Plain"], "\[LessEqual]", "3"}], 
       TraditionalForm], "errors" -> {}, "input" -> "$\\mathrm{Qual}\\leq 3$",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e078d95f-b14b-e04c-a94b-99e8e563c508"],
 ". These rotationally supported disk systems are well suited to the \
analysis, as their kinematics closely follow the circular-orbit approximation."
}], "Text",
 CellChangeTimes->{{3.987448625229679*^9, 3.9874486399697704`*^9}, {
  3.987448736698082*^9, 
  3.987448785976824*^9}},ExpressionUUID->"02eb2c27-7694-124d-8786-\
9fb6b8daccc4"],

Cell[TextData[{
 "For each galaxy the rotation curve provides an asymptotic circular velocity \
",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["v", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$v$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "212a2b50-37e6-9045-ab63-ad5b6abac3de"],
 ", while the baryonic mass ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["M", "TI"], 
        StyleBox["b", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$M_b$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e525a095-d0b0-8e4f-ad99-cd13aae208e5"],
 " is computed as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["M", "TI"], 
          StyleBox["b", "TI"]], "\[LongEqual]", 
         SubscriptBox["\[CapitalUpsilon]", "\[FivePointedStar]"], 
         SubscriptBox[
          StyleBox["L", "TI"], "3.6"], "+", 
         SubscriptBox[
          StyleBox["f", "TI"], 
          RowBox[{
            StyleBox["g", "TI"], 
            StyleBox["a", "TI"], 
            StyleBox["s", "TI"]}]], " ", 
         SubscriptBox[
          StyleBox["M", "TI"], 
          StyleBox["HI", FontSlant -> "Plain"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$M_b=\\Upsilon_\\star L_{3.6}+f_{gas}\\,M_{\\mathrm{HI}}$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5475757a-4427-584b-a799-122a76ea6178"],
 ". The value of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2d342363-52fa-5f45-ac33-5cdaba0725dd"],
 " is determined by minimizing the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox["\[Chi]", "2"], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\chi^2$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "856da9e9-1eb3-294f-a692-13eae8b595e3"],
 " statistic between the theoretical envelope and the observed ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["M", "TI"], 
            StyleBox["b", "TI"]], ",", 
           StyleBox["v", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$(M_b,v)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a8cb018c-43a5-074f-9463-59d593e6b5df"],
 " pairs."
}], "Text",
 CellChangeTimes->{{3.987448893604166*^9, 
  3.9874489445092697`*^9}},ExpressionUUID->"28923108-cd3a-1b43-af60-\
596321665aa2"],

Cell["The best-fit manifold acceleration is", "Text",
 CellChangeTimes->{
  3.9874489488938503`*^9},ExpressionUUID->"c1d9828c-0513-ac44-960f-\
3490f1bbf4b4"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["A", "TI"], "\[LongEqual]", "3.7", "\[Cross]", 
         SuperscriptBox["10", "-11"], " ", 
         StyleBox["m", "TI"], " ", 
         SuperscriptBox[
          StyleBox["s", "TI"], "-2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$A = 3.7\\times10^{-11}\\,m\\,s^{-2}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9874489617200794`*^9, 3.9874489662816067`*^9}, {
  3.987449138345392*^9, 
  3.9874491383615303`*^9}},ExpressionUUID->"aa2c3c0d-de88-7b42-b1b0-\
9e8036bf3bc4"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
  "tapURL", 
   "=", "\"\<https://tapvizier.cds.unistra.fr/TAPVizieR/tap/sync\>\""}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"adql", "=", "\"\<SELECT * FROM \\\"J/AJ/152/157/table1\\\"\>\""}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"raw", "=", 
   RowBox[{"Import", "[", 
    RowBox[{
     RowBox[{"URLBuild", "[", 
      RowBox[{"tapURL", ",", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"\"\<request\>\"", "->", "\"\<doQuery\>\""}], ",", 
         RowBox[{"\"\<lang\>\"", "->", "\"\<adql\>\""}], ",", 
         RowBox[{"\"\<format\>\"", "->", "\"\<csv\>\""}], ",", 
         RowBox[{"\"\<query\>\"", "->", "adql"}]}], "|>"}]}], "]"}], 
     ",", "\"\<CSV\>\""}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"header", "=", 
   RowBox[{"First", "[", "raw", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"rows", "=", 
   RowBox[{"Rest", "[", "raw", "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"upsStar", "=", "0.5"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fracUpsErr", "=", "0.0"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"gasFactor", "=", "1.33"}], ";"}], "\n", 
 RowBox[{
  RowBox[{"maxQual", "=", "3"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"column", "=", 
   RowBox[{"AssociationThread", "[", 
    RowBox[{"header", "->", 
     RowBox[{"Range", "[", 
      RowBox[{"Length", "[", "header", "]"}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"get", "[", 
    RowBox[{"row_", ",", "key_"}], "]"}], ":=", 
   RowBox[{"row", "[", 
    RowBox[{"[", 
     RowBox[{"column", "[", "key", "]"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"baryonicMass", "[", "row_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"l36", "=", 
        RowBox[{"N", "@", 
         RowBox[{"get", "[", 
          RowBox[{"row", ",", "\"\<L3_6\>\""}], "]"}]}]}], ",", 
       RowBox[{"mhi", "=", 
        RowBox[{"N", "@", 
         RowBox[{"get", "[", 
          RowBox[{"row", ",", "\"\<MHI\>\""}], "]"}]}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"upsStar", "*", "l36"}], "+", 
      RowBox[{"gasFactor", "*", "mhi"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"massError", "[", "row_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"l36", "=", 
        RowBox[{"N", "@", 
         RowBox[{"get", "[", 
          RowBox[{"row", ",", "\"\<L3_6\>\""}], "]"}]}]}], ",", 
       RowBox[{"el36", "=", 
        RowBox[{"N", "@", 
         RowBox[{"get", "[", 
          RowBox[{"row", ",", "\"\<e_L3_6\>\""}], "]"}]}]}], ",", 
       RowBox[{"mhi", "=", 
        RowBox[{"N", "@", 
         RowBox[{"get", "[", 
          RowBox[{"row", ",", "\"\<MHI\>\""}], "]"}]}]}], ",", 
       RowBox[{"dist", "=", 
        RowBox[{"N", "@", 
         RowBox[{"get", "[", 
          RowBox[{"row", ",", "\"\<Dist\>\""}], "]"}]}]}], ",", 
       RowBox[{"edist", "=", 
        RowBox[{"N", "@", 
         RowBox[{"get", "[", 
          RowBox[{"row", ",", "\"\<e_Dist\>\""}], "]"}]}]}], ",", "fracDist", 
       ",", "eStarPhot", ",", "eStarML", ",", "eGasDist", ",", "eStarDist"}], 
      "}"}], ",", 
     RowBox[{
      RowBox[{"fracDist", "=", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"dist", ">", "0"}], ",", 
         RowBox[{"edist", "/", "dist"}], ",", "0.0"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eStarPhot", "=", 
       RowBox[{"upsStar", "*", "el36"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"eStarML", "=", 
       RowBox[{"fracUpsErr", "*", "upsStar", "*", "l36"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eStarDist", "=", 
       RowBox[{"2", "*", "fracDist", "*", 
        RowBox[{"(", 
         RowBox[{"upsStar", "*", "l36"}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"eGasDist", "=", 
       RowBox[{"2", "*", "fracDist", "*", 
        RowBox[{"(", 
         RowBox[{"gasFactor", "*", "mhi"}], ")"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Sqrt", "[", 
       RowBox[{
        RowBox[{"eStarPhot", "^", "2"}], "+", 
        RowBox[{"eStarML", "^", "2"}], "+", 
        RowBox[{"eStarDist", "^", "2"}], "+", 
        RowBox[{"eGasDist", "^", "2"}]}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"vflat", "[", "row_", "]"}], ":=", 
   RowBox[{"N", "@", 
    RowBox[{"get", "[", 
     RowBox[{"row", ",", "\"\<Vflat\>\""}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"vflatError", "[", "row_", "]"}], ":=", 
   RowBox[{"N", "@", 
    RowBox[{"get", "[", 
     RowBox[{"row", ",", "\"\<e_Vflat\>\""}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"validRowQ", "[", "row_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"v", "=", 
        RowBox[{"vflat", "[", "row", "]"}]}], ",", 
       RowBox[{"ev", "=", 
        RowBox[{"vflatError", "[", "row", "]"}]}], ",", 
       RowBox[{"q", "=", 
        RowBox[{"get", "[", 
         RowBox[{"row", ",", "\"\<Qual\>\""}], "]"}]}]}], "}"}], ",", 
     RowBox[{
      RowBox[{"NumericQ", "[", "v", "]"}], "&&", 
      RowBox[{"NumericQ", "[", "ev", "]"}], "&&", 
      RowBox[{"v", ">", "0"}], "&&", 
      RowBox[{"ev", ">=", "0"}], "&&", 
      RowBox[{"q", "<=", "maxQual"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"goodRows", "=", 
   RowBox[{"Select", "[", 
    RowBox[{"rows", ",", "validRowQ"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"btfrData", "=", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"baryonicMass", "[", "#", "]"}], ",", 
        RowBox[{"vflat", "[", "#", "]"}], ",", 
        RowBox[{"massError", "[", "#", "]"}], ",", 
        RowBox[{"vflatError", "[", "#", "]"}]}], "}"}], "&"}], ")"}], "/@", 
    "goodRows"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.97801177737241*^9, 3.97801177737241*^9}, {
   3.9780121227661743`*^9, 3.978012157192642*^9}, {3.978012192618908*^9, 
   3.9780123293430786`*^9}, {3.978012369975727*^9, 3.978012415065012*^9}, {
   3.9780125121592007`*^9, 3.9780125138980827`*^9}, {3.97801279333193*^9, 
   3.978012794997755*^9}, {3.9780132574313107`*^9, 3.9780132617965603`*^9}, {
   3.9780134743131714`*^9, 3.9780134861440887`*^9}, {3.9780138607517014`*^9, 
   3.978013906180046*^9}, {3.97801414500585*^9, 3.978014160510933*^9}, {
   3.978014290172779*^9, 3.9780142954945545`*^9}, {3.978014567300741*^9, 
   3.9780145902666683`*^9}, 3.9780155531457024`*^9, 3.978015660342182*^9, {
   3.9780163181665993`*^9, 3.978016336866989*^9}, 3.978016428180126*^9, {
   3.97801655230682*^9, 3.978016554961836*^9}, {3.978016854871294*^9, 
   3.978016897156933*^9}, 3.9780169805943623`*^9, {3.97802188316346*^9, 
   3.9780218852107544`*^9}, {3.978022081992628*^9, 3.9780220838764744`*^9}, {
   3.978022118495676*^9, 3.978022135127121*^9}, {3.9780223264236774`*^9, 
   3.9780223306882477`*^9}, {3.978022395052719*^9, 3.9780223979592304`*^9}, {
   3.978022620549595*^9, 3.9780227009966564`*^9}, 3.97802317400782*^9, {
   3.9780238168622627`*^9, 3.978023856115305*^9}, {3.9780240026749973`*^9, 
   3.9780240156518974`*^9}, {3.9780273427718563`*^9, 
   3.9780273526931725`*^9}, {3.978027468739151*^9, 3.9780274912514668`*^9}, {
   3.978027671380373*^9, 3.978027694132328*^9}, {3.9780332856797066`*^9, 
   3.978033315412407*^9}, 3.9780335709970036`*^9, {3.978033660520262*^9, 
   3.978033668591078*^9}, 3.978033837746231*^9, 3.9780342030413*^9, {
   3.9780343373704453`*^9, 3.9780343515023956`*^9}, 3.978034395946409*^9, {
   3.978034522111988*^9, 3.9780345336484737`*^9}, {3.978034584096138*^9, 
   3.9780347018040276`*^9}, {3.978034764117876*^9, 3.978034783107849*^9}, {
   3.9780348230440693`*^9, 3.978034847729435*^9}, {3.9780351126494617`*^9, 
   3.978035179838728*^9}, {3.9780352551348248`*^9, 3.9780352587931175`*^9}, {
   3.9781017704009895`*^9, 3.9781018368217945`*^9}, 3.978101886025263*^9, 
   3.978107449392399*^9, {3.978107538074028*^9, 3.9781075456768856`*^9}, {
   3.9781076951985207`*^9, 3.978107696526741*^9}, {3.9781079264946327`*^9, 
   3.9781079617543144`*^9}, {3.978108066153263*^9, 3.978108067550226*^9}, 
   3.9781081420531464`*^9, {3.9781084004766903`*^9, 3.9781084148182735`*^9}, {
   3.9781084668474903`*^9, 3.978108469371935*^9}, {3.9781085173374634`*^9, 
   3.9781085240225735`*^9}, {3.9781098509406033`*^9, 3.9781098746615047`*^9}, 
   3.978113521864744*^9, {3.9781144277006416`*^9, 3.978114508706337*^9}, {
   3.9781152098439217`*^9, 3.9781152287907696`*^9}, {3.978117758535618*^9, 
   3.9781177613721695`*^9}, {3.978117865755989*^9, 3.9781178692966576`*^9}, {
   3.97811809805266*^9, 3.9781181097992916`*^9}, {3.9781184580502567`*^9, 
   3.9781184739924393`*^9}, {3.9781185315494194`*^9, 3.978118600644184*^9}, 
   3.978119092315689*^9, 3.9781191717807465`*^9, {3.9781192112828217`*^9, 

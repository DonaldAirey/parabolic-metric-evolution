   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["v", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$v$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c7715c84-5feb-d34e-a409-69932fb8505c"],
 ", the mass function ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["M", "TI"], "(", 
         StyleBox["r", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$M(r)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "32f79f44-a634-4f47-8395-572574536650"],
 " is a concave quadratic in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$r$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "befef5e7-e68e-724e-a174-a01a7d3b13c9"],
 ". Differentiating gives"
}], "Text",
 CellChangeTimes->{{3.9874159956107006`*^9, 
  3.987416009828703*^9}},ExpressionUUID->"3e95d97a-34ac-4049-bf65-\
3411dee45ac4"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["M", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["r", "TI"]}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["v", "TI"], "2"], "-", "2", 

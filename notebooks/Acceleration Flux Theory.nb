Cell[CellGroupData[{

Cell["Causal Structure", "Subsection",
 CellChangeTimes->{{3.9795577933638763`*^9, 3.9795577979110813`*^9}, {
   3.9811413142618065`*^9, 3.9811413283580036`*^9}, 
   3.9873595548829174`*^9},ExpressionUUID->"189bdef1-f691-6e4d-a02e-\
c48fc3723f25"],

Cell[TextData[{
 "The null structure of the bilocal interval also determines the extent of \
causal connectivity on the manifold. The largest spatial separation permitted \
by null ordering is obtained from equation (13) with the emission event at \
the origin of the manifold history, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["t", "TI"], 
          StyleBox["e", "TI"]], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "$t_e = 0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b3573f31-72bf-4343-806b-9be2272aace2"],
 ", and the observation event at epoch ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["t", "TI"], 
          StyleBox["o", "TI"]], "\[LongEqual]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_o = t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dedff80c-3749-f34d-9123-f37e07dbba00"],
 ". Solving the null condition ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "2"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "$\\Delta s^2 = 0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ce4b00c6-b7bb-ef40-9194-5226b6252c5b"],
 " for the observed separation gives the causal horizon"
}], "Text",
 CellChangeTimes->{{3.979558266065878*^9, 3.9795583406109543`*^9}, {
  3.9795594343696785`*^9, 3.97955945744491*^9}, {3.979559493112997*^9, 
  3.979559500532921*^9}, {3.9799972919472904`*^9, 3.9799972987666855`*^9}, {
  3.9811413200244713`*^9, 3.981141322659275*^9}, {3.981141370919668*^9, 
  3.9811414876220818`*^9}, {3.981802348051758*^9, 3.981802356103222*^9}, {
  3.987359565032984*^9, 
  3.9873596215938473`*^9}},ExpressionUUID->"d3594b4b-2d07-6647-91d3-\
0d821235ecb2"],


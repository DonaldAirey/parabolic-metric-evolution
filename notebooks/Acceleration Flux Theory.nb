Cell["\<\
Differentiating the causal horizon gives the expansion rate of the causal \
boundary,\
\>", "Text",
 CellChangeTimes->{
  3.987359974521042*^9},ExpressionUUID->"8cf21f5b-81b2-944b-852a-\
a494b5b25f7e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["c", FontSlant -> "Plain"]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          StyleBox["d", "TI"], 
          RowBox[{
            StyleBox["d", "TI"], 
            StyleBox["t", "TI"]}]], 
         SubscriptBox["\[DifferentialD]", 
          StyleBox["ch", FontSlant -> "Plain"]], "\[LongEqual]", "2", 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["V", "TI"], "0"], "-", 
             StyleBox["A", "TI"], 
             StyleBox["t", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "$c_{\\mathrm{c}}(t)=\\frac{d}{dt}\\,d_{\\mathrm{ch}}=2\\left(V_0-At\\\
right)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987359987698189*^9, 3.9873599953502693`*^9}, {
  3.9874111221542416`*^9, 
  3.9874111221542416`*^9}},ExpressionUUID->"3193c43b-b133-4e46-ab0f-\
c81a266d4430"],

Cell["\<\
This quantity defines the rate at which the accessible causal domain can be \
extended under the operational clock, and therefore characterizes the growth \
of the causally orderable region.\
\>", "Text",
 CellChangeTimes->{{3.979558343174263*^9, 3.979558345893486*^9}, {
   3.9795583871273403`*^9, 3.9795584428762684`*^9}, 3.9795595224165287`*^9, 
   3.9799973096107044`*^9, 3.9799976715428925`*^9, 
   3.987360481853985*^9},ExpressionUUID->"26cfd654-a767-5949-836c-\
ff46ed8c465e"],

Cell[TextData[{
 "Comparing the causal horizon with the manifold extent ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$L(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c6240641-1ed5-3e45-9af1-6096fc80c224"],
 " defined in equation (7) yields"
}], "Text",
 CellChangeTimes->{{3.987360500648056*^9, 3.987360515060398*^9}, {
  3.9873609904743233`*^9, 
  3.987360992562084*^9}},ExpressionUUID->"97226027-8f0c-8546-8695-\
b5e8982e3e75"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["d", "TI"], 
             StyleBox["ch", FontSlant -> "Plain"]], "(", 
            StyleBox["t", "TI"], ")"}], 
          RowBox[{
            StyleBox["L", "TI"], "(", 
            StyleBox["t", "TI"], ")"}]], "\[LongEqual]", "2"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "$\\frac{d_{\\mathrm{ch}}(t)}{L(t)} = 2$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987360542727995*^9, 3.9873605475977097`*^9}, 
   3.9873605972474136`*^9, {3.987411110948818*^9, 
   3.987411110948818*^9}},ExpressionUUID->"cf8a8171-99a5-ff4d-ac29-\
6a71015a8d69"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Simplify", "[", 
  FractionBox[
   RowBox[{
    InterpretationBox[
     SubscriptBox["d", "ch"],
     $CellContext`causalityHorizon], "[", "t", "]"}], 
   RowBox[{"L", "[", "t", "]"}]], "]"}]], "Input",
 CellChangeTimes->{{3.979557490612911*^9, 3.9795575089724503`*^9}, 
   3.979590189004652*^9, 3.9795903020465775`*^9, 3.9812779842196407`*^9},
 CellLabel->"In[87]:=",ExpressionUUID->"ec53d364-17a7-3c4e-b3ba-5cdd7c7407ac"],

Cell[BoxData["2"], "Output",
 CellChangeTimes->{3.987751762323429*^9},
 CellLabel->"Out[87]=",ExpressionUUID->"87344afa-4c29-a747-b8d3-321f139c5b23"]
}, Open  ]],

Cell["\<\
The causal horizon is therefore twice the manifold extent at all epochs, \
placing the entire last-scattering surface within a single causal region. \
Because the homogeneous manifold acceleration introduces no preferred \
direction, the large-scale isotropy of the cosmic microwave background \
follows directly from the geometry.\
\>", "Text",
 CellChangeTimes->{
  3.987360607967472*^9},ExpressionUUID->"f6e3aa6b-56b9-2144-8a1d-\
8e19c13b2394"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Gravity", "Section",
 CellChangeTimes->{{3.9758597633119392`*^9, 3.9758597696398697`*^9}, {
  3.9873610420963383`*^9, 
  3.987361043078745*^9}},ExpressionUUID->"447f8d59-701e-0647-b255-\
388ae28f77c3"],

Cell[TextData[{
 "When the temporal interval between neighboring events is small compared \
with the characteristic evolution scale of the manifold extent ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$L(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "649a0a42-9b22-cb40-be6b-3407e32fb673"],
 ", the bilocal construction admits a smooth local reduction yielding an \
effective acceleration field inherited from the manifold kinematics."
}], "Text",
 CellChangeTimes->{{3.987361066725361*^9, 
  3.9873610789450035`*^9}},ExpressionUUID->"0c5cb65a-6974-9242-ad3d-\
c8caaf3fb98b"],

Cell[CellGroupData[{

Cell["Coincidence Limit", "Subsection",
 CellChangeTimes->{
  3.987361097165121*^9},ExpressionUUID->"56f3ddc0-43e9-3e49-ab5a-\
654103c33420"],

Cell[TextData[{
 "The local description is obtained as the coincidence limit of the bilocal \
interval as the endpoint separation tends to zero. Let the observation event \
occur at epoch ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "04af110f-ef62-f64e-b67b-d853f79ab26e"],
 " and the emission event at ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["t", "TI"], "-", "\[CapitalDelta]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$t-\\Delta t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a4cae48b-ef41-4542-ad3d-7fc6f1553414"],
 ", with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         StyleBox["t", "TI"], "\[Rule]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "$\\Delta t \\to 0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "370a15f7-bf69-3f4f-981f-5dcf2780d764"],
 ". To extract the leading nontrivial local structure, the temporal and \
spatial bilocal functionals are expanded to first and second orders in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\Delta t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ee326205-c4b5-164a-9dcc-deaabac29483"],
 "."
}], "Text",
 CellChangeTimes->{{3.9873611119750614`*^9, 
  3.9873611386247196`*^9}},ExpressionUUID->"6e68ecfe-fa59-4044-9f8b-\
c6060f40ac2c"],

Cell["Using the local expansion of the manifold extent,", "Text",
 CellChangeTimes->{
  3.987361182134775*^9},ExpressionUUID->"417c0ab6-0772-a34a-8df2-\
6590ccc457fd"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["t", "TI"], "-", "\[CapitalDelta]", 
             StyleBox["t", "TI"]}], ")"}], "\[LongEqual]", 
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "-", 
         OverscriptBox[
          StyleBox["L", "TI"], "."], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], " ", "\[CapitalDelta]", 
         StyleBox["t", "TI"], "-", 
         FractionBox["1", "2"], 
         StyleBox["A", "TI"], " ", "\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["t", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "$L(t-\\Delta t)=L(t)-\\dot L(t)\\,\\Delta t-\\frac{1}{2}A\\,\\Delta \
t^2$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "75088c10-21f3-8247-9999-d6077a490aef"],
 ","
}], "Text",
 CellChangeTimes->{{3.9873611918847046`*^9, 
  3.9873611966975765`*^9}},ExpressionUUID->"918caa47-a35f-e441-9941-\
6f20456f69fd"],

Cell["the slice-separation relation gives", "Text",
 CellChangeTimes->{
  3.987361209394964*^9},ExpressionUUID->"4fb63088-75a5-6241-95a5-\
fda801bab264"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{"\[CapitalDelta]", 
            SubsuperscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["e", "TI"], "1"]}], 
          RowBox[{
            StyleBox["L", "TI"], "(", 
            RowBox[{
              StyleBox["t", "TI"], "-", "\[CapitalDelta]", 
              StyleBox["t", "TI"]}], ")"}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"\[CapitalDelta]", 
            SubsuperscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["o", "TI"], "1"]}], 
          RowBox[{
            StyleBox["L", "TI"], "(", 
            StyleBox["t", "TI"], ")"}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "$\\frac{\\Delta x_e^1}{L(t-\\Delta t)}=\\frac{\\Delta x_o^1}{L(t)}$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9873612476543255`*^9, 3.987361261208315*^9}, {
  3.9874110907861576`*^9, 
  3.987411090789673*^9}},ExpressionUUID->"8fbb505f-c2bb-5441-aa0c-\
699a23ccc1ae"],

Cell["Hence", "Text",
 CellChangeTimes->{{3.9873613062266006`*^9, 
  3.987361308731697*^9}},ExpressionUUID->"d6e16198-8f4b-c642-8981-\
bb3b5e1e5079"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["e", "TI"], "1"], "\[LongEqual]", "\[CapitalDelta]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["o", "TI"], "1"], 
         RowBox[{"(", 
           RowBox[{"1", "-", 
             FractionBox[
              OverscriptBox[
               StyleBox["L", "TI"], "."], 
              StyleBox["L", "TI"]], "\[CapitalDelta]", 
             StyleBox["t", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "$\\Delta x_e^1=\\Delta x_o^1\\left(1-\\frac{\\dot L}{L}\\Delta \
t\\right)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9873613727636337`*^9, 3.987361376793606*^9}, {
  3.9874111587259464`*^9, 
  3.9874111587371407`*^9}},ExpressionUUID->"4e2373cf-f120-2c48-af07-\
dc48e8232490"],

Cell["so the bilocal spatial component becomes", "Text",
 CellChangeTimes->{
  3.987361392073492*^9},ExpressionUUID->"7be6b41b-33b0-1547-9a04-\
c1a6464329dc"],

Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{"\[CapitalDelta]", 
        SuperscriptBox[
         StyleBox["s", "TI"], "1"], "\[LongEqual]", "\[CapitalDelta]", 
        SubsuperscriptBox[
         StyleBox["x", "TI"], 
         StyleBox["o", "TI"], "1"], 
        RowBox[{"(", 
          RowBox[{"1", "-", 
            FractionBox["1", "2"], 
            FractionBox[
             OverscriptBox[
              StyleBox["L", "TI"], "."], 
             StyleBox["L", "TI"]], "\[CapitalDelta]", 
            StyleBox["t", "TI"]}], ")"}], "\[TildeTilde]", "\[CapitalDelta]", 
        SubsuperscriptBox[
         StyleBox["x", "TI"], 
         StyleBox["o", "TI"], "1"]}], TraditionalForm], "errors" -> {}, 
    "input" -> 
    "$\\Delta s^1=\\Delta x_o^1\\left(1-\\frac{1}{2}\\frac{\\dot L}{L}\\Delta \
t\\right)\\approx \\Delta x_o^1$", "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9873614011934795`*^9, 3.987361404903631*^9}, {
  3.9874112153840637`*^9, 
  3.9874112153840637`*^9}},ExpressionUUID->"64515db5-2fae-5b46-b936-\
b9278cfc4668"],

Cell[TextData[{
 "to leading order in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\Delta t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ea725d77-8c18-4b40-80ed-66d753b7274b"],
 ". Over the same interval, the temporal component is"
}], "Text",
 CellChangeTimes->{{3.987361424953367*^9, 
  3.9873614326731052`*^9}},ExpressionUUID->"61e55972-e87e-e04e-946b-\
fe780dcfd54e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "0"], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", 
          RowBox[{
            StyleBox["t", "TI"], "-", "\[CapitalDelta]", 
            StyleBox["t", "TI"]}], 
          StyleBox["t", "TI"]], 
         StyleBox["i", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["A", "TI"], 
             SuperscriptBox[
              StyleBox["t", "TI"], "\[Prime]"], "-", 
             SubscriptBox[
              StyleBox["V", "TI"], "0"]}], ")"}], "\[DifferentialD]", 
         SuperscriptBox[
          StyleBox["t", "TI"], "\[Prime]"], "\[TildeTilde]", 
         StyleBox["i", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["V", "TI"], "0"], "-", 
             StyleBox["A", "TI"], 
             StyleBox["t", "TI"]}], ")"}], "\[CapitalDelta]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\Delta s^0=\\int_{t-\\Delta t}^{t} i\\left(A t' - V_0\\right)\\,dt' \
\\approx i\\left(V_0-At\\right)\\Delta t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9874122907722855`*^9, 
  3.9874123087154045`*^9}},ExpressionUUID->"4f8b995d-19ce-a64d-964d-\
dc37f39b1292"],

Cell["\<\
Substituting these leading terms into equation~(\\ref{eq:bilocal_interval}) \
yields\
\>", "Text",
 CellChangeTimes->{
  3.987361460483137*^9},ExpressionUUID->"f974e38d-2f57-0443-bdb4-\
49de814838b2"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "2"], "\[TildeTilde]", "-", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{
              SubscriptBox[
               StyleBox["V", "TI"], "0"], "-", 
              StyleBox["A", "TI"], 
              StyleBox["t", "TI"]}], ")"}], "2"], "\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["t", "TI"], "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"\[CapitalDelta]", 
              SubsuperscriptBox[
               StyleBox["x", "TI"], 
               StyleBox["o", "TI"], "1"]}], ")"}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\Delta s^2 \\approx -\\left(V_0-At\\right)^2\\Delta t^2 + (\\Delta \
x_o^1)^2$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987361474743334*^9, 3.987361480723255*^9}, {
  3.987491041162403*^9, 
  3.987491041162403*^9}},ExpressionUUID->"deb5d0c3-e3d7-da42-ae8b-\
7dfd3370b1eb"],

Cell[TextData[{
 "which is the emergent local interval obtained from the coincidence limit of \
the bilocal geometry. The local interval therefore defines a tangent of fixed \
magnitude ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["V", "TI"], "0"], "-", 
         StyleBox["A", "TI"], 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$V_0-At$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fa41d9bc-136a-c642-a94d-12a682fd3d8c"],
 " shared by all trajectories at epoch ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ff2c3d14-ffef-6548-ae76-75ee670a4007"],
 ", whose projections onto orthogonal temporal and spatial components give \
rise to timelike, null, and spacelike directions."
}], "Text",
 CellChangeTimes->{{3.98736149311277*^9, 
  3.9873615081530437`*^9}},ExpressionUUID->"53197caa-908d-b644-9626-\
5c9fdbf1f8ab"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Acceleration Field", "Subsection",
 CellChangeTimes->{{3.9758620369803143`*^9, 3.9758620859202538`*^9}, {
   3.977595362073496*^9, 3.9775953795066395`*^9}, 3.978817375536915*^9, 
   3.9799994714121246`*^9, 
   3.987412689977455*^9},ExpressionUUID->"db87797d-e851-c542-8ab1-\
a39b36d31ac1"],

Cell[TextData[{
 "Consider an event pair ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["p", "TI"], 
            StyleBox["e", "TI"]], ",", 
           SubscriptBox[
            StyleBox["p", "TI"], 
            StyleBox["o", "TI"]]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$(p_e,p_o)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6ad394d3-4124-f049-864c-59f8a4a41f1f"],
 " whose temporal separation ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\Delta t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cdfda2b8-6d2d-0449-8d90-3658d4b98edf"],
 " satisfies ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         StyleBox["t", "TI"], "\[LessLess]", 
         StyleBox["L", "TI"], "/", 
         OverscriptBox[
          StyleBox["L", "TI"], "."]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\Delta t \\ll L/\\dot L$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e63677a9-ec9b-cf4e-8653-775607d54642"],
 ". Expanding the manifold extent about a reference epoch ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["t", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c48e5b1-4610-5140-ab4a-af99f50b73f1"],
 " gives"
}], "Text",
 CellChangeTimes->{{3.979999486421873*^9, 3.9799995332207336`*^9}, {
  3.9799996005803814`*^9, 3.9799996586430264`*^9}, {3.987412703944586*^9, 
  3.987412727813114*^9}},ExpressionUUID->"4a7efa3e-6ab7-b141-9184-\
dc3b4d2ec59c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox[
              StyleBox["t", "TI"], "0"], "+", "\[Delta]", 
             StyleBox["t", "TI"]}], ")"}], "\[LongEqual]", 
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["t", "TI"], "0"], ")"}], "+", 
         OverscriptBox[
          StyleBox["L", "TI"], "."], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["t", "TI"], "0"], ")"}], " ", "\[Delta]", 
         StyleBox["t", "TI"], "+", 
         FractionBox["1", "2"], 
         OverscriptBox[
          StyleBox["L", "TI"], "\:0308"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["t", "TI"], "0"], ")"}], " ", "\[Delta]", 
         SuperscriptBox[
          StyleBox["t", "TI"], "2"], "+", "\[CenterEllipsis]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "$L(t_0+\\delta t)=L(t_0)+\\dot{L}(t_0)\\,\\delta \
t+\\frac{1}{2}\\ddot{L}(t_0)\\,\\delta t^2+\\cdots$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9874127470890293`*^9, 3.9874127515647945`*^9}, {
  3.987491057787161*^9, 
  3.987491057787161*^9}},ExpressionUUID->"39c72282-6be0-4243-bdda-\
6af9baf858ba"],

Cell[TextData[{
 "Using equation (##), the quadratic term is governed by the constant local \
value ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["L", "TI"], "\:0308"], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["t", "TI"], "0"], ")"}], "\[LongEqual]", "-", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\ddot{L}(t_0)=-A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c8c54574-4145-ec48-9fff-4df005253c1d"],
 ". The local reduction therefore contains a homogeneous second-order \
contribution corresponding to a uniform deceleration of magnitude ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c539efea-491a-9a47-9dca-995ff276d232"],
 " inherited from the global manifold evolution, which provides the physical \
origin of gravity in the local limit. This uniform deceleration defines the \
background acceleration field underlying local gravitational dynamics."
}], "Text",
 CellChangeTimes->{{3.9788173874230633`*^9, 3.9788173930463257`*^9}, {
   3.978817431739727*^9, 3.978817443285095*^9}, 3.978818482210308*^9, {
   3.9794972557621746`*^9, 3.9794972651223545`*^9}, {3.9794973231372395`*^9, 
   3.979497325527445*^9}, 3.979999544079056*^9, {3.9874127787741146`*^9, 
   3.987412799338375*^9}, {3.987413190286955*^9, 
   3.987413190772604*^9}},ExpressionUUID->"ca175a65-1a2a-ea40-b525-\
82fe86a4a998"],

Cell["\<\
The effective inward acceleration in a bound system decomposes into a \
homogeneous background and a sourced concentration,\
\>", "Text",
 CellChangeTimes->{
  3.987413194708206*^9},ExpressionUUID->"416ede50-c696-2c4f-aa46-\
91973d4931be"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["in", FontSlant -> "Plain"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["bg", FontSlant -> "Plain"]], "+", 
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["conc", FontSlant -> "Plain"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "$a_ {\\mathrm {in}} (r) = a_ {\\mathrm {bg}} + a_ {\\mathrm {conc}} (r) \
$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.9815369845838203`*^9, {3.9874132045739193`*^9, 
   3.987413209072729*^9}},ExpressionUUID->"0c91ee70-4b1c-1840-ac7f-\
f541fd335df2"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["a", "in"],
    $CellContext`inwardAcceleration], "[", "r_", "]"}], "=", 
  RowBox[{
   RowBox[{"-", "A"}], "-", 
   FractionBox[
    RowBox[{"G", " ", 
     RowBox[{"M", "[", "r", "]"}]}], 
    SuperscriptBox["r", "2"]]}]}]], "Input",
 CellChangeTimes->{{3.9777621265832977`*^9, 3.977762198676071*^9}, {
  3.9777625344269733`*^9, 3.9777625359150524`*^9}},
 CellLabel->"In[88]:=",ExpressionUUID->"8b721936-9292-0842-9659-f73502eef8ff"],

Cell[BoxData[
 RowBox[{
  RowBox[{"-", "A"}], "-", 
  FractionBox[
   RowBox[{"G", " ", 
    RowBox[{"M", "[", "r", "]"}]}], 
   SuperscriptBox["r", "2"]]}]], "Output",
 CellChangeTimes->{3.9877517623286057`*^9},
 CellLabel->"Out[88]=",ExpressionUUID->"fc60e201-967a-d845-a681-c81e78af860f"]
}, Open  ]],

Cell[TextData[{
 "The background term ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["a", "TI"], 
        StyleBox["bg", FontSlant -> "Plain"]], TraditionalForm], 
     "errors" -> {}, "input" -> "$a_{\\mathrm{bg}}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "27fb6c53-6a0f-5642-b3cd-bc584baae6fc"],
 " is uniform and has constant magnitude ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "004b3fd1-5774-f241-9a3c-5987e7d6c709"],
 ". In the absence of localized content, it defines the manifold evolution, \
and an inertial frame follows it without inducing concentration or depletion. \
Localized inertial content, however, resists this acceleration, \
redistributing the flux into spatial concentrations that define the sourced \
gravitational component ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["conc", FontSlant -> "Plain"]], "(", 
         StyleBox["x", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$a_{\\mathrm{conc}}(x)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6a0a3e66-d22c-a644-a04b-c95f8c18b5e7"],
 " governing bound dynamics. The inertial parameter ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["m", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$m$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "56ea75ef-2582-c847-8c77-392203952bf6"],
 " entering this redistribution is the same quantity that weights the \
invariant separation in the construction of geometric action, so that the \
gravitational response corresponds to a redistribution of the \
inertia-weighted action-space separation underlying the local geometry."
}], "Text",
 CellChangeTimes->{{3.9874132340172462`*^9, 
  3.9874132617438126`*^9}},ExpressionUUID->"9be798bf-def5-7347-85f7-\
641bd8a1223d"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Minimal Local Closure", "Subsection",
 CellChangeTimes->{
  3.9874133218178043`*^9},ExpressionUUID->"a169a159-dc87-9645-9816-\
2aaca04f34a6"],

Cell[TextData[{
 "The bilocal construction fixes the homogeneous background acceleration \
scale ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "484a6af7-0b1b-564d-92b4-4185170c4521"],
 " through the second-order local reduction of the manifold extent but does \
not determine the sourced concentration arising from spatial variations in \
inertial resistance. A weak-field closure is therefore required."
}], "Text",
 CellChangeTimes->{{3.9874133343556747`*^9, 
  3.98741335909037*^9}},ExpressionUUID->"11dbe09a-0ca2-c643-b6f9-\
405f6cbd53be"],

Cell[TextData[{
 "We adopt a minimal closure as the lowest-order local form consistent with \
locality, linearity in enclosed inertial content, rotational invariance, and \
additivity. These conditions restrict the sourced field to a divergence \
relation as the leading-order connection between field structure and inertial \
content, rather than an assumed inverse-square form. The concentration field \
therefore satisfies a divergence proportional to a local inertial density, \
with enclosed content given by its volume integral. In the weak-field limit, \
this density is dominated by rest mass and reduces to the baryonic density. \
All intrinsic kinematic scales are fixed by the acceleration scale ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "960e7e64-a929-eb4d-b69e-20f4b8330abf"],
 ", while the constant ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["G", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$G$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "86a44457-738d-9349-b17e-e83650394e3a"],
 " sets the coupling to localized inertial content without introducing an \
additional kinematic scale."
}], "Text",
 CellChangeTimes->{{3.9874133458818073`*^9, 
  3.987413376579672*^9}},ExpressionUUID->"e529194e-8e11-8942-986e-\
152e0c0355ff"],

Cell["\<\
For a spherically symmetric configuration the sourced acceleration is radial,\
\>", "Text",
 CellChangeTimes->{{3.975862546698141*^9, 3.975862548800514*^9}, 
   3.9758626604879704`*^9, {3.9758626984177437`*^9, 3.9758627444676228`*^9}, {
   3.9758628695233*^9, 3.9758628969873466`*^9}, 3.9758644081007767`*^9, {
   3.9759372759096336`*^9, 3.9759373015326424`*^9}, {3.975937671968586*^9, 
   3.975937704139902*^9}, {3.975937744768461*^9, 3.9759377927578106`*^9}, {
   3.975937860747532*^9, 3.9759378827876377`*^9}, {3.9759379207221603`*^9, 
   3.975937925005535*^9}, {3.9759379561373234`*^9, 3.9759379587607536`*^9}, 
   3.9759380063343315`*^9, {3.9759702903948116`*^9, 3.975970294550562*^9}, {
   3.976134659481037*^9, 3.9761346594967957`*^9}, {3.977252794289953*^9, 
   3.9772528063895626`*^9}, 3.977595043110508*^9, {3.9777511406183376`*^9, 
   3.9777511608657684`*^9}, {3.9777597972835674`*^9, 3.977759816803934*^9}, {
   3.97776382418124*^9, 3.97776382418124*^9}, {3.9778578986616116`*^9, 
   3.9778579050456944`*^9}, {3.97999955680674*^9, 3.979999571286064*^9}, 
   3.9874134927656574`*^9},ExpressionUUID->"ef63ee23-ee15-0b40-82ac-\
557ff4d8c352"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["a", FontSlant -> "Bold"], 
          StyleBox["conc", FontSlant -> "Plain"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["r", "TI"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], " ", 
         OverscriptBox[
          StyleBox["r", "TI"], "^"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\mathbf a_ {\\mathrm {conc}} (r) = a_r (r)\\, \\hat r$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{
  3.9815372726267986`*^9, {3.987413504192276*^9, 
   3.9874135082871914`*^9}},ExpressionUUID->"0aa27532-44da-514c-ac2a-\
97314b617cee"],

Cell[TextData[{
 "In the local-reduction regime relevant for gravitationally bound systems, \
the concentration field resides in three spatial dimensions, so spherical \
symmetry is defined with respect to ordinary 2-spheres in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SuperscriptBox[
        StyleBox["R", FontSlant -> "Plain"], "3"], TraditionalForm], 
     "errors" -> {}, "input" -> "$\\mathbb{R}^3$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2dbe593f-26bd-784d-a801-375bb84403e3"],
 ". The flux through a sphere of radius ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$r$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "96f320a9-9a48-da41-95c9-1fda99cda413"],
 " is"
}], "Text",
 CellChangeTimes->{{3.987413526947872*^9, 
  3.987413541107872*^9}},ExpressionUUID->"2cf36254-822f-3947-a0da-\
d0987d4f466d"],

Cell[BoxData[
 FormBox[
  TemplateBox[<|"boxes" -> FormBox[
      RowBox[{"\[CapitalPhi]", 
        RowBox[{"(", 
          StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
        SubscriptBox["\[ContourIntegral]", 
         StyleBox["S", "TI"]], 
        SubscriptBox[
         StyleBox["a", FontSlant -> "Bold"], 
         StyleBox["conc", FontSlant -> "Plain"]], "\[CenterDot]", 
        StyleBox["d", "TI"], 
        StyleBox["S", FontSlant -> "Bold"]}], TraditionalForm], 
    "errors" -> {}, "input" -> 
    "$\\Phi(r)=\\oint_S \\mathbf a_{\\mathrm{conc}}\\cdot d\\mathbf S$", 
    "state" -> "Boxes"|>,
   "TeXAssistantTemplate"], TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9874135549513245`*^9, 3.9874135581010723`*^9}, {
  3.9874911012081604`*^9, 
  3.987491101218361*^9}},ExpressionUUID->"2fbd8182-26e7-8d4a-bf35-\
abb1013cec30"],

Cell["\<\
Imposing flux conservation together with linearity in the enclosed inertial \
content gives\
\>", "Text",
 CellChangeTimes->{
  3.9874135697562237`*^9},ExpressionUUID->"2dcf2962-01e8-8f44-9e72-\
c5b2833c1917"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[ContourIntegral]", 
          StyleBox["S", "TI"]], 
         SubscriptBox[
          StyleBox["a", FontSlant -> "Bold"], 
          StyleBox["conc", FontSlant -> "Plain"]], "\[CenterDot]", 
         StyleBox["d", "TI"], 
         StyleBox["S", FontSlant -> "Bold"], "\[LongEqual]", "-4", "\[Pi]", 
         StyleBox["G", "TI"], 
         StyleBox["M", "TI"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "$\\oint_S \\mathbf a_{\\mathrm{conc}}\\cdot d\\mathbf S = -4\\pi G \
M(r)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9874135821154404`*^9, 3.9874135865885944`*^9}, {
  3.9874911211398735`*^9, 
  3.987491121145115*^9}},ExpressionUUID->"18897616-c9e7-154e-b5b6-\
deb53939f8e3"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["M", "TI"], "(", 
         StyleBox["r", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$M(r)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "41aa8f25-6727-4b44-84e1-d21560a1fe17"],
 " is the enclosed inertial content within radius ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$r$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b7fe946a-aca6-cd4c-8df0-cea2f67aeed1"],
 ", obtained from the local density by"
}], "Text",
 CellChangeTimes->{{3.987413892154417*^9, 
  3.9874139011310787`*^9}},ExpressionUUID->"61284952-e293-714a-bc2a-\
01753e26411e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["M", "TI"], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox["\[Integral]", 
          StyleBox["V", "TI"]], 
         SubscriptBox["\[Rho]", 
          StyleBox["inertial", FontSlant -> "Plain"]], "\[DifferentialD]", 
         StyleBox["V", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$M(r)=\\int_V \\rho_{\\mathrm{inertial}}\\,dV$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987414007480673*^9, 3.9874140119683895`*^9}, {
  3.9874911353081245`*^9, 
  3.987491135314129*^9}},ExpressionUUID->"5d821766-6bcd-624d-b1d9-\
e265309cb672"],

Cell[TextData[{
 "and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["G", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$G$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cdf16f01-94d2-7447-a041-a816f698eda8"],
 " is the empirical coupling relating inertial content to concentration of \
the background acceleration. Spherical symmetry then yields"
}], "Text",
 CellChangeTimes->{{3.987414024654497*^9, 
  3.9874140550191574`*^9}},ExpressionUUID->"1f82156c-f437-2149-886e-\
098746497873"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["a", FontSlant -> "Bold"], 
          StyleBox["conc", FontSlant -> "Plain"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", "-", 
         FractionBox[
          RowBox[{
            StyleBox["G", "TI"], 
            StyleBox["M", "TI"], 
            RowBox[{"(", 
              StyleBox["r", "TI"], ")"}]}], 
          SuperscriptBox[
           StyleBox["r", "TI"], "2"]], " ", 
         OverscriptBox[
          StyleBox["r", "TI"], "^"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "$\\mathbf a_{\\mathrm{conc}}(r)=-\\frac{G M(r)}{r^2}\\,\\hat r$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9874140642525024`*^9, 3.98741406799263*^9}, {
  3.9874911588539944`*^9, 
  3.987491158856529*^9}},ExpressionUUID->"c996abb3-9205-3645-b416-\
c5addfc48152"],

Cell["and Gauss\[CloseCurlyQuote]s theorem gives", "Text",
 CellChangeTimes->{
  3.9874156381857605`*^9},ExpressionUUID->"676d258b-9ea9-c248-80bb-\
1595ecdeb08d"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Del]", "\[NegativeThinSpace]", "\[CenterDot]", 
         SubscriptBox[
          StyleBox["a", FontSlant -> "Bold"], 
          StyleBox["conc", FontSlant -> "Plain"]], "\[LongEqual]", "-4", 
         "\[Pi]", 
         StyleBox["G", "TI"], 
         SubscriptBox["\[Rho]", 
          StyleBox["inertial", FontSlant -> "Plain"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\nabla\\!\\cdot \\mathbf{a}_{\\mathrm{conc}} = -4\\pi G \
\\rho_{\\mathrm{inertial}}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9874156466895885`*^9, 3.987415650119858*^9}, {
  3.987491166297352*^9, 
  3.9874911663017464`*^9}},ExpressionUUID->"84c4ddd4-62cb-694f-924f-\
3f8d3fc1b530"],

Cell[TextData[{
 "which is the Poisson equation for the sourced weak-field limit. In the \
weak-field regime relevant for galactic dynamics, the inertial density is \
dominated by baryonic rest-mass contributions, so ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Rho]", 
          StyleBox["inertial", FontSlant -> "Plain"]], "\[TildeTilde]", 
         SubscriptBox["\[Rho]", 
          StyleBox["b", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\rho_{\\mathrm{inertial}}\\approx\\rho_b$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7aa1d042-944a-254b-8e1e-52ddd00a730a"],
 "."
}], "Text",
 CellChangeTimes->{{3.987415674048332*^9, 
  3.9874156857319756`*^9}},ExpressionUUID->"7eb2ec82-e384-ce4a-96aa-\
9266373dc2d9"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Circular Orbits", "Subsection",
 CellChangeTimes->{
  3.9874156966787167`*^9},ExpressionUUID->"9cfc56e9-2c54-4b4e-81d3-\
9346fbb85a50"],

Cell[TextData[{
 "For a body in a circular orbit of radius ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["r", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$r$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6b9935ab-bdac-3045-b951-4933d24eb5c8"],
 " with tangential speed ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["v", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$v$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "761dc495-03b1-404d-8812-741baf0991d3"],
 ", the required centripetal acceleration is"
}], "Text",
 CellChangeTimes->{
  3.9874157104063225`*^9, {3.98741697646084*^9, 
   3.9874169798679256`*^9}},ExpressionUUID->"8f8a98f1-c292-4b45-9aee-\
f5ab90a66c91"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["a", "TI"], 
          StyleBox["cent", FontSlant -> "Plain"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", "-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["v", "TI"], "2"], 
          StyleBox["r", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$a_{\\mathrm{cent}}(r) = -\\frac{v^2}{r}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987415721762703*^9, 3.9874157265400066`*^9}, {
  3.9874911831756535`*^9, 
  3.9874911831756535`*^9}},ExpressionUUID->"4ad4de0e-bec2-7049-be58-\
99ee9abd5631"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    InterpretationBox[
     SubscriptBox["a", "cent"],
     $CellContext`centrifugalAcceleration], "[", "r_", "]"}], "=", 
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox["v", "2"], "r"]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.977764493666857*^9, 3.977764522903763*^9}, {
   3.977764640374361*^9, 3.977764644616535*^9}, 3.987415735646837*^9, 
   3.9874165721698017`*^9},
 CellLabel->"In[89]:=",ExpressionUUID->"c7108f9d-3d02-a64d-85f5-096ce34c40b0"],

Cell["\<\
Equating this with the inward acceleration from equation (27) gives\
\>", "Text",
 CellChangeTimes->{{3.9874158874529667`*^9, 3.9874158939427357`*^9}, {
  3.987416999550274*^9, 
  3.9874169996435013`*^9}},ExpressionUUID->"9a430974-2177-2142-84d0-\
9cd4a2b78049"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"-", 
         FractionBox[
          SuperscriptBox[
           StyleBox["v", "TI"], "2"], 
          StyleBox["r", "TI"]], "\[LongEqual]", "-", 
         StyleBox["A", "TI"], "-", 
         FractionBox[
          RowBox[{
            StyleBox["G", "TI"], 
            SubscriptBox[
             StyleBox["M", "TI"], 
             StyleBox["b", "TI"]], 
            RowBox[{"(", 
              StyleBox["r", "TI"], ")"}]}], 
          SuperscriptBox[
           StyleBox["r", "TI"], "2"]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$-\\frac{v^2}{r} = -A - \\frac{G M_b(r)}{r^2}$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987415904703785*^9, 3.9874159095053577`*^9}, {
  3.9874912001242714`*^9, 
  3.987491200139969*^9}},ExpressionUUID->"eb5eb807-dae3-8a42-9bca-\
f06b5fc50d57"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"circularOrbitCondition", "=", 
  RowBox[{
   RowBox[{
    InterpretationBox[
     SubscriptBox["a", "cent"],
     $CellContext`centrifugalAcceleration], "[", "r", "]"}], "\[Equal]", 
   RowBox[{
    InterpretationBox[
     SubscriptBox["a", "in"],
     $CellContext`inwardAcceleration], "[", "r", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9777512406128235`*^9, 3.977751259362673*^9}, {
  3.9874168114878807`*^9, 3.9874168132283897`*^9}},
 CellLabel->"In[90]:=",ExpressionUUID->"a41ff245-92a6-0341-8bc3-57eb22d71599"],


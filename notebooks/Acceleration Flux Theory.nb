Cell["\<\
Figure 1. Schematic representation of the complex parabolic metric manifold. \
Latitude lines correspond to spatial slices at fixed epoch, while longitude \
lines trace the temporal evolution of the manifold.\
\>", "Text",
 CellChangeTimes->{{3.981656319220955*^9, 3.98165632792692*^9}, {
  3.981659460625702*^9, 3.9816594673888664`*^9}, {3.98165965118132*^9, 

Cell[CellGroupData[{

Cell["Cosmic Time", "Subsection",
 CellChangeTimes->{{3.987601373145241*^9, 
  3.9876013767375546`*^9}},ExpressionUUID->"feff74e8-d256-1d42-b627-\
d77e01341366"],

Cell["\<\
The redshift\[Dash]time relation differs from standard cosmological evolution \
due to the underlying parabolic evolution. Table II compares the resulting \
cosmic times with those from FLRW algorithms.\
\>", "Text",
 CellChangeTimes->{{3.9876013879264812`*^9, 3.9876014017707577`*^9}, {
  3.987704930859825*^9, 
  3.9877049315541687`*^9}},ExpressionUUID->"f6a65771-b403-ac4f-a49d-\
e81461e6fec8"],

Cell["\<\
The parabolic expansion yields uniformly larger cosmic ages than FLRW, \
significantly extending the available time for early structure formation.\
\>", "Text",
 CellChangeTimes->{
  3.987602906024454*^9},ExpressionUUID->"4cf6b04a-40b5-4040-ae93-\
76cf463c629e"],


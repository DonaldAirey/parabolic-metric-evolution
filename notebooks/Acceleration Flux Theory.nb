  "In[229]:=",ExpressionUUID->"6981617b-70df-4843-9d37-73aa627d9e26"],

Cell["giving the sound speed", "Text",
 CellChangeTimes->{{3.9816397904092445`*^9, 3.981639860130598*^9}, 
   3.987617554561718*^9},ExpressionUUID->"ac1eb737-fc23-4f4a-9d90-\
af8674ebb1ca"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["s", "TI"]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["c", "TI"], 
             StyleBox["c", FontSlant -> "Plain"]], "(", 
            StyleBox["t", "TI"], ")"}], 
          SqrtBox[
           RowBox[{"3", "(", 
             RowBox[{"1", "+", 
               StyleBox["R", "TI"], 
               RowBox[{"(", 
                 StyleBox["t", "TI"], ")"}]}], ")"}]]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$c_s(t)=\\frac{c_{\\mathrm{c}}(t)}{\\sqrt{3\\left(1+R(t)\\right)}}$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987617617442564*^9, 3.9876176225213203`*^9}, {
  3.987706339307007*^9, 
  3.987706339317272*^9}},ExpressionUUID->"7b475a72-17c9-a54e-9c72-\
969403321d10"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["c", "c"],
    $CellContext`speedOfCausality], "[", "t_", "]"}], ":=", 
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", 
     InterpretationBox[
      SubscriptBox["d", "ch"],
      $CellContext`causalityHorizon], ")"}], "\[Prime]",
    MultilineFunction->None], "[", "t", "]"}]}]], "Input",
 CellChangeTimes->{{3.9807845134778156`*^9, 3.9807845367750664`*^9}, {
   3.980784586780138*^9, 3.980784587612999*^9}, 3.980784785338175*^9, 
   3.980785049805769*^9, {3.98078586500811*^9, 3.980785913839901*^9}, {
   3.9807860978547535`*^9, 3.980786152558563*^9}, {3.980786442487297*^9, 
   3.980786467972254*^9}, {3.980786635282736*^9, 3.9807867147824306`*^9}, 
   3.980787232655176*^9, 3.9807872783156967`*^9, 3.981127574683861*^9, 
   3.981277832607111*^9, {3.9812780411088696`*^9, 3.981278052101223*^9}, 
   3.9812781054839745`*^9, {3.981301157900543*^9, 3.98130117285384*^9}, 
   3.981301220572571*^9, {3.981642113089916*^9, 3.981642122528515*^9}, {
   3.9876220423998585`*^9, 3.987622052792244*^9}},
 CellLabel->
  "In[230]:=",ExpressionUUID->"70ec9758-2336-8942-856b-10a39524cd05"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["c", "s"],
    $CellContext`speedOfSound], "[", 
   RowBox[{"t_", "?", "QuantityQ"}], "]"}], ":=", 
  FractionBox[
   RowBox[{
    InterpretationBox[
     SubscriptBox["c", "c"],
     $CellContext`speedOfCausality], "[", "t", "]"}], 
   SqrtBox[
    RowBox[{"3", " ", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       RowBox[{"R", "[", "t", "]"}]}], ")"}]}]]]}]], "Input",
 CellChangeTimes->{{3.980786712283993*^9, 3.9807867125820274`*^9}, 
   3.981127580690407*^9, {3.981643995921671*^9, 3.9816439964472275`*^9}, {
   3.987621394652937*^9, 3.9876214031486073`*^9}, {3.9876220594375706`*^9, 
   3.9876220646312428`*^9}},
 CellLabel->
  "In[231]:=",ExpressionUUID->"9948934e-ed26-3041-8399-9f7ab35ea7c7"],

Cell[TextData[{
 "The causal expansion rate ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["c", FontSlant -> "Plain"]], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$c_{\\mathrm{c}}(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "95f9ddcf-dc01-3044-8083-8775619e4bb4"],
 " sets the rate at which interactions can be ordered through the operational \
clock and thus defines the effective causal scale entering the acoustic \
horizon integral, so that the sound horizon is"
}], "Text",
 CellChangeTimes->{{3.9876176324516506`*^9, 
  3.9876176444317207`*^9}},ExpressionUUID->"46831ff0-b6cc-424d-b87c-\
9124a6c12da6"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["s", "TI"]], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", "0", 
          SubscriptBox[
           StyleBox["t", "TI"], "*"]], 
         SubscriptBox[
          StyleBox["c", "TI"], 
          StyleBox["s", "TI"]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[DifferentialD]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$r_s=\\int_0^{t_*} c_s(t)\\,dt$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987617652931238*^9, 3.987617660724493*^9}, {
  3.9877064294267616`*^9, 
  3.9877064294267616`*^9}},ExpressionUUID->"94997fbf-ea3b-bc4c-9489-\
13baa947421e"],

Cell[TextData[{
 "Evaluating this expression using the manifold parameters yields ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["s", "TI"]], "\[LongEqual]", "3.7 ", 
         StyleBox["Mpc", FontSlant -> "Plain"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "$r_s=3.7\\,\\mathrm{Mpc}$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "193ee32f-594a-7249-8ed4-201d8fb4f2ee"],
 "."
}], "Text",
 CellChangeTimes->{{3.987617686210024*^9, 
  3.9876176916192207`*^9}},ExpressionUUID->"11a85636-e89b-8549-b3ef-\
f9caff579583"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["r", "s"],
    $CellContext`soundHorizon], "=", 
   RowBox[{"NIntegrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       InterpretationBox[
        SubscriptBox["c", "s"],
        $CellContext`speedOfSound], "[", 
       InterpretationBox[
        SuperscriptBox["t", "\[Prime]"],
        $CellContext`timeIterator], "]"}], "/.", "\[VeryThinSpace]", 
      "initialConditions"}], ",", 
     RowBox[{"{", 
      RowBox[{
       InterpretationBox[
        SuperscriptBox["t", "\[Prime]"],
        $CellContext`timeIterator], ",", "0", ",", 
       InterpretationBox[
        SubscriptBox["t", "*"],
        $CellContext`timeOfRecombination]}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{"UnitConvert", "[", 
  RowBox[{
   InterpretationBox[
    SubscriptBox["r", "s"],
    $CellContext`soundHorizon], ",", "\"\<Megaparsecs\>\""}], "]"}]}], "Input",
 CellChangeTimes->{
  3.980787284374134*^9, {3.9807907974258823`*^9, 3.9807908426472473`*^9}, 
   3.9807909929467335`*^9, {3.980791256693756*^9, 3.9807912836597652`*^9}, {
   3.9807918485548725`*^9, 3.9807918947538376`*^9}, {3.981276426860876*^9, 
   3.9812764337987423`*^9}, {3.9813010703915176`*^9, 
   3.9813011046622677`*^9}, {3.987621365925455*^9, 3.9876213842210217`*^9}},
 CellLabel->
  "In[232]:=",ExpressionUUID->"0e15eca3-0399-c948-87e9-8359bef2b725"],

Cell[BoxData[
 TemplateBox[{
  "3.690921866376803`", "\"Mpc\"", "megaparsecs", "\"Megaparsecs\""},
  "Quantity"]], "Output",
 CellChangeTimes->{3.9877518745676155`*^9},
 CellLabel->
  "Out[233]=",ExpressionUUID->"db654d36-e802-9d47-982c-4b2cb832b9c7"]

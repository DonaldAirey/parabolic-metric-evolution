   RowBox[{"M", "[", "L_", "]"}], "=", 
   RowBox[{
    FractionBox[
     RowBox[{"4", "\[Pi]"}], "3"], 
    SuperscriptBox["L", "3"], 
    InterpretationBox[
     SubscriptBox["\[Rho]", "b"],
     $CellContext`baryonDensity]}]}], ";"}]], "Input",

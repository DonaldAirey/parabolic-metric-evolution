Cell[TextData[{
 "With the manifold acceleration ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "01a5bea5-1cb4-a244-b445-c9f311864832"],
 " determined from the baryonic Tully-Fisher analysis, the Cepheid-calibrated \
Pantheon+ subset is used to determine the observation epoch ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["o", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_o$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "47c73613-ad2e-2940-a0fd-35793419cb16"],
 " on the absolute distance scale. For each candidate value of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["o", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_o$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d58f5cb7-8465-2540-89e4-75b5deb702a1"],
 ", the corresponding ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["V", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "$V_0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1bb00c42-2d99-bb4a-ba0a-1d69b2bd384c"],
 " follows algebraically from equation (67), and theoretical distance moduli ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", 
          StyleBox["th", FontSlant -> "Plain"]], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\mu_{\\mathrm{th}}(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a1091973-9231-094e-b33b-cac691c92108"],
 " are evaluated at the calibration-set redshifts. These are compared with \
the observed values ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", 
          StyleBox["obs", FontSlant -> "Plain"]], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\mu_{\\mathrm{obs}}(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ad5c09c4-b0d6-ef45-b9a8-030575696a98"],
 ", defining the residual vector"
}], "Text",
 CellChangeTimes->{{3.987591295045885*^9, 3.9875913521762104`*^9}, {
  3.9877046986496735`*^9, 
  3.9877046987955837`*^9}},ExpressionUUID->"6fb8f582-ca5e-4c4e-bf46-\
cacba625350c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["i", "TI"]], "\[LongEqual]", 
         SubscriptBox["\[Mu]", 
          StyleBox["obs", FontSlant -> "Plain"]], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], 
            StyleBox["i", "TI"]], ")"}], "-", 
         SubscriptBox["\[Mu]", 
          StyleBox["th", FontSlant -> "Plain"]], 
         RowBox[{"(", 
           SubscriptBox[
            StyleBox["z", "TI"], 
            StyleBox["i", "TI"]], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "$r_i = \\mu_{\\mathrm{obs}}(z_i) - \\mu_{\\mathrm{th}}(z_i)$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.98759135364579*^9, 3.98759135652087*^9}, {
  3.9877048144374084`*^9, 
  3.987704814443802*^9}},ExpressionUUID->"c2414f55-07ff-9346-a483-\
4ab52f1526f7"],

Cell["\<\
The best-fit observation epoch is obtained by minimizing the \
covariance-weighted chi-square statistic\
\>", "Text",
 CellChangeTimes->{
  3.987591367597971*^9},ExpressionUUID->"21571d8e-0842-e74e-8ffe-\
78f36194e8bf"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Chi]", "2"], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["T", FontSlant -> "Plain"]], 
         SuperscriptBox[
          StyleBox["C", "TI"], "-1"], 
         StyleBox["r", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\chi^2 = r^{\\mathrm T} C^{-1} r$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987591377379915*^9, 3.9875913802384453`*^9}, {
  3.9877048272348003`*^9, 
  3.9877048272348003`*^9}},ExpressionUUID->"7cd7659d-bbeb-714a-af1d-\
642e17a24aae"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["C", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$C$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "91fe0013-66cb-a14a-b218-abe5059727e4"],
 " is the full Pantheon+ STAT+SYS covariance matrix. The resulting best-fit \
value of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["o", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_o$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c7c41f46-cb93-004a-999f-8e9322f295ab"],
 " then determines ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["V", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "$V_0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "08e8daaf-220e-0347-b091-a4c39cc4fda8"],
 ", completing the kinematic parameter set. The resulting parameters are \
listed in Table 1."
}], "Text",
 CellChangeTimes->{{3.987591394020582*^9, 
  3.987591416534109*^9}},ExpressionUUID->"340d6225-f9b4-1848-a5ef-\
71ce573cca19"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
  "pantheonDirectory", 
   "=", "\"\<https://github.com/PantheonPlusSH0ES/DataRelease/raw/refs/heads/\
main/Pantheon+_Data/4_DISTANCES_AND_COVAR/\>\""}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dataUrl", "=", 
   RowBox[{"StringJoin", "[", 
    RowBox[{"pantheonDirectory", ",", "\"\<Pantheon+SH0ES.dat\>\""}], "]"}]}],
   ";"}], "\n", 
 RowBox[{
  RowBox[{"covarianceUrl", "=", 
   RowBox[{"StringJoin", "[", 
    RowBox[{"pantheonDirectory", ",", "\"\<Pantheon+SH0ES_STAT+SYS.cov\>\""}],
     "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"pantheonData", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"dataUrl", ",", "\"\<Table\>\"", ",", 
     RowBox[{"HeaderLines", "->", "1"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"covarianceData", "=", 
   RowBox[{"Import", "[", 
    RowBox[{"covarianceUrl", ",", "\"\<Table\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"rawCovariance", "=", 
   RowBox[{"Flatten", "[", "covarianceData", "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"dimensionSize", "=", 
   RowBox[{"rawCovariance", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"covarianceMatrix", "=", 
   RowBox[{"ArrayReshape", "[", 
    RowBox[{
     RowBox[{"Rest", "[", "rawCovariance", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"dimensionSize", ",", "dimensionSize"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cephidMask", "=", 
   RowBox[{"pantheonData", "[", 
    RowBox[{"[", 
     RowBox[{"All", ",", "14"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cephidIndices", "=", 
   RowBox[{"Flatten", "@", 
    RowBox[{"Position", "[", 
     RowBox[{"cephidMask", ",", "1"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"supernovaIndices", "=", 
   RowBox[{"Flatten", "@", 
    RowBox[{"Position", "[", 
     RowBox[{"cephidMask", ",", "0"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"cephidData", "=", 
   RowBox[{"pantheonData", "[", 
    RowBox[{"[", "cephidIndices", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cephidRedshifts", "=", 
   RowBox[{"N", "@", 
    RowBox[{"cephidData", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cephidDistanceModuli", "=", 
   RowBox[{"N", "@", 
    RowBox[{"cephidData", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "13"}], "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cephidCovarianceMatrix", "=", 
   RowBox[{"covarianceMatrix", "[", 
    RowBox[{"[", 
     RowBox[{"cephidIndices", ",", "cephidIndices"}], "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"cephidCovarianceMatrix", "=", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"cephidCovarianceMatrix", "+", 
       RowBox[{"Transpose", "[", "cephidCovarianceMatrix", "]"}]}], ")"}], "/",
      "2"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"supernovaData", "=", 
   RowBox[{"pantheonData", "[", 
    RowBox[{"[", "supernovaIndices", "]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"supernovaRedshifts", "=", 
   RowBox[{"N", "@", 
    RowBox[{"supernovaData", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "3"}], "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"supernovaDistanceModuli", "=", 
   RowBox[{"N", "@", 
    RowBox[{"supernovaData", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "11"}], "]"}], "]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"supernovaCovarianceMatrix", "=", 
   RowBox[{"covarianceMatrix", "[", 
    RowBox[{"[", 
     RowBox[{"supernovaIndices", ",", "supernovaIndices"}], "]"}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"supernovaCovarianceMatrix", "=", 
   RowBox[{"N", "[", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"supernovaCovarianceMatrix", "+", 
       RowBox[{"Transpose", "[", "supernovaCovarianceMatrix", "]"}]}], ")"}], 
     "/", "2"}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.983474124792448*^9, 3.9834741248060856`*^9}, {
  3.983522599848316*^9, 3.983522606769785*^9}},
 CellLabel->
  "In[138]:=",ExpressionUUID->"05cd7615-7e2b-3542-ae4d-37a6254b9996"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"pc", "\[Rule]", 
      RowBox[{"QuantityMagnitude", "[", 
       RowBox[{"UnitConvert", "[", 
        RowBox[{
         RowBox[{"Quantity", "[", 
          RowBox[{"1", ",", "\"\<Parsecs\>\""}], "]"}], 
         ",", "\"\<Meters\>\""}], "]"}], "]"}]}], ",", 
     RowBox[{"c", "\[Rule]", 
      RowBox[{"QuantityMagnitude", "[", 
       RowBox[{"UnitConvert", "[", 
        RowBox[{
         RowBox[{"Quantity", "[", "\"\<SpeedOfLight\>\"", "]"}], ",", 
         FractionBox["\"\<Meters\>\"", "\"\<Seconds\>\""]}], "]"}], "]"}]}], ",", 
     RowBox[{"A", "\[Rule]", 
      RowBox[{"QuantityMagnitude", "[", 
       InterpretationBox[
        StyleBox["\[ScriptCapitalA]",
         FontFamily->"Times"],
        $CellContext`accelerationSI], "]"}]}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   InterpretationBox[
    SuperscriptBox["\[Chi]", "2"],
    $CellContext`chiSquared], "[", 
   RowBox[{"t_", "?", "NumericQ"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     InterpretationBox[
      OverscriptBox["r", "\[RightArrow]"],
      $CellContext`residuals], "}"}], ",", 
    RowBox[{
     RowBox[{
      InterpretationBox[
       OverscriptBox["r", "\[RightArrow]"],
       $CellContext`residuals], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         InterpretationBox[
          SubscriptBox["\[Mu]", "cep"],
          $CellContext`cephidDistanceModuli], "-", 
         RowBox[{
          InterpretationBox[
           SubscriptBox["\[Mu]", "pme"],
           $CellContext`pmePrediction], "/@", 
          InterpretationBox[
           SubscriptBox["z", "cep"],
           $CellContext`cephidRedshifts]}]}], "/.", "\[VeryThinSpace]", 
        "params"}], "/.", "\[VeryThinSpace]", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          InterpretationBox[
           SubscriptBox["t", "o"],
           $CellContext`observationTime], "\[Rule]", "t"}], ",", 
         RowBox[{
          InterpretationBox[
           SubscriptBox["V", "0"],
           $CellContext`initialVelocity], "\[Rule]", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"velocity", "/.", "\[VeryThinSpace]", "params"}], "/.", 
            "\[VeryThinSpace]", 
            RowBox[{"{", 
             RowBox[{
              InterpretationBox[
               SubscriptBox["t", "o"],
               $CellContext`observationTime], "\[Rule]", "t"}], "}"}]}], 
           ")"}]}]}], "}"}]}]}], ";", 
     RowBox[{
      InterpretationBox[
       OverscriptBox["r", "\[RightArrow]"],
       $CellContext`residuals], ".", 
      RowBox[{"LinearSolve", "[", 
       RowBox[{"cephidCovarianceMatrix", ",", 
        InterpretationBox[
         OverscriptBox["r", "\[RightArrow]"],
         $CellContext`residuals]}], "]"}]}]}]}], "]"}]}], "\n", 
 RowBox[{
  RowBox[{"result", "=", 
   RowBox[{"FindMinimum", "[", 
    RowBox[{
     RowBox[{
      InterpretationBox[
       SuperscriptBox["\[Chi]", "2"],
       $CellContext`chiSquared], "[", 
      RowBox[{"Exp", "[", 
       InterpretationBox[
        SubscriptBox["t", "log"],
        $CellContext`logTime], "]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{
       InterpretationBox[
        SubscriptBox["t", "log"],
        $CellContext`logTime], ",", 
       RowBox[{"Log", "[", 
        SuperscriptBox["10", "17"], "]"}]}], "}"}], ",", 
     RowBox[{"Method", "\[Rule]", "\"\<QuasiNewton\>\""}], ",", 
     RowBox[{"AccuracyGoal", "\[Rule]", "6"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.9767374162277317`*^9, 3.9767374891812744`*^9}, 

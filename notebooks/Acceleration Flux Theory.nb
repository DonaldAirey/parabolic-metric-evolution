  "03be4b3a-b6ec-7c49-959c-ff5032e29556"],
 " and observation event ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["p", "TI"], 
        StyleBox["o", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$p_o$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a5a422c6-1945-9b47-90fd-5bb7f68e68d2"],
 ", showing the accumulated temporal evolution and the symmetric midpoint \
spatial separation between scaled slices."
}], "Text",
 CellChangeTimes->{{3.9753484139350166`*^9, 3.975348531513836*^9}, {
   3.97534856638657*^9, 3.975348651792795*^9}, {3.975439739203863*^9, 
   3.9754397783834248`*^9}, {3.975446635854849*^9, 3.975446635854849*^9}, {
   3.9761346586554127`*^9, 3.9761346586872864`*^9}, {3.9772256185399437`*^9, 
   3.9772256408051014`*^9}, {3.977226071717121*^9, 3.977226071717121*^9}, {
   3.9772409354818344`*^9, 3.9772409359885044`*^9}, 3.9772469129905796`*^9, 
   3.977247011236582*^9, {3.9774808127210007`*^9, 3.9774808132026787`*^9}, 
   3.977663077734682*^9, 3.9782680146341743`*^9, {3.9798205907966976`*^9, 
   3.9798206087154465`*^9}, {3.9798206570675335`*^9, 3.979820670357708*^9}, {
   3.979820704448889*^9, 3.979820784700493*^9}, {3.9816598589672413`*^9, 
   3.9816598590625877`*^9}, {3.987260457787777*^9, 
   3.987260469428404*^9}},ExpressionUUID->"72cc1c98-9383-b34d-804c-\
a35abcbca1cd"],

Cell[TextData[{
 "The bilocal construction is illustrated in Figure 2. The spatial slices \
scale with a global manifold extent ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$L(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ba684fef-94fe-ed43-a7b1-46e85a5273fd"],
 ", so the separations at emission and observation satisfy"
}], "Text",
 CellChangeTimes->{{3.9872602730395527`*^9, 3.9872602961952667`*^9}, {
  3.9872605172008553`*^9, 
  3.9872605172722874`*^9}},ExpressionUUID->"52bb16d1-861a-7c47-b34a-\
cc56fb391fa4"],

Cell[BoxData[
 RowBox[{
  FractionBox[
   InterpretationBox[
    SubsuperscriptBox["\[CapitalDelta]x", "e", "1"],
    $CellContext`\[CapitalDelta]xe1], 
   RowBox[{"L", "[", 
    InterpretationBox[
     SubscriptBox["t", "e"],
     $CellContext`emissionTime], "]"}]], "\[Equal]", 
  FractionBox[
   InterpretationBox[
    SubsuperscriptBox["\[CapitalDelta]x", "o", "1"],
    $CellContext`\[CapitalDelta]xo1], 
   RowBox[{"L", "[", 
    InterpretationBox[
     SubscriptBox["t", "o"],
     $CellContext`observationTime], "]"}]]}]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987277791626013*^9, 
  3.987277800840664*^9}},ExpressionUUID->"a282bd9e-19a2-144e-ad78-\
0cf4a1d21cc9"],

Cell[BoxData[
 RowBox[{
  RowBox[{"comovingRelation", "=", 
   RowBox[{
    FractionBox[
     InterpretationBox[
      SubsuperscriptBox["\[CapitalDelta]x", "e", "1"],
      $CellContext`\[CapitalDelta]xe1], 
     RowBox[{"L", "[", 
      InterpretationBox[
       SubscriptBox["t", "e"],
       $CellContext`emissionTime], "]"}]], "\[Equal]", 
    FractionBox[
     InterpretationBox[
      SubsuperscriptBox["\[CapitalDelta]x", "o", "1"],
      $CellContext`\[CapitalDelta]xo1], 
     RowBox[{"L", "[", 
      InterpretationBox[
       SubscriptBox["t", "o"],
       $CellContext`observationTime], "]"}]]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9872684145907135`*^9, 3.987268428678604*^9}, 
   3.9872685121394043`*^9, 3.987268667847103*^9},
 CellLabel->"In[72]:=",ExpressionUUID->"b2ea369d-c383-144f-ac2f-2630e7e13d4f"],

Cell["\<\
Imposing symmetry under interchange of emission and observation together with \
a smooth coincidence limit motivates adopting the midpoint average as the \
minimal symmetric choice,\
\>", "Text",
 CellChangeTimes->{
  3.9872603784273453`*^9},ExpressionUUID->"619087d0-9557-704b-a29d-\
08ece7e62e1f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "1"], "\[LongEqual]", "\[CapitalDelta]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["o", "TI"], "1"], "-", 
         FractionBox["1", "2"], 
         RowBox[{"(", 
           RowBox[{"\[CapitalDelta]", 
             SubsuperscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["o", "TI"], "1"], "-", "\[CapitalDelta]", 
             SubsuperscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["e", "TI"], "1"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\Delta s^1=\\Delta x_o^1-\\frac12(\\Delta x_o^1-\\Delta x_e^1)$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9872603892554417`*^9, 3.9872603933360157`*^9}, {
  3.9872778622114735`*^9, 
  3.9872778622114735`*^9}},ExpressionUUID->"302538e1-d1d0-9746-adc4-\
f738746d31f0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "1"], "\[LongEqual]", 
         FractionBox["1", "2"], 
         RowBox[{"(", 
           RowBox[{"\[CapitalDelta]", 
             SubsuperscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["o", "TI"], "1"], "+", "\[CapitalDelta]", 
             SubsuperscriptBox[
              StyleBox["x", "TI"], 
              StyleBox["e", "TI"], "1"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\Delta s^1=\\frac12(\\Delta x_o^1+\\Delta x_e^1)$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9872604096619434`*^9, 3.987260413131445*^9}, {
  3.987260976319729*^9, 3.9872609770149536`*^9}, {3.987277869208622*^9, 
  3.9872778692112827`*^9}},ExpressionUUID->"99f2b564-64f1-424c-b554-\
78f8641b659e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  InterpretationBox[
   SuperscriptBox["\[CapitalDelta]s", "1"],
   $CellContext`\[CapitalDelta]s1], "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"Expand", "[", 
    RowBox[{
     InterpretationBox[
      SubsuperscriptBox["\[CapitalDelta]x", "o", "1"],
      $CellContext`\[CapitalDelta]xo1], "-", 
     RowBox[{
      FractionBox["1", "2"], " ", 
      RowBox[{"(", 
       RowBox[{
        InterpretationBox[
         SubsuperscriptBox["\[CapitalDelta]x", "o", "1"],
         $CellContext`\[CapitalDelta]xo1], "-", 
        InterpretationBox[
         SubsuperscriptBox["\[CapitalDelta]x", "e", "1"],
         $CellContext`\[CapitalDelta]xe1]}], ")"}]}]}], "]"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.98726950688196*^9, 3.9872695431137905`*^9}},
 CellLabel->"In[73]:=",ExpressionUUID->"f903a85d-7683-d74c-a17b-bcf3a252846e"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  RowBox[{"(", 
   RowBox[{
    InterpretationBox[
     SubsuperscriptBox["\[CapitalDelta]x", "e", "1"],
     $CellContext`\[CapitalDelta]xe1], "+", 
    InterpretationBox[
     SubsuperscriptBox["\[CapitalDelta]x", "o", "1"],
     $CellContext`\[CapitalDelta]xo1]}], ")"}]}]], "Output",
 CellChangeTimes->{3.9877517614393425`*^9},
 CellLabel->"Out[73]=",ExpressionUUID->"80df73fa-5c95-4a49-b58b-fa109a3968aa"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Invariance of the Bilocal Interval", "Subsection",
 CellChangeTimes->{
  3.9872609067263393`*^9},ExpressionUUID->"b701604d-5ddc-9d42-8198-\
cdc5406605f6"],

Cell[TextData[{
 "Consider a bilocal scalar constructed from the temporal and spatial \
endpoint functionals ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{"\[CapitalDelta]", 
           SuperscriptBox[
            StyleBox["s", "TI"], "0"], ",", "\[CapitalDelta]", 
           SuperscriptBox[
            StyleBox["s", "TI"], "1"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "$(\\Delta s^0,\\Delta s^1)$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "942dc6bd-5f2b-b74a-a651-52620880c266"],
 ". We adopt a quadratic form as the lowest-order scalar consistent with \
finite separations, ensuring that the local reduction yields a well-defined \
null condition while avoiding higher-order dependence on endpoint structure,"
}], "Text",
 CellChangeTimes->{3.9872609276940193`*^9, 
  3.9872779710309963`*^9},ExpressionUUID->"f3b63ec2-2ad8-7643-9606-\
5f9af342dc52"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "2"], "\[LongEqual]", 
         StyleBox["a", "TI"], " ", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"\[CapitalDelta]", 
              SuperscriptBox[
               StyleBox["s", "TI"], "0"]}], ")"}], "2"], "+", 
         StyleBox["b", "TI"], " ", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"\[CapitalDelta]", 
              SuperscriptBox[
               StyleBox["s", "TI"], "1"]}], ")"}], "2"], "+", "2", 
         StyleBox["c", "TI"], " ", "\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "0"], "\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "1"]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "$\\Delta s^2 = a\\,(\\Delta s^0)^2 + b\\,(\\Delta s^1)^2 + 2c\\,\\Delta \
s^0 \\Delta s^1$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9872610719603558`*^9, 3.9872611162568703`*^9}, 
   3.9872613022011566`*^9},ExpressionUUID->"701f128a-108e-924d-9f58-\
bcfee8384ddb"],

Cell[TextData[{
 "Under interchange of the ordered endpoints ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["p", "TI"], 
            StyleBox["e", "TI"]], ",", 
           SubscriptBox[
            StyleBox["p", "TI"], 
            StyleBox["o", "TI"]]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$(p_e,p_o)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2191b28a-bab1-fc44-a8e8-da0a75cf21b4"],
 ", the temporal functional changes sign while the symmetric spatial \
functional does not, so the mixed term changes sign. Invariance therefore \
requires ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["c", "TI"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "$c=0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f286fdbd-edc9-e04b-b982-c054c1eb5314"],
 "."
}], "Text",
 CellChangeTimes->{{3.9872611331319923`*^9, 
  3.987261145131935*^9}},ExpressionUUID->"c0e0cedf-4e0c-d24d-9f2b-\
123b862c0873"],

Cell["\<\
In the local reduction, sufficiently small endpoint separations render the \
temporal and spatial functionals linear in the coordinate increments. The \
null condition must define a finite null ratio, which requires both temporal \
and spatial contributions to enter non-degenerately so that the null \
condition defines a finite null ratio. The interval therefore reduces to\
\>", "Text",
 CellChangeTimes->{
  3.98726124778866*^9},ExpressionUUID->"63fa5446-e883-6a44-8adb-6ac0323c10fc"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "2"], "\[LongEqual]", 
         StyleBox["a", "TI"], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"\[CapitalDelta]", 
              SuperscriptBox[
               StyleBox["s", "TI"], "0"]}], ")"}], "2"], "+", 
         StyleBox["b", "TI"], 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"\[CapitalDelta]", 
              SuperscriptBox[
               StyleBox["s", "TI"], "1"]}], ")"}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\Delta s^2 = a (\\Delta s^0)^2 + b (\\Delta s^1)^2$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], "."}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.9872612603511677`*^9, 
  3.9872612986319523`*^9}},ExpressionUUID->"15950962-4b57-6647-83e8-\
d56acf583b12"],

Cell["\<\
The remaining quadratic form is therefore constrained up to a positive \
overall factor and a relative scaling between the temporal and spatial \
functionals. These functionals are not arbitrary coordinates but are \
identified with the canonical imaginary and real components of the complex \
manifold, with this identification fixing their relative normalization. The \
bilocal interval is therefore\
\>", "Text",
 CellChangeTimes->{
  3.987269609859949*^9, {3.987273869767866*^9, 
   3.9872738704142857`*^9}},ExpressionUUID->"d58928c2-f03e-084a-af68-\
032a63cc7a60"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "2"], "\[LongEqual]", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"\[CapitalDelta]", 
              SuperscriptBox[
               StyleBox["s", "TI"], "0"]}], ")"}], "2"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
            RowBox[{"\[CapitalDelta]", 
              SuperscriptBox[
               StyleBox["s", "TI"], "1"]}], ")"}], "2"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\Delta s^2 = (\\Delta s^0)^2 + (\\Delta s^1)^2$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], " ", ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9872738842884617`*^9, 3.9872738908713207`*^9}, {
  3.9872780748392944`*^9, 
  3.987278074840908*^9}},ExpressionUUID->"344da1b2-ce92-624e-9629-\
f1a1f195bb2c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SuperscriptBox["\[CapitalDelta]s", "2"],
    $CellContext`\[CapitalDelta]s2], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"(", 
      InterpretationBox[
       SuperscriptBox["\[CapitalDelta]s", "0"],
       $CellContext`\[CapitalDelta]s0], ")"}], "2"], "+", 
    SuperscriptBox[
     RowBox[{"(", 
      InterpretationBox[
       SuperscriptBox["\[CapitalDelta]s", "1"],
       $CellContext`\[CapitalDelta]s1], ")"}], "2"]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.975500594324188*^9, 3.975500602352495*^9}, {
   3.9764774522151775`*^9, 3.9764774573314476`*^9}, {3.9764774905614624`*^9, 
   3.976477512890049*^9}, 3.9775155624497986`*^9, {3.977690570907854*^9, 
   3.9776905931215115`*^9}, 3.978961587874956*^9, 3.9873258263691864`*^9, {
   3.987326298948763*^9, 3.987326322122572*^9}, 3.9873286242246056`*^9},
 CellLabel->"In[74]:=",ExpressionUUID->"f9fa6ce2-02e1-164c-b224-e27ac3dbc36c"],

Cell[TextData[{
 "with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "0"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\Delta s^0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "51eccc10-efa3-d34d-9d43-a16db134f6d9"],
 " purely imaginary and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "1"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\Delta s^1$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ed63d7f8-8966-644c-b139-a94b545fbf5b"],
 " real."
}], "Text",
 CellChangeTimes->{{3.987273911928196*^9, 
  3.9872739212742767`*^9}},ExpressionUUID->"055f2e9c-7e36-944a-8015-\
7a9ceaae8770"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Imaginary Velocity", "Subsection",
 CellChangeTimes->{{3.9753991762457047`*^9, 3.9753991779965096`*^9}, {
  3.97540901400651*^9, 
  3.975409015046177*^9}},ExpressionUUID->"4f196a79-b20d-634d-991f-\
d8af2cc9861e"],

Cell[TextData[{
 "The intrinsic evolution of the manifold is parameterized by a coordinate ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Chi]", TraditionalForm], "errors" -> {}, "input" -> 
     "$\\chi$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "08c13eaf-fc5b-3341-8c52-8010eeddc835"],
 ". Observable time is introduced by the projection ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Chi]", "\[LongEqual]", 
         StyleBox["i", "TI"], 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\chi = i t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9bb99ae6-05fc-a84b-b5dc-91610f54a76b"],
 ", so that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "\[Chi]", "\[LongEqual]", 
         StyleBox["i", "TI"], "\[DifferentialD]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$d\\chi = i\\,dt$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "235b3870-64df-b041-aded-1b3cf40c10c1"],
 ", fixing the real-imaginary decomposition used in the bilocal construction."
}], "Text",
 CellChangeTimes->{{3.9753991890809784`*^9, 3.9753992111537*^9}, {
   3.975399753417801*^9, 3.975399759668125*^9}, {3.9776691200281487`*^9, 
   3.977669147278139*^9}, {3.9776693269225407`*^9, 3.9776693275955467`*^9}, {
   3.977675102938406*^9, 3.977675134333046*^9}, {3.977679438111536*^9, 
   3.977679442734743*^9}, {3.9792932493076477`*^9, 3.9792932981200714`*^9}, 
   3.979832802215229*^9, {3.9798329233403015`*^9, 3.9798329400092163`*^9}, {
   3.9872741727453747`*^9, 3.987274174318348*^9}, {3.9872743555690536`*^9, 
   3.987274376277376*^9}},ExpressionUUID->"35781b8c-cf5e-b24a-94f6-\
e4a178598690"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"\[Chi]", "[", "t_", "]"}], "=", 
   RowBox[{"\[ImaginaryI]", " ", "t"}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9872744905466213`*^9, 3.9872745161791496`*^9}, {
  3.9872749907539463`*^9, 3.987274996116947*^9}, {3.9872750312324467`*^9, 
  3.98727503377672*^9}},
 CellLabel->"In[75]:=",ExpressionUUID->"c86f7176-fbde-2944-b48c-6881a009a337"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"With", " ", "constant", " ", "intrinsic", " ", "acceleration", " ", 
    TemplateBox[<|"boxes" -> FormBox[
        StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
      "$A$", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], ",", 
   RowBox[{
   "the", " ", "velocity", " ", "scale", " ", "along", " ", "the", " ", 
    "manifold", " ", "history", " ", "follows", " ", "from", " ", 
    "integration", " ", "with", " ", "respect", " ", "to", " ", 
    TemplateBox[<|
     "boxes" -> FormBox["\[Chi]", TraditionalForm], "errors" -> {}, "input" -> 
      "$\\chi$", "state" -> "Boxes"|>,
     "TeXAssistantTemplate"]}], ","}], TraditionalForm]], "Text",
 CellChangeTimes->{
  3.981535669721512*^9, {3.987274182757353*^9, 3.9872741935215855`*^9}, 
   3.9872744002570915`*^9},ExpressionUUID->"29f5daa0-5d42-7449-93f7-\
42dece49206c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["v", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "\[Integral]", 
         StyleBox["A", "TI"], "\[DifferentialD]", "\[Chi]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "$v(t) = \\int A\\, d\\chi$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], " ", "."}], TraditionalForm]], "DisplayFormula",
 CellChangeTimes->{{3.9753998141715317`*^9, 3.975399845813795*^9}, {
   3.975427287535734*^9, 3.9754272895492*^9}, 3.9754933048988285`*^9, {
   3.9754933606666946`*^9, 3.9754933747864075`*^9}, {3.9761346588514347`*^9, 
   3.9761346588627796`*^9}, {3.9772470283269463`*^9, 3.977247029894903*^9}, 
   3.9775134500745983`*^9, {3.9776693008407516`*^9, 3.977669318190691*^9}, 
   3.9776749058982773`*^9, {3.9776751446574078`*^9, 3.977675145496073*^9}, 
   3.97767943015217*^9, 3.9792933153073826`*^9, {3.9798329508567295`*^9, 
   3.9798329582776985`*^9}, {3.987274208222471*^9, 3.987274213380827*^9}, {
   3.9872781359726086`*^9, 
   3.9872781359746094`*^9}},ExpressionUUID->"6aa29f51-4203-284d-8fda-\
26a6452540c3"],

Cell[TextData[{
 "Substituting ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "\[Chi]", "\[LongEqual]", 
         StyleBox["i", "TI"], "\[DifferentialD]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$d\\chi = i\\,dt$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e860900b-07c4-4d44-893f-35b5aa293092"],
 " gives ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["v", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["i", "TI"], "\[NegativeThinSpace]", "\[Integral]", 
         StyleBox["A", "TI"], "\[DifferentialD]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$v(t) = i\\!\\int A\\,dt$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a7a1e2ab-d2fa-b748-ba28-4c29080ce223"],
 ", which evaluates to"
}], "Text",
 CellChangeTimes->{{3.9872782171617126`*^9, 
  3.987278231068495*^9}},ExpressionUUID->"4d8b9ccd-2664-eb43-aca2-\
db8d876d6069"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["v", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         StyleBox["i", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["A", "TI"], 
             StyleBox["t", "TI"], "-", 
             SubscriptBox[
              StyleBox["V", "TI"], "0"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "$v(t) = i(At - V_0)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987278291447979*^9, 
  3.9872783209080677`*^9}},ExpressionUUID->"ab2d08a7-7754-2d46-85d8-\
bfd4417da2eb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"v", "[", "t_", "]"}], "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{
    RowBox[{"\[Integral]", 
     RowBox[{
      RowBox[{"A", " ", 
       RowBox[{
        SubscriptBox["\[PartialD]", "t"], 
        RowBox[{"\[Chi]", "[", "t", "]"}]}]}], 
      RowBox[{"\[DifferentialD]", "t"}]}]}], "-", 
    RowBox[{"\[ImaginaryI]", " ", 
     InterpretationBox[
      SubscriptBox["V", "0"],
      $CellContext`initialVelocity]}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9775708042645836`*^9, 3.977570830724291*^9}, {
   3.977571154538351*^9, 3.9775711780683594`*^9}, 3.977571367995556*^9, 
   3.977571527228836*^9, 3.977571675030422*^9, 3.9775717392368183`*^9, {
   3.9775723341590633`*^9, 3.977572364538954*^9}, {3.9775724854944954`*^9, 
   3.977572500553953*^9}, 3.9775725666821575`*^9, {3.977669089868149*^9, 
   3.9776690935881767`*^9}, {3.9776718490922413`*^9, 3.977671878791092*^9}, {
   3.9776743311312294`*^9, 3.9776743370224514`*^9}, {3.9788108341632957`*^9, 
   3.9788108944159985`*^9}, 3.978898102870064*^9, 3.978961626557873*^9, {
   3.987274439477234*^9, 3.98727444581188*^9}, 3.9872745279476185`*^9, 
   3.9872750213665943`*^9, 3.9872764254475574`*^9},
 CellLabel->"In[76]:=",ExpressionUUID->"e1f7e063-1eae-6340-8c30-888939c7008f"],

Cell[BoxData[
 RowBox[{"\[ImaginaryI]", " ", 
  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", 
     InterpretationBox[
      SubscriptBox["V", "0"],
      $CellContext`initialVelocity]}], "+", 
    RowBox[{"A", " ", "t"}]}], ")"}]}]], "Output",
 CellChangeTimes->{3.9877517615497913`*^9},
 CellLabel->"Out[76]=",ExpressionUUID->"c6e1befa-3991-e641-92e5-7515a666fa19"]
}, Open  ]],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["V", "TI"], "0"], TraditionalForm], "errors" -> {}, "input" -> 
     "$V_0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "aec2f335-f17c-0548-9a54-793500fa4f07"],
 " is an integration constant representing the initial expansion rate of the \
manifold."
}], "Text",
 CellChangeTimes->{{3.9872750916539555`*^9, 
  3.987275095631794*^9}},ExpressionUUID->"7c7f9f40-d74d-fb44-907b-\
a0e7559f4d0b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Induced Spatial Evolution", "Subsection",
 CellChangeTimes->{{3.9754007968400097`*^9, 3.975400799875807*^9}, 
   3.9754009968249702`*^9, 3.9754089869840946`*^9, 3.979833939058628*^9, 
   3.987276515896656*^9},ExpressionUUID->"03eb8afc-9bf8-2648-aea3-\
2a13e93552db"],

Cell[TextData[{
 "The observable spatial extent arises from integrating the imaginary \
velocity along the imaginary temporal direction. The global spatial scale of \
the manifold is therefore ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[Congruent]", "\[Integral]", 
         StyleBox["v", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[DifferentialD]", "\[Chi]"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "$L(t) \\equiv \\int v(t)\\, d\\chi$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a42ef848-2777-3544-a3d5-b32587826300"],
 ". Substituting the expression for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["v", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$v(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "99d212ea-1961-5949-b160-c52932724b71"],
 " and using ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "\[Chi]", "\[LongEqual]", 
         StyleBox["i", "TI"], "\[DifferentialD]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$d\\chi = i\\,dt$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "41348649-5bd9-2e41-9ade-31b04445ed75"],
 " gives ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", "\[Integral]", 
         StyleBox["i", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["A", "TI"], 
             StyleBox["t", "TI"], "-", 
             SubscriptBox[
              StyleBox["V", "TI"], "0"]}], ")"}], " ", 
         StyleBox["i", "TI"], "\[DifferentialD]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$L(t) = \\int i(At - V_0)\\, i\\, dt$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b2a8d38c-f7d1-ee4a-a481-86be7912dd5a"],
 ". Evaluating the integral yields"
}], "Text",
 CellChangeTimes->{{3.975401006325598*^9, 3.9754010242005253`*^9}, {
   3.975409050349676*^9, 3.9754090574358883`*^9}, {3.9754169600968246`*^9, 
   3.975416964941164*^9}, {3.975417072053911*^9, 3.975417074200218*^9}, {
   3.9761346588947353`*^9, 3.9761346588947353`*^9}, {3.9772490576633015`*^9, 
   3.977249058855791*^9}, 3.97751051080114*^9, {3.977674398443718*^9, 
   3.9776743991903076`*^9}, {3.9776793929323044`*^9, 3.977679405964575*^9}, {
   3.9776803731014633`*^9, 3.9776803850829678`*^9}, {3.979501179326685*^9, 
   3.9795012188104725`*^9}, {3.979837676700428*^9, 3.979837710429367*^9}, 
   3.9798379866930103`*^9, {3.987276535409172*^9, 
   3.9872765714752617`*^9}},ExpressionUUID->"2aea7078-b403-314a-925f-\
f641789bf65f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["V", "TI"], "0"], 
         StyleBox["t", "TI"], "-", 
         FractionBox["1", "2"], 
         StyleBox["A", "TI"], 
         SuperscriptBox[
          StyleBox["t", "TI"], "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$L(t) = V_0 t - \\frac{1}{2} A t^2$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.979501240103094*^9, 3.979501289501915*^9}, 
   3.9798377179736576`*^9, {3.9872765860376167`*^9, 3.987276590611164*^9}, {
   3.9872776336357803`*^9, 
   3.9872776336387405`*^9}},ExpressionUUID->"1d22da86-da61-9849-a073-\
c203288b3560"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"L", "[", "t_", "]"}], "=", 
  RowBox[{"\[Integral]", 
   RowBox[{
    RowBox[{
     RowBox[{"v", "[", "t", "]"}], " ", 
     RowBox[{
      SubscriptBox["\[PartialD]", "t"], 
      RowBox[{"\[Chi]", "[", "t", "]"}]}]}], 
    RowBox[{"\[DifferentialD]", "t"}]}]}]}]], "Input",
 CellChangeTimes->{
  3.9754092190208015`*^9, {3.9754165523398495`*^9, 3.975416554837448*^9}, {
   3.975416589254339*^9, 3.9754165938506413`*^9}, 3.975416929162529*^9, {
   3.975417345770027*^9, 3.9754173521866264`*^9}, 3.975417631545044*^9, {
   3.975421844447504*^9, 3.975421845680626*^9}, 3.9757790704322376`*^9, {
   3.9775714234136524`*^9, 3.9775714351504326`*^9}, {3.977571477697798*^9, 
   3.977571563045969*^9}, 3.9775716309399014`*^9, 3.977571662829096*^9, 
   3.9775717431560802`*^9, {3.9775723394946594`*^9, 3.9775723880449543`*^9}, {
   3.9775725309594707`*^9, 3.9775725418505154`*^9}, 3.978961622047512*^9, {
   3.9872775825016155`*^9, 3.987277587745041*^9}, 3.9872776215245056`*^9},
 CellLabel->"In[77]:=",ExpressionUUID->"9348db03-7576-d74b-9345-e9a5e8dec8de"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["V", "0"],
    $CellContext`initialVelocity], " ", "t"}], "-", 
  FractionBox[
   RowBox[{"A", " ", 
    SuperscriptBox["t", "2"]}], "2"]}]], "Output",
 CellChangeTimes->{3.9877517615569973`*^9},
 CellLabel->"Out[77]=",ExpressionUUID->"e1b41a86-d261-e94b-94a8-00f2d6d643d1"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Manifold Deceleration", "Subsection",
 CellChangeTimes->{{3.987276645328869*^9, 
  3.987276647496292*^9}},ExpressionUUID->"afeab170-cefe-4045-b746-\
d50572f920ae"],

Cell[TextData[{
 "The intrinsic evolution is defined along ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Chi]", TraditionalForm], "errors" -> {}, "input" -> 
     "$\\chi$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "955ab4f0-b378-6c47-b357-f5219fd2b570"],
 ", while observable dynamics are expressed in the projected time coordinate ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7e2d0c13-e30a-b848-8223-99d8153e3456"],
 " with ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["d", "TI"], "\[Chi]", "\[LongEqual]", 
         StyleBox["i", "TI"], "\[DifferentialD]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$d\\chi = i\\,dt$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "94305d5a-6bdc-734f-ac23-bbc83edcc658"],
 ". Rewriting the manifold extent in terms of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "038f677c-676e-f242-a2f1-a28ea002f3f3"],
 " yields its observable form. Differentiating twice with respect to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5e135838-763f-6649-b7eb-35322a4a6616"],
 " gives"
}], "Text",
 CellChangeTimes->{{3.9872766591479263`*^9, 
  3.987276689556143*^9}},ExpressionUUID->"da766871-0fd8-f545-a6a6-\
00b6c9abebba"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            SuperscriptBox[
             StyleBox["d", "TI"], "2"], 
            StyleBox["L", "TI"]}], 
          RowBox[{
            StyleBox["d", "TI"], 
            SuperscriptBox[
             StyleBox["t", "TI"], "2"]}]], "\[LongEqual]", "-", 
         StyleBox["A", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\frac{d^2 L}{dt^2} = -A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987276762476845*^9, 3.987276769334215*^9}, {
  3.9872786497262554`*^9, 
  3.9872786497262554`*^9}},ExpressionUUID->"536bf604-087f-4c4e-bb72-\
76a27086c329"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  SubscriptBox["\[PartialD]", 
   RowBox[{"{", 
    RowBox[{"t", ",", "2"}], "}"}]], 
  RowBox[{"L", "[", "t", "]"}]}]], "Input",
 CellChangeTimes->{{3.9775727394071465`*^9, 3.9775727394071465`*^9}, 
   3.9775740359073925`*^9, 3.978961617560396*^9, {3.987279064684313*^9, 
   3.987279071184307*^9}},
 CellLabel->"In[78]:=",ExpressionUUID->"5a51eb66-b629-1d49-a1c5-b7ad11c3b21b"],

Cell[BoxData[
 RowBox[{"-", "A"}]], "Output",
 CellChangeTimes->{3.98775176160651*^9},
 CellLabel->"Out[78]=",ExpressionUUID->"178877ca-0db1-c549-b50c-aadac2bff28e"]
}, Open  ]],

Cell[TextData[{
 "so the manifold extent evolves with a constant kinematic deceleration of \
magnitude ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["A", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$A$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "28920ea0-babb-c94b-bafe-284fe09e470b"],
 ", which is universal and independent of position or epoch."
}], "Text",
 CellChangeTimes->{3.9872767849900208`*^9, 
  3.9872771798052044`*^9},ExpressionUUID->"52eec250-1a68-614f-9432-\
351688204a46"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Cosmological Distance", "Section",
 CellChangeTimes->{{3.9872771997965927`*^9, 
  3.9872772098035755`*^9}},ExpressionUUID->"00bc9697-18d4-9d4e-b611-\
98a894f8926b"],

Cell["\<\
Observable cosmological distances follow from the bilocal interval defined in \
equation (5). \
\>", "Text",
 CellChangeTimes->{{3.9872772276168633`*^9, 3.9872772531507816`*^9}, {
  3.9872773912175655`*^9, 3.9872773915368824`*^9}, {3.987278422061165*^9, 
  3.9872784270255775`*^9}},ExpressionUUID->"bcc524c8-2ba6-4b4d-a6b8-\
1a231f538b53"],

Cell[CellGroupData[{

Cell["Temporal Separation", "Subsection",
 CellChangeTimes->{{3.987277438782545*^9, 
  3.9872774402124977`*^9}},ExpressionUUID->"ada324d8-46ca-0b4f-af67-\
3a7fc637020a"],

Cell[TextData[{
 "The temporal component of the bilocal interval is obtained from the \
accumulated tangent evolution along the manifold history between the emission \
and observation parameters ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["e", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_e$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0ee351bd-e593-9d44-b207-5bd02cfd9038"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["o", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_o$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6db5a85e-c875-c44e-8a37-1f789a747157"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "0"], "\[Congruent]", 
         SubsuperscriptBox["\[Integral]", 
          SubscriptBox[
           StyleBox["t", "TI"], 
           StyleBox["e", "TI"]], 
          SubscriptBox[
           StyleBox["t", "TI"], 
           StyleBox["o", "TI"]]], 
         StyleBox["v", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[DifferentialD]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\Delta s^0 \\equiv \\int_{t_e}^{t_o} v(t)\\,dt$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "54d79ddf-47db-0145-9fd3-034813bc0ee8"],
 ". Substituting Eq. (6) gives"
}], "Text",
 CellChangeTimes->{{3.9872774507625694`*^9, 3.9872774915173607`*^9}, {
  3.9872784749614105`*^9, 
  3.9872784778359146`*^9}},ExpressionUUID->"223643a2-4f89-8140-b975-\
2881a733b49e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "0"], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", 
          SubscriptBox[
           StyleBox["t", "TI"], 
           StyleBox["e", "TI"]], 
          SubscriptBox[
           StyleBox["t", "TI"], 
           StyleBox["o", "TI"]]], 
         StyleBox["i", "TI"], 
         RowBox[{"(", 
           RowBox[{
             StyleBox["A", "TI"], 
             StyleBox["t", "TI"], "-", 
             SubscriptBox[
              StyleBox["V", "TI"], "0"]}], ")"}], "\[DifferentialD]", 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\Delta s^0 = \\int_{t_e}^{t_o} i\\left(A t - V_0\\right)\\,dt$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], " ", "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9872785345127373`*^9, 
  3.9872785472869816`*^9}},ExpressionUUID->"35183cf5-d8b4-b04f-a5ea-\
6c71c4063dd6"],

Cell["Evaluating the integral yields", "Text",
 CellChangeTimes->{
  3.9872785710766582`*^9},ExpressionUUID->"56ee8090-71e7-8c47-a8ac-\
da56ebca6b90"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "0"], "\[LongEqual]", 
         StyleBox["i", "TI"], 
         RowBox[{"(", 
           RowBox[{
             FractionBox[
              StyleBox["A", "TI"], "2"], 
             RowBox[{"(", 
               RowBox[{
                 SubsuperscriptBox[
                  StyleBox["t", "TI"], 
                  StyleBox["o", "TI"], "2"], "-", 
                 SubsuperscriptBox[
                  StyleBox["t", "TI"], 
                  StyleBox["e", "TI"], "2"]}], ")"}], "-", 
             SubscriptBox[
              StyleBox["V", "TI"], "0"], 
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["t", "TI"], 
                  StyleBox["o", "TI"]], "-", 
                 SubscriptBox[
                  StyleBox["t", "TI"], 
                  StyleBox["e", "TI"]]}], ")"}]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"MakeBoxes", "[", 
    RowBox[{"accelerationSI", ",", "StandardForm"}], "]"}], ":=", 
   RowBox[{"InterpretationBox", "[", 
    RowBox[{
     RowBox[{"StyleBox", "[", 
      RowBox[{"\"\<\[ScriptCapitalA]\>\"", ",", 
       RowBox[{"FontFamily", "->", "\"\<Times\>\""}]}], "]"}], ",", 
     "accelerationSI"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"MakeBoxes", "[", 
     RowBox[{"angularScale", ",", " ", "StandardForm"}], "]"}], " ", ":=", 
    " ", 
    RowBox[{"InterpretationBox", "[", 
     RowBox[{
      RowBox[{"SubscriptBox", "[", 
       RowBox[{"\"\<\[Theta]\>\"", ",", " ", "\"\<*\>\""}], "]"}], ",", 
      "angularScale"}], "]"}]}], ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"MakeBoxes", "[", 
    RowBox[{"baryonDensity", ",", "StandardForm"}], "]"}], ":=", 
   RowBox[{"InterpretationBox", "[", 
    RowBox[{
     RowBox[{"SubscriptBox", "[", 
      RowBox[{"\"\<\[Rho]\>\"", ",", "\"\<b\>\""}], "]"}], ",", 
     "baryonDensity"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"MakeBoxes", "[", 
    RowBox[{"boltzmannConstant", ",", "StandardForm"}], "]"}], ":=", 
   RowBox[{"InterpretationBox", "[", 
    RowBox[{
     RowBox[{"SubscriptBox", "[", 
      RowBox[{"\"\<k\>\"", ",", 
       RowBox[{"StyleBox", "[", 
        RowBox[{"\"\<B\>\"", ",", 
         RowBox[{"FontSlant", "->", "\"\<Plain\>\""}]}], "]"}]}], "]"}], ",", 
     "boltzmannConstant"}], "]"}]}], ";", 
  RowBox[{
   RowBox[{"MakeBoxes", "[", 
    RowBox[{"causalityHorizon", ",", "StandardForm"}], "]"}], ":=", 

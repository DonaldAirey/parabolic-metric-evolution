          StyleBox["M", "TI"], 
          StyleBox["b", "TI"]], 
         RowBox[{"(", 
           StyleBox["r", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["r", "TI"], "(", 
            RowBox[{
              SuperscriptBox[
               StyleBox["v", "TI"], "2"], "-", 
              StyleBox["A", "TI"], 
              StyleBox["r", "TI"]}], ")"}], 
          StyleBox["G", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$M_b(r) = \\frac{r\\left(v^2 - A r\\right)}{G}$", "state" -> "Boxes"|>,

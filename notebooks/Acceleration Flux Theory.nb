}, Open  ]],

Cell[CellGroupData[{

Cell["Acoustic Angular Scale", "Subsection",
 CellChangeTimes->{{3.9809722568619576`*^9, 3.9809722595342064`*^9}, 
   3.9876204505286617`*^9},ExpressionUUID->"0d621d4c-e9a3-414b-9c56-\
638a073e4f70"],

Cell[TextData[{
 "The observed acoustic angle is determined by the ratio of the sound horizon \
at recombination to the bilocally assigned transverse size of the \
emission-observation pair. ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$L(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "237d7d8b-1f23-964d-b441-72ab8df26872"],
 " denotes the circumference of the spatial slice at epoch ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["t", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$t$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "19dd3978-76d4-d64e-9398-ae73958b735e"],
 ", so the relevant transverse quantity is the effective bilocal transverse \
circumference associated with the ordered pair ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["t", "TI"], "*"], ",", 
           SubscriptBox[
            StyleBox["t", "TI"], 
            StyleBox["o", "TI"]]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$(t_*,t_o)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "6178bc35-7b62-ba43-b2ed-77744ff3bbc1"],
 "."
}], "Text",
 CellChangeTimes->{{3.980972377739023*^9, 3.980972443154377*^9}, {
  3.98137470530694*^9, 3.981374717623152*^9}, {3.981374858586075*^9, 
  3.981374895560198*^9}, {3.98137584827787*^9, 3.9813759211294327`*^9}, {
  3.9876204683387012`*^9, 
  3.987620494183628*^9}},ExpressionUUID->"956a2523-f26b-4f4c-bc1a-\
9d00e04dbd78"],

Cell[TextData[{
 "To define this quantity, consider a transverse bilocal path whose endpoints \
lie at antipodal points on the spatial slices at emission and observation. \
The transverse separations between antipodal points on those slices are \
therefore the corresponding slice circumferences, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], "(", 
         SubscriptBox[
          StyleBox["t", "TI"], "*"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$L(t_*)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "555ab81b-7a4c-0b4a-81b5-e47c622abceb"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["L", "TI"], "(", 
         SubscriptBox[
          StyleBox["t", "TI"], 
          StyleBox["o", "TI"]], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$L(t_o)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "82e31c7a-70bd-1b4d-9eac-6993fd09d009"],
 ". Applying the bilocal spatial rule of equation (3) to this transverse \
configuration defines the bilocal spatial separation between antipodal \
transverse endpoints, which we identify as the effective transverse \
circumference,"
}], "Text",
 CellChangeTimes->{{3.9813750701071453`*^9, 3.9813750871387978`*^9}, {
   3.981375940302271*^9, 3.9813759941859493`*^9}, 3.9876205069082623`*^9, {
   3.987623423364971*^9, 3.9876234395947895`*^9}, {3.9877064540663795`*^9, 
   3.987706456716732*^9}},ExpressionUUID->"fc936a9b-491b-8947-8f88-\
dae23e78183d"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["C", "TI"], "\[Perpendicular]"], "\[Congruent]", 
         FractionBox["1", "2"], 
         RowBox[{"[", 
           RowBox[{
             StyleBox["L", "TI"], 
             RowBox[{"(", 
               SubscriptBox[
                StyleBox["t", "TI"], 
                StyleBox["o", "TI"]], ")"}], "+", 
             StyleBox["L", "TI"], 
             RowBox[{"(", 
               SubscriptBox[
                StyleBox["t", "TI"], "*"], ")"}]}], "]"}]}], TraditionalForm],
      "errors" -> {}, "input" -> 
     "$C_\\perp \\equiv \\frac12\\left[L(t_o)+L(t_*)\\right]$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876205476144066`*^9, 3.9876205517482643`*^9}, {
  3.9877074226248894`*^9, 
  3.9877074226248894`*^9}},ExpressionUUID->"13237487-c131-d741-a323-\
d2122d31ff68"],

Cell["Using the redshift relation from equation (15), this becomes", "Text",
 CellChangeTimes->{
  3.987623659052391*^9, {3.9877074352719345`*^9, 
   3.987707438776724*^9}},ExpressionUUID->"31b087f4-af03-b74e-b26a-\
aa12a97e8ab8"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["C", "TI"], "\[Perpendicular]"], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["L", "TI"], "(", 
            SubscriptBox[
             StyleBox["t", "TI"], 
             StyleBox["o", "TI"]], ")"}], "2"], " ", 
         FractionBox[
          RowBox[{"2", "+", 
            SubscriptBox[
             StyleBox["z", "TI"], "*"]}], 
          RowBox[{"1", "+", 
            SubscriptBox[
             StyleBox["z", "TI"], "*"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> "$C_\\perp=\\frac{L(t_o)}{2}\\,\\frac{2+z_*}{1+z_*}$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.98762367238908*^9, 3.987623675773527*^9}, {
  3.9877074489865856`*^9, 
  3.9877074489865856`*^9}},ExpressionUUID->"24e4ddf4-b8ca-8045-b0f8-\
1f1cb18b96fe"],

Cell["The corresponding effective transverse radius is", "Text",
 CellChangeTimes->{{3.9809729731360645`*^9, 3.9809730063744793`*^9}, 
   3.9811406534072056`*^9, {3.9813765906740036`*^9, 3.9813765993419743`*^9}, 
   3.987620612567766*^9},ExpressionUUID->"60efcc41-e559-fe42-a217-\
cb9942f3804d"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["r", "TI"], "\[Perpendicular]"], "\[LongEqual]", 
         FractionBox[
          SubscriptBox[
           StyleBox["C", "TI"], "\[Perpendicular]"], 
          RowBox[{"2", "\[Pi]"}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["L", "TI"], "(", 
            SubscriptBox[
             StyleBox["t", "TI"], 
             StyleBox["o", "TI"]], ")"}], 
          RowBox[{"4", "\[Pi]"}]], " ", 
         FractionBox[
          RowBox[{"2", "+", 
            SubscriptBox[
             StyleBox["z", "TI"], "*"]}], 
          RowBox[{"1", "+", 
            SubscriptBox[
             StyleBox["z", "TI"], "*"]}]]}], TraditionalForm], "errors" -> {},
      "input" -> 
     "$r_\\perp=\\frac{C_\\perp}{2\\pi}=\\frac{L(t_o)}{4\\pi}\\,\\frac{2+z_*}{\
1+z_*}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987620623833067*^9, 3.987620627516464*^9}, {
  3.987708729585762*^9, 
  3.987708729585762*^9}},ExpressionUUID->"463a8acc-9603-5546-841f-\
861c96c45768"],

Cell["The acoustic angular scale is then", "Text",
 CellChangeTimes->{
  3.987620718692257*^9},ExpressionUUID->"2da4f709-f261-0447-8813-\
308a50842271"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Theta]", "*"], "\[LongEqual]", 
         FractionBox[
          SubscriptBox[
           StyleBox["r", "TI"], 
           StyleBox["s", "TI"]], 
          SubscriptBox[
           StyleBox["r", "TI"], "\[Perpendicular]"]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "$\\theta_*=\\frac{r_s}{r_\\perp}$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876207272975197`*^9, 3.987620730104166*^9}, {
  3.987708742486164*^9, 
  3.9877087424960194`*^9}},ExpressionUUID->"46b27a89-4361-1c4c-a770-\
245f3e10daf3"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["\[Theta]", "*"],
    $CellContext`angularScale], "=", 
   FractionBox[
    InterpretationBox[
     SubscriptBox["r", "s"],
     $CellContext`soundHorizon], 
    InterpretationBox[
     SubscriptBox["R", "\[Perpendicular]"],
     $CellContext`transverseRadius]]}], ";"}]], "Input",
 CellChangeTimes->{{3.981385932084133*^9, 3.9813859934688683`*^9}, {
  3.9876228457399693`*^9, 3.987622878301548*^9}},
 CellLabel->
  "In[234]:=",ExpressionUUID->"1ac85262-a587-8f4d-a6bd-d4559e2e947a"],

Cell[TextData[{
 "Substituting the expression above for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["r", "TI"], "\[Perpendicular]"], TraditionalForm], 
     "errors" -> {}, "input" -> "$r_\\perp$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a5b13f23-edac-8148-a517-74eeeea2ba8f"],
 " gives"
}], "Text",
 CellChangeTimes->{{3.987620746740057*^9, 
  3.9876207523173676`*^9}},ExpressionUUID->"1cf6f392-ee56-8945-b0da-\
621cbd791f55"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Theta]", "*"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"4", "\[Pi]", 
            RowBox[{"(", 
              RowBox[{"1", "+", 
                SubscriptBox[
                 StyleBox["z", "TI"], "*"]}], ")"}]}], 
          RowBox[{
            StyleBox["L", "TI"], 
            RowBox[{"(", 
              SubscriptBox[
               StyleBox["t", "TI"], 
               StyleBox["o", "TI"]], ")"}], 
            RowBox[{"(", 
              RowBox[{"2", "+", 
                SubscriptBox[
                 StyleBox["z", "TI"], "*"]}], ")"}]}]], " ", 
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["s", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\theta_*=\\frac{4\\pi(1+z_*)}{L(t_o)(2+z_*)}\\,r_s$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876207668370514`*^9, 3.9876207721620502`*^9}, {
  3.9877087605827656`*^9, 
  3.987708760585615*^9}},ExpressionUUID->"68c358f0-6797-9b49-b0d9-\
8f766e70618b"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["\[Theta]", "*"],
    $CellContext`angularScale], "=", 
   RowBox[{
    InterpretationBox[
     SubscriptBox["\[Theta]", "*"],
     $CellContext`angularScale], "/.", "\[VeryThinSpace]", 
    RowBox[{
     InterpretationBox[
      SubscriptBox["R", "\[Perpendicular]"],
      $CellContext`transverseRadius], "\[Rule]", 
     FractionBox[
      InterpretationBox[
       SubscriptBox["C", "\[Perpendicular]"],
       $CellContext`transverseCircumference], 
      RowBox[{"2", " ", "\[Pi]"}]]}]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.9813860170051785`*^9, 3.981386106561743*^9}, {
   3.9813861462785015`*^9, 3.981386152951828*^9}, {3.981386397206545*^9, 
   3.9813863980853653`*^9}, {3.981386604562908*^9, 3.9813866672948837`*^9}, {
   3.9813873476889553`*^9, 3.9813873871823616`*^9}, 3.987623029016823*^9},
 CellLabel->
  "In[235]:=",ExpressionUUID->"c02bd0eb-e025-504c-a0c3-4c576241f46f"],

Cell[TextData[{
 "Using equation (7) evaluated at ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["o", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_o$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cb15cb9a-dca1-6b48-b9ab-ea4b35ac177b"],
 " yields"
}], "Text",
 CellChangeTimes->{{3.9876207835284023`*^9, 3.987620795278633*^9}, 
   3.987623754568762*^9},ExpressionUUID->"bea755d2-2da0-f54e-bea0-\
8f68ac0f3125"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Theta]", "*"], "\[LongEqual]", 
         FractionBox[
          RowBox[{"8", "\[Pi]", 
            RowBox[{"(", 
              RowBox[{"1", "+", 
                SubscriptBox[
                 StyleBox["z", "TI"], "*"]}], ")"}]}], 
          RowBox[{
            SubscriptBox[
             StyleBox["t", "TI"], 
             StyleBox["o", "TI"]], 
            RowBox[{"(", 
              RowBox[{"2", 
                SubscriptBox[
                 StyleBox["V", "TI"], "0"], "-", 
                StyleBox["A", "TI"], 
                SubscriptBox[
                 StyleBox["t", "TI"], 
                 StyleBox["o", "TI"]]}], ")"}], 
            RowBox[{"(", 
              RowBox[{"2", "+", 
                SubscriptBox[
                 StyleBox["z", "TI"], "*"]}], ")"}]}]], " ", 
         SubscriptBox[
          StyleBox["r", "TI"], 
          StyleBox["s", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\theta_*=\\frac{8\\pi(1+z_*)}{t_o(2V_0-A t_o)(2+z_*)}\\,r_s$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987620807662369*^9, 3.9876208116170063`*^9}, {
  3.9877087952658806`*^9, 
  3.9877087952658806`*^9}},ExpressionUUID->"392c510c-ba5a-9149-8fcf-\
ab1c07c4cbba"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["\[Theta]", "*"],
    $CellContext`angularScale], "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     InterpretationBox[
      SubscriptBox["\[Theta]", "*"],
      $CellContext`angularScale], "/.", "\[VeryThinSpace]", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        InterpretationBox[
         SubscriptBox["C", "\[Perpendicular]"],
         $CellContext`transverseCircumference], "\[Rule]", 
        RowBox[{
         FractionBox["1", "2"], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"L", "[", 
            InterpretationBox[
             SubscriptBox["t", "o"],
             $CellContext`observationTime], "]"}], "+", 
           RowBox[{"L", "[", 
            InterpretationBox[
             SubscriptBox["r", "s"],
             $CellContext`soundHorizon], "]"}]}], ")"}]}]}], "/.", 
       "\[VeryThinSpace]", 
       RowBox[{
        RowBox[{"L", "[", 

Cell[TextData[{
 "Substituting into equation (13) and imposing the null condition ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[CapitalDelta]", 
         SuperscriptBox[
          StyleBox["s", "TI"], "2"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "$\\Delta s^2 = 0$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "a4d26595-9cd6-f349-8d10-47721e505689"],
 " yields the observable spatial separation,"
}], "Text",

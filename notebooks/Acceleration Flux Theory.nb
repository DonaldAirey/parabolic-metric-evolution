Cell[BoxData[
 FractionBox[
  RowBox[{
   InterpretationBox[
    SubscriptBox["V", "0"],
    $CellContext`initialVelocity], "+", 
   RowBox[{
    InterpretationBox[
     SubscriptBox["V", "0"],
     $CellContext`initialVelocity], " ", "z"}], "-", 
   SqrtBox[
    RowBox[{
     RowBox[{"(", 

       RowBox[{"Red", ",", 
        RowBox[{"AbsoluteThickness", "[", "2.5", "]"}]}], "}"}]}]}], "]"}]}], 
  ";"}], "\n", 
 RowBox[{"btfrPlot", "=", 
  RowBox[{"Show", "[", 
   RowBox[{"observedPlot", ",", "modelPlot", ",", 
    RowBox[{"ImageSize", "\[Rule]", "Large"}]}], "]"}]}]}], "Input",

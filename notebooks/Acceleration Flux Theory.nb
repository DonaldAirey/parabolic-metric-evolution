Cell[CellGroupData[{

Cell["Early-Time Evolution", "Section",
 CellChangeTimes->{
  3.9876031423490887`*^9},ExpressionUUID->"a258e56a-9bde-2d48-950c-\
c843c4037682"],

Cell["\<\
Independent constraints arise from the cosmic microwave background (CMB), \
whose acoustic scale probes the distance to last scattering relative to the \
sound horizon.\
\>", "Text",
 CellChangeTimes->{
  3.9876031515890923`*^9},ExpressionUUID->"a356c15c-9e20-894a-a028-\
913480837d5b"],

Cell["\<\
The expansion history is determined by the PME kinematics derived above, \
while recombination microphysics is evaluated using standard rate equations. \
Thermodynamic quantities are mapped using the scale factor\
\>", "Text",
 CellChangeTimes->{
  3.987603162992111*^9},ExpressionUUID->"9fce5b54-ba2a-cf46-8dfe-\
30d5022e4505"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            StyleBox["L", "TI"], "(", 
            StyleBox["t", "TI"], ")"}], 
          RowBox[{
            StyleBox["L", "TI"], "(", 
            SubscriptBox[
             StyleBox["t", "TI"], 
             StyleBox["o", "TI"]], ")"}]]}], TraditionalForm], "errors" -> {},
      "input" -> "$a(t) = \\frac{L(t)}{L(t_o)}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987603176458294*^9, 3.9876031805366955`*^9}, {
  3.9877052692035046`*^9, 
  3.9877052692035046`*^9}},ExpressionUUID->"9fe3b377-2cb5-764f-bbef-\
7a54b168a00e"],

Cell[CellGroupData[{

Cell["Baryon and Photon Densities", "Subsection",
 CellChangeTimes->{
  3.987603192736294*^9},ExpressionUUID->"e709ae5c-1930-9d4b-bc64-\
8deed626ecf4"],

Cell["\<\
The recombination history and pre-decoupling sound speed require the baryon \
and photon densities. The baryon density is fixed by the manifold \
acceleration scale rather than introduced as an independent cosmological \
parameter. This follows from the local divergence law (equation (33)), which \
relates the sourced acceleration field to the baryonic density.\
\>", "Text",
 CellChangeTimes->{{3.9876032043330784`*^9, 3.9876032157863483`*^9}, {
  3.987705206683399*^9, 
  3.9877052136844997`*^9}},ExpressionUUID->"2d2630a4-e99a-5943-b925-\
c2124269555a"],

Cell[TextData[{
 "For a homogeneous baryonic distribution of density ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Rho]", 
        StyleBox["b", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\rho_b$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5f38f610-4734-df4f-95a7-716602f1f615"],
 " within a region of characteristic size ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["L", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$L$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "aa13dfc5-0c76-b949-abdf-c57ebc19ffa2"],
 ", the enclosed mass is"
}], "Text",
 CellChangeTimes->{{3.987603228427124*^9, 
  3.9876032368024387`*^9}},ExpressionUUID->"8ade0b0f-dee3-4240-8b15-\
bfc592bd8e18"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["M", "TI"], 
         RowBox[{"(", 
           StyleBox["L", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"4", "\[Pi]"}], "3"], 
         SuperscriptBox[
          StyleBox["L", "TI"], "3"], 
         SubscriptBox["\[Rho]", 
          StyleBox["b", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$M(L)=\\frac{4\\pi}{3}L^3\\rho_b$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",

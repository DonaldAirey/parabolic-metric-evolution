   SuperscriptBox["v", "4"], 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"4", " ", "A", " ", "G"}], ")"}], " ", "massScale"}]]}], "\n", 
 RowBox[{
  RowBox[{"observedPlot", "=", 

 CellChangeTimes->{
  3.987603260888796*^9},ExpressionUUID->"ca746ec3-50b3-2845-9921-\
bb7d3c08fbfb"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Rho]", 
          StyleBox["b", "TI"]], "\[LongEqual]", 

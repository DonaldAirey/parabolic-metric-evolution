  3.987607471973276*^9}},ExpressionUUID->"bf928164-01cd-6b41-84ff-\
98562c930ace"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          RowBox[{
            StyleBox["G", "TI"], 
            StyleBox["M", "TI"], 

Cell["\<\
Table 1 - PME kinematic parameters determined from BTFR and \
Cepheid-calibrated Pantheon+ subset.\
\>", "Text",
 CellChangeTimes->{{3.977567532141512*^9, 3.9775676263798904`*^9}, 
   3.9792390198174305`*^9, {3.9792452983602715`*^9, 3.9792453074476433`*^9}, {
   3.9792455777899876`*^9, 3.979245607912098*^9}, {3.9792954141510353`*^9, 
   3.979295421572731*^9}, {3.979296156777832*^9, 3.9792961598583736`*^9}, 
   3.9795609282841587`*^9, 3.9795611709390526`*^9, {3.9795619597361107`*^9, 
   3.9795619599553795`*^9}, {3.9795622292897415`*^9, 3.979562231136034*^9}, {
   3.980021006772833*^9, 3.980021035649374*^9}, {3.9818039504657936`*^9, 
   3.9818039721253014`*^9}, {3.987591536877594*^9, 
   3.987591543644024*^9}},ExpressionUUID->"f7165b05-4293-624c-9e17-\
fe26cafe84bb"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Comparison with Observations", "Subsection",
 CellChangeTimes->{{3.977140272635559*^9, 
  3.977140275651041*^9}},ExpressionUUID->"3840ce29-eb39-5947-b52e-\
103eeaa0393a"],

Cell["\<\
Figure 5 shows the PME prediction and the Planck 2018 FLRW model compared \
with the Pantheon+SH0ES data.\
\>", "Text",
 CellChangeTimes->{{3.987600653097822*^9, 3.9876006589279613`*^9}, 
   3.987600961917677*^9},ExpressionUUID->"5dd4e1d6-8754-6943-af0d-\
1f2b432fe26c"],

Cell[TextData[{
 "The Pantheon+SH0ES dataset provides observed distance moduli ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", 
          StyleBox["obs", FontSlant -> "Plain"]], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\mu_{\\mathrm{obs}}(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0d8506a6-864e-9947-aec5-4ec2d2ffcab5"],
 " calibrated on an absolute scale through the SH0ES determination of the \
Type~Ia supernova absolute magnitude. This calibration is applied identically \
to both models."
}], "Text",
 CellChangeTimes->{{3.9876006779429474`*^9, 
  3.98760068885606*^9}},ExpressionUUID->"58e8a43f-f484-e348-8eac-\
f28e875e513e"],

Cell[TextData[{
 "Each model predicts ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["D", "TI"], 
          StyleBox["L", "TI"]], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$D_L(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f38659dc-0e16-c243-a631-4621ad80e29b"],
 ", which is mapped to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", 
          StyleBox["th", FontSlant -> "Plain"]], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\mu_{\\mathrm{th}}(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "286e725e-7a5f-5540-9329-09f300dec2b9"],
 " using the definition of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Mu]", "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\mu(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "de029d55-a0c8-274f-852c-684b4b172209"],
 " introduced earlier. We compare ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", 
          StyleBox["th", FontSlant -> "Plain"]], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\mu_{\\mathrm{th}}(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f0ed9ae3-f756-f640-8f4f-966e18903cdf"],
 " to ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Mu]", 
          StyleBox["obs", FontSlant -> "Plain"]], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\mu_{\\mathrm{obs}}(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "910577ca-eafb-8a4a-9707-802aa14cf759"],
 " using the full Pantheon+ STAT+SYS covariance matrix."
}], "Text",
 CellChangeTimes->{{3.9876006982411633`*^9, 
  3.9876007272421093`*^9}},ExpressionUUID->"31589655-86d0-654e-aaa0-\
05c4b48bc36c"],

Cell[TextData[{
 "PME is evaluated using the fixed parameter set derived above. FLRW is \
evaluated using a spatially flat model specified by the Planck 2018 parameter \
set ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalOmega]", 
          StyleBox["m", "TI"]], "\[LongEqual]", "0.315"}], TraditionalForm], 
     "errors" -> {}, "input" -> "$\\Omega_m = 0.315$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "17244d46-27d1-cd44-86ad-ad8243875fb7"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[CapitalOmega]", "\[CapitalLambda]"], "\[LongEqual]", 
         "1", "-", 
         SubscriptBox["\[CapitalOmega]", 
          StyleBox["m", "TI"]]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\Omega_\\Lambda = 1-\\Omega_m$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4c4d29c4-c4cc-3c4f-8ce1-2176a3c24976"],
 ", and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["H", "TI"], "0"], "\[LongEqual]", "67.4", 
         StyleBox["k", "TI"], 
         StyleBox["m", "TI"], 
         SuperscriptBox[
          StyleBox["s", "TI"], "-1"], 
         StyleBox["M", "TI"], 
         StyleBox["p", "TI"], 
         SuperscriptBox[
          StyleBox["c", "TI"], "-1"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$H_0 = 67.4 km s^{-1} Mpc^{-1}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fac3323c-b3f1-5242-a5b8-30889d7b35a3"],
 " [",
 ButtonBox["1",
  BaseStyle->"Hyperlink",
  ButtonData->"Planck2018"],
 "]. The comparison is performed on the out-of-sample supernovae, excluding \
the Cepheid calibration records."
}], "Text",
 CellChangeTimes->{{3.987600739579275*^9, 3.9876007595865974`*^9}, {
  3.987600814632145*^9, 
  3.9876008544419994`*^9}},ExpressionUUID->"63a89f32-8169-294b-baa7-\
f594b9e07595"],

Cell["The resulting covariance-weighted chi-square values are", "Text",
 CellChangeTimes->{
  3.9876008954892235`*^9},ExpressionUUID->"7207b3ca-8e3b-ca4a-9840-\
04e263e43080"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubsuperscriptBox["\[Chi]", 
          StyleBox["PME", FontSlant -> "Plain"], "2"], "\[LongEqual]", "2726",
          ",    ", 
         SubsuperscriptBox["\[Chi]", 
          StyleBox["FLRW", FontSlant -> "Plain"], "2"], "\[LongEqual]", 
         "4049"}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\chi^2_{\\mathrm{PME}}=2726,\\qquad \\chi^2_{\\mathrm{FLRW}}=4049$", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876009101155357`*^9, 3.987600913475895*^9}, {
  3.9877048448080196`*^9, 
  3.98770484481378*^9}},ExpressionUUID->"e4dce166-9947-f442-9536-\
7a654e916c27"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Nu]", "\[LongEqual]", "1625"}], TraditionalForm], 
     "errors" -> {}, "input" -> "$\\nu=1625$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "15d84ff3-6b42-864c-a4f6-765371d83f88"],
 ", corresponding to reduced values ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox["\[Chi]", "2"], "/", "\[Nu]", "\[LongEqual]", 
         "1.68"}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\chi^2/\\nu=1.68$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9cf6f5b9-0013-5d44-8f51-a5aa3a522d0d"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["2.49", TraditionalForm], "errors" -> {}, "input" -> 
     "$2.49$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e25ff372-670b-744d-b967-15c3cb2227e4"],
 ", respectively. PME predicts the observed distance moduli substantially \
more accurately than the Planck 2018 FLRW model across the Pantheon+SH0ES \
sample, without dark sector parameters."
}], "Text",
 CellChangeTimes->{{3.987600922787264*^9, 
  3.987600945559374*^9}},ExpressionUUID->"7484a6a3-92fb-3847-b35c-\
00832e323fdf"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pmeParams", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"A", "\[Rule]", 
      InterpretationBox[
       StyleBox["\[ScriptCapitalA]",
        FontFamily->"Times"],
       $CellContext`accelerationSI]}], ",", 
     RowBox[{
      InterpretationBox[
       SubscriptBox["V", "0"],
       $CellContext`initialVelocity], "\[Rule]", 
      InterpretationBox[
       SubscriptBox[
        StyleBox["\[ScriptCapitalV]",
         FontFamily->"Times"], "0"],
       $CellContext`initialVelocitySI]}], ",", 
     RowBox[{
      InterpretationBox[
       SubscriptBox["t", "o"],
       $CellContext`observationTime], "\[Rule]", 
      InterpretationBox[
       SubscriptBox[
        StyleBox["\[ScriptT]",
         FontFamily->"Times"], "o"],
       $CellContext`observationTimeSI]}], ",", 
     RowBox[{"pc", "\[Rule]", 
      RowBox[{"UnitConvert", "[", 
       RowBox[{
        RowBox[{"Quantity", "[", 
         RowBox[{"1", ",", "\"\<Parsecs\>\""}], "]"}], 
        ",", "\"\<Meters\>\""}], "]"}]}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"flrwParams", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      InterpretationBox[
       SubscriptBox["\[CapitalOmega]", "m"],
       $CellContext`massDensity], "\[Rule]", "0.315"}], ",", 
     RowBox[{
      InterpretationBox[
       SubscriptBox["\[CapitalOmega]", "k"],
       $CellContext`curvatureDensity], "\[Rule]", "0"}]}], "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"flrwParams", "=", 
   RowBox[{"Join", "[", 
    RowBox[{"flrwParams", ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{
         InterpretationBox[
          SubscriptBox["\[CapitalOmega]", "\[Lambda]"],
          $CellContext`lambdaDensity], "\[Rule]", 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           InterpretationBox[
            SubscriptBox["\[CapitalOmega]", "m"],
            $CellContext`massDensity], "-", 
           InterpretationBox[
            SubscriptBox["\[CapitalOmega]", "k"],
            $CellContext`curvatureDensity]}], ")"}]}], "/.", 
        "\[VeryThinSpace]", "flrwParams"}], ",", 
       RowBox[{
        InterpretationBox[
         SubscriptBox["H", "0"],
         $CellContext`hubbleConstant], "\[Rule]", 
        RowBox[{"UnitConvert", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Quantity", "[", 
            RowBox[{"67.4", ",", 
             FractionBox["\"\<Kilometers\>\"", 
              RowBox[{"\"\<Seconds\>\"", " ", "\"\<Megaparsecs\>\""}]]}], 
            "]"}], "/.", " ", "flrwParams"}], ",", 
          RowBox[{"1", "/", "\"\<Seconds\>\""}]}], "]"}]}], ",", 
       RowBox[{"pc", "\[Rule]", 
        RowBox[{"UnitConvert", "[", 
         RowBox[{
          RowBox[{"Quantity", "[", 
           RowBox[{"1", ",", "\"\<Parsecs\>\""}], "]"}], 
          ",", "\"\<Meters\>\""}], "]"}]}], ",", 
       RowBox[{"c", "\[Rule]", 
        RowBox[{"UnitConvert", "[", 
         RowBox[{
          RowBox[{"Quantity", "[", "\"\<SpeedOfLight\>\"", "]"}], ",", 
          FractionBox["\"\<Meters\>\"", "\"\<Seconds\>\""]}], "]"}]}]}], 
      "}"}]}], "]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.979296369538599*^9, 3.9792964148985043`*^9}, {
   3.9792969350240364`*^9, 3.979296938056988*^9}, {3.9792970398400364`*^9, 
   3.979297044979803*^9}, {3.9792975136355114`*^9, 3.9792975209792557`*^9}, {

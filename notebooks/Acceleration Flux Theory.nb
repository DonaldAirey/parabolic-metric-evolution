Cell[TextData[{
 "Figure 4. Log-log plot of baryonic mass ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["M", "TI"], 
        StyleBox["b", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$M_b$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8a478f67-44fb-8c47-af1c-6cdb4d925b08"],
 " versus outer rotation speed ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["v", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$v$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "676f4610-784e-8241-b673-d89fb2ed2682"],
 " for the SPARC galaxy sample of McGaugh, Lelli and Schombert [",
 ButtonBox["18",
  BaseStyle->"Hyperlink",
  ButtonData->"McGaugh2016"],
 "]. Black circles show the observed galaxies. The solid red line shows the \
PME circular-orbit envelope evaluated at the best-fit acceleration."
}], "Text",
 CellChangeTimes->{{3.9766397454337826`*^9, 3.976639846803047*^9}, {
   3.976640139558981*^9, 3.97664014585009*^9}, 3.9769078922876663`*^9, {
   3.9769079317147484`*^9, 3.9769079919011936`*^9}, {3.9769080250286427`*^9, 
   3.9769080250286427`*^9}, 3.9770605461290054`*^9, {3.977225377189287*^9, 
   3.97722537774123*^9}, {3.9790503410992603`*^9, 3.979050341881859*^9}, 
   3.979671470943638*^9, {3.980011804728863*^9, 3.9800118050474777`*^9}, {

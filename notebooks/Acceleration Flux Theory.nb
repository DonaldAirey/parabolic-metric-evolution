Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"supernovaObservedPoints", " ", "=", " ", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"supernovaRedshifts", ",", " ", "supernovaDistanceModuli"}], 
      "}"}], "]"}]}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pmePredictedPoints", " ", "=", " ", 
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"supernovaRedshifts", ",", " ", 
       RowBox[{
        RowBox[{"pmePrediction", " ", "/@", " ", "supernovaRedshifts"}], " ", 
        "/.", " ", "pmeParams"}]}], "}"}], "]"}]}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"observedPlot", " ", "=", " ", 
    RowBox[{"ListPlot", "[", 
     RowBox[{"supernovaObservedPoints", ",", " ", 
      RowBox[{"PlotStyle", " ", "->", " ", 
       RowBox[{"{", "Gray", "}"}]}], ",", " ", 
      RowBox[{"PlotMarkers", " ", "->", " ", 
       RowBox[{"{", 
        RowBox[{"\"\<\[FilledCircle]\>\"", ",", " ", "Medium"}], "}"}]}], ",",
       " ", 
      RowBox[{"PlotRange", " ", "->", " ", "All"}]}], "]"}]}], ";"}], " "}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"pmeLine", " ", "=", " ", 
    RowBox[{"ListLinePlot", "[", 
     RowBox[{"pmePredictedPoints", ",", " ", 

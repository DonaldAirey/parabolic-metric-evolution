   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Tau]", 
          StyleBox["T", "TI"]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubsuperscriptBox["\[Integral]", 
          StyleBox["t", "TI"], 

Cell[TextData[{
 "Figure 6. Photon visibility function ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["g", "TI"], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$g(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "aeda68f8-fcdd-e84b-bea4-bdc4b811aaa1"],
 " evaluated using the recombination history on the PME expansion background. \
The peak defines the recombination epoch, yielding ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["z", "TI"], "*"], "\[LongEqual]", "1039"}], 
       TraditionalForm], "errors" -> {}, "input" -> "$z_* = 1039$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "48ede7b9-5eb3-0646-8b31-1d3c55aa06e0"],
 "."
}], "Text",
 CellChangeTimes->{{3.981633347586588*^9, 3.9816334187683067`*^9}, {
  3.9816334956512737`*^9, 3.9816335238527317`*^9}, {3.981633798697752*^9, 
  3.9816338089232273`*^9}, {3.9816598974196377`*^9, 3.9816598975376244`*^9}, {
  3.98761638644166*^9, 
  3.9876163986448*^9}},ExpressionUUID->"96e4c528-9cae-f948-8168-a7c7ca1b0b35"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Sound Horizon", "Subsection",
 CellChangeTimes->{{3.9720673848068066`*^9, 3.972067391021948*^9}, {
   3.972067639477247*^9, 3.9720676475714684`*^9}, 
   3.9876172509696255`*^9},ExpressionUUID->"e388aab7-935a-7840-9072-\
eb97b3da606c"],

Cell[TextData[{
 "Prior to recombination, baryons and photons form a tightly coupled fluid \
whose acoustic interaction distance defines the sound horizon. The \
thermodynamic evolution follows the scale factor ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["a", "TI"], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$a(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f56dca6b-55ce-2b40-b300-42b071f3236f"],
 " defined in equation (73)."
}], "Text",
 CellChangeTimes->{
  3.9816390206620502`*^9, {3.98761726031781*^9, 3.9876172708970337`*^9}, {
   3.9877062533047523`*^9, 
   3.987706255398636*^9}},ExpressionUUID->"c25db370-6c4c-014e-8c81-\
e80ba9ca39d9"],

Cell["The baryon\[Dash]photon momentum ratio is defined as", "Text",
 CellChangeTimes->{
  3.9816390511114044`*^9},ExpressionUUID->"4a6f5dd3-3f5b-1e4c-8d0c-\
c78b1e63eca6"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["R", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"3", 
            SubscriptBox["\[Rho]", 
             StyleBox["b", "TI"]]}], 
          RowBox[{"4", 
            SubscriptBox["\[Rho]", "\[Gamma]"], 
            RowBox[{"(", 
              StyleBox["t", "TI"], ")"}]}]], " ", 
         FractionBox[
          RowBox[{
            StyleBox["a", "TI"], 
            SuperscriptBox[
             RowBox[{"(", 
               StyleBox["t", "TI"], ")"}], "-3"]}], 
          RowBox[{
            StyleBox["a", "TI"], 
            SuperscriptBox[
             RowBox[{"(", 
               StyleBox["t", "TI"], ")"}], "-4"]}]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"3", 
            SubscriptBox["\[Rho]", 
             StyleBox["b", "TI"]]}], 
          RowBox[{"4", 
            SubscriptBox["\[Rho]", "\[Gamma]"], 
            RowBox[{"(", 
              StyleBox["t", "TI"], ")"}]}]], " ", 
         StyleBox["a", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "$R(t)=\\frac{3\\rho_b}{4\\rho_\\gamma(t)}\\,\\frac{a(t)^{-3}}{a(t)^{-4}}\
=\\frac{3\\rho_b}{4\\rho_\\gamma(t)}\\,a(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876175311725197`*^9, 3.987617535004778*^9}, {
  3.987706327714964*^9, 
  3.9877063277169647`*^9}},ExpressionUUID->"0ba6d5e1-4bdf-f149-a67c-\
f763ff8acc2c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"R", "[", 
   RowBox[{"t_", "?", "QuantityQ"}], "]"}], ":=", 
  RowBox[{
   FractionBox[
    RowBox[{"3", " ", 
     InterpretationBox[
      SubscriptBox["\[Rho]", "b"],
      $CellContext`baryonDensity], " "}], 
    RowBox[{"4", " ", 
     RowBox[{
      InterpretationBox[
       SubscriptBox["\[Rho]", "\[Gamma]"],
       $CellContext`photonDensity], "[", "t", "]"}]}]], 
   RowBox[{
    InterpretationBox[
     SubscriptBox["a", "t"],
     $CellContext`scaleFactorFromTime], "[", "t", "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9720673302492886`*^9, 3.9720673738855743`*^9}, {
   3.9720674044005146`*^9, 3.9720674270724354`*^9}, 3.972074809627573*^9, {
   3.9720759905376663`*^9, 3.972076008263565*^9}, 3.9721182993880405`*^9, {
   3.9721186798889046`*^9, 3.9721186809308453`*^9}, {3.972145055416321*^9, 
   3.972145070549717*^9}, 3.9721466629649525`*^9, {3.972295459327551*^9, 
   3.972295470372534*^9}, 3.9723193189718323`*^9, {3.9723194207923603`*^9, 
   3.972319422605253*^9}, {3.97232057329154*^9, 3.972320584168476*^9}, {
   3.9723206342814007`*^9, 3.9723206696536255`*^9}, {3.9782863061458435`*^9, 
   3.978286430686262*^9}, {3.978369279002884*^9, 3.978369284237852*^9}, {
   3.9783693698436375`*^9, 3.9783694643508205`*^9}, {3.978369499734871*^9, 
   3.9783695036232357`*^9}, {3.978369586709711*^9, 3.9783696530720596`*^9}, {
   3.9783697219151974`*^9, 3.9783697490987415`*^9}, {3.9783707042947464`*^9, 
   3.978370708712227*^9}, {3.9783733893004055`*^9, 3.978373397569313*^9}, {
   3.9784405833351765`*^9, 3.9784405848837147`*^9}, {3.9784677073533306`*^9, 
   3.9784677259152718`*^9}, {3.9784680283692436`*^9, 
   3.9784680436814423`*^9}, {3.9807787611382065`*^9, 
   3.9807787734760666`*^9}, {3.980778921656246*^9, 3.9807789266901703`*^9}, {

          RowBox[{"\[CapitalDelta]", 
            SubsuperscriptBox[
             StyleBox["x", "TI"], 
             StyleBox["o", "TI"], "1"]}], "2"], 
         RowBox[{"(", 
           RowBox[{"1", "+", 
             FractionBox[
              RowBox[{
                SubscriptBox[
                 StyleBox["V", "TI"], "0"], 
                SubscriptBox[
                 StyleBox["t", "TI"], 
                 StyleBox["e", "TI"]], "-", 
                FractionBox["1", "2"], 
                StyleBox["A", "TI"], 
                SubsuperscriptBox[
                 StyleBox["t", "TI"], 
                 StyleBox["e", "TI"], "2"]}], 
              RowBox[{
                SubscriptBox[
                 StyleBox["V", "TI"], "0"], 
                SubscriptBox[
                 StyleBox["t", "TI"], 

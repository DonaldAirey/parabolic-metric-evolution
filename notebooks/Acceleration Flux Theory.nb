        RowBox[{"Style", "[", 
         RowBox[{
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{
             SubscriptBox["\"\<v\>\"", "\"\<flat\>\""], 
             ",", "\"\< (km \!\(\*SuperscriptBox[\(s\), \(-1\)]\))\>\""}], 
            "}"}], "]"}], ",", "14"}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{
             SubscriptBox["\"\<M\>\"", "\"\<b\>\""], ",", "\"\< (\>\"", ",", 
             TemplateBox[{"\"10\"", "\"9\""},
              "Superscript"], ",", 
             SubscriptBox["\"\<M\>\"", "\"\<\[CircleDot]\>\""], 
             ",", "\"\<)\>\""}], "}"}], "]"}], ",", "14"}], "]"}]}], "}"}]}], 
     ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Directive", "[", 
        RowBox[{"Black", ",", 
         RowBox[{"Opacity", "[", "0.6", "]"}]}], "]"}], "}"}]}], ",", 
     RowBox[{"GridLines", "\[Rule]", "Automatic"}], ",", 
     RowBox[{"PlotMarkers", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Automatic", ",", "12"}], "}"}]}], ",", 
     RowBox[{"PlotRange", "\[Rule]", "All"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"modelPlot", "=", 
   RowBox[{"LogLogPlot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"modelMass", "[", 
       RowBox[{"Quantity", "[", 
        RowBox[{"v", ",", 
         FractionBox["\"\<Kilometers\>\"", "\"\<Seconds\>\""]}], "]"}], "]"}],
       "/.", "\[VeryThinSpace]", 

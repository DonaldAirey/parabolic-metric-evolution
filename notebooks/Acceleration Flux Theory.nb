Cell[TextData[{
 "We identify wavelength with a comoving spatial separation and assume that \
such separations scale with the manifold extent, so that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Lambda]", 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[Proportional]", 
         StyleBox["L", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$\\lambda(t) \\propto L(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4e745314-8e3a-924b-a0ba-7c9cb54b1e58"],
 "."
}], "Text",
 CellChangeTimes->{{3.987330152195322*^9, 
  3.987330160438982*^9}},ExpressionUUID->"72026683-6fe0-3347-8940-\
207ae01ab248"],

Cell[BoxData[
 FormBox[

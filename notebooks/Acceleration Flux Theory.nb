     RowBox[{
      RowBox[{
       InterpretationBox[
        SubscriptBox["t", "e"],
        $CellContext`emissionTime], "\[Rule]", "0"}], ",", 
      RowBox[{
       InterpretationBox[
        SubscriptBox["t", "o"],
        $CellContext`observationTime], "\[Rule]", "t"}]}], "}"}]}], 
   "]"}]}]], "Input",

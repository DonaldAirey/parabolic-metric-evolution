   3.977252806407612*^9, {3.977597788731493*^9, 3.977597789103586*^9}, {
   3.977751295758995*^9, 3.977751313340372*^9}, 3.977852973309145*^9, 
   3.97785347272213*^9, {3.977855569085186*^9, 3.9778555695161304`*^9}, {
   3.978818704309353*^9, 3.978818708243393*^9}, {3.9789824055527973`*^9, 

Cell[BoxData[{
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox[
     StyleBox["\[ScriptT]",
      FontFamily->"Times"], "o"],
    $CellContext`observationTimeSI], "=", 
   RowBox[{"Quantity", "[", 
    RowBox[{
     RowBox[{"Exp", "[", 
      RowBox[{
       InterpretationBox[
        SubscriptBox["t", "log"],
        $CellContext`logTime], "/.", "\[VeryThinSpace]", 
       RowBox[{
       "result", "\[LeftDoubleBracket]", "2", "\[RightDoubleBracket]"}]}], 
      "]"}], ",", "\"\<Seconds\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox[
     StyleBox["\[ScriptCapitalV]",
      FontFamily->"Times"], "0"],
    $CellContext`initialVelocitySI], "=", 

           StyleBox["z", "TI"], ")"}], "\[LongEqual]", "\[CapitalDelta]", 
         SubsuperscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["o", "TI"], "1"], "\[LongEqual]", 

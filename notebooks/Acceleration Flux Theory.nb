Cell[TextData[{
 "The surface ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["M", "TI"], "(", 
         RowBox[{
           StyleBox["v", "TI"], ",", 
           StyleBox["r", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$M(v,r)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dc9deef1-9ad3-c349-b8da-896688ff7700"],
 " therefore defines a fundamental plane of circular-orbit solutions, as \
shown in Figure 3, with the ridge ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["M", "TI"], "max"], "(", 
         StyleBox["v", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$M_{\\max}(v)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0645e5eb-fec7-6c47-b86a-2df87b7861fa"],
 " giving the upper envelope of baryonic mass for a given orbital speed. \
Galaxies dominated by circular rotation are expected to saturate this \
boundary and follow a characteristic mass--velocity relation."
}], "Text",
 CellChangeTimes->{{3.9874475683336697`*^9, 
  3.9874476083374805`*^9}},ExpressionUUID->"a0317f20-7298-1f4d-88bb-\
2825d849be64"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"params", "=", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"G", "\[Rule]", 
      RowBox[{"UnitConvert", "[", 
       RowBox[{
        RowBox[{"Quantity", "[", "\"\<GravitationalConstant\>\"", "]"}], ",", 
        FractionBox[
         SuperscriptBox["\"\<Meters\>\"", "3"], 
         RowBox[{"\"\<Kilograms\>\"", " ", 
          SuperscriptBox["\"\<Seconds\>\"", "2"]}]]}], "]"}]}], ",", 
     RowBox[{"A", "\[Rule]", 
      RowBox[{"Quantity", "[", 
       RowBox[{
        FractionBox["1", 
         SuperscriptBox["10", "11"]], ",", 
        FractionBox["\"\<Meters\>\"", 
         SuperscriptBox["\"\<Seconds\>\"", "2"]]}], "]"}]}]}], "}"}]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"massSurface", "[", 
    RowBox[{"v_", ",", "r_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{"ConditionalExpression", "[", 
     RowBox[{
      RowBox[{"UnitConvert", "[", 
       RowBox[{
        RowBox[{"M", "[", 
         RowBox[{"v", ",", "r"}], "]"}], ",", "\"\<SolarMass\>\""}], "]"}], ",", 
      RowBox[{
       RowBox[{"QuantityMagnitude", "[", 
        RowBox[{"UnitConvert", "[", 
         RowBox[{
          RowBox[{
           SuperscriptBox["v", "2"], "-", 
           RowBox[{"A", " ", "r"}]}], ",", 
          FractionBox[
           SuperscriptBox["\"\<Meters\>\"", "2"], 
           SuperscriptBox["\"\<Seconds\>\"", "2"]]}], "]"}], "]"}], ">", 
       "0"}]}], "]"}], "/.", "\[VeryThinSpace]", "params"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{"massScale", "=", 
   FractionBox["1", 
    RowBox[{"Quantity", "[", 
     RowBox[{
      SuperscriptBox["10", "9"], ",", "\"\<SolarMass\>\""}], "]"}]]}], 
  ";"}], "\n", 
 RowBox[{
  RowBox[{"fundamentalPlane", "=", 
   RowBox[{"Plot3D", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"UnitConvert", "[", 
       RowBox[{
        RowBox[{"massSurface", "[", 
         RowBox[{
          RowBox[{"Quantity", "[", 
           RowBox[{"v", ",", 
            FractionBox["\"\<Kilometers\>\"", "\"\<Seconds\>\""]}], "]"}], ",", 
          RowBox[{"Quantity", "[", 
           RowBox[{"r", ",", "\"\<Kiloparsecs\>\""}], "]"}]}], "]"}], 
        ",", "\"\<SolarMass\>\""}], "]"}], " ", "massScale"}], ",", 
     RowBox[{"{", 
      RowBox[{"v", ",", "0", ",", "100"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "0", ",", "30"}], "}"}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Style", "[", 
         RowBox[{"\"\<speed (km \!\(\*SuperscriptBox[\(s\), \(-1\)]\))\>\"", ",",
           "14"}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<radius (kpc)\>\"", ",", "14"}], "]"}], ",", 
        RowBox[{"Style", "[", 
         RowBox[{"\"\<mass (\!\(\*SuperscriptBox[\(10\), \(9\)]\) \
\!\(\*SubscriptBox[\(M\), \(\[Sun]\)]\))\>\"", ",", "14"}], "]"}]}], "}"}]}], 
     ",", 
     RowBox[{"PlotRange", "\[Rule]", "All"}], ",", 
     RowBox[{"PlotStyle", "->", 

          StyleBox["t", "TI"], "\[Prime]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\tau_T(t)=\\int_t^{t_o}\\Gamma_T(t')\\,dt'$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 

Cell[TextData[{
 "Substituting this radius into equation (37) yields the maximum baryonic \
mass compatible with a circular orbit at speed ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["v", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$v$", "state" -> "Boxes"|>,

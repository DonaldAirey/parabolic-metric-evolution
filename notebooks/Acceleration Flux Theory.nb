8ba3a013a5c7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["\[Sigma]", "T"],
    $CellContext`thomsonScatteringCrossSection], "=", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\"Thomson cross section\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"PhysicalConstant\"", ",", "\"ThomsonCrossSection\""}], 
          "]"}], "\"Entity[\\\"PhysicalConstant\\\", \
\\\"ThomsonCrossSection\\\"]\"", "\"physical constant\""},
       "Entity"], "[", "\"\<Value\>\"", "]"}], ",", "\"\<SIBase\>\""}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["\[CapitalGamma]", "T"],
    $CellContext`thomsonScatteringRate], "[", 
   RowBox[{"t_", "?", "QuantityQ"}], "]"}], ":=", 
  RowBox[{
   RowBox[{
    InterpretationBox[
     SubscriptBox["n", "e"],
     $CellContext`electronDensity], "[", "t", "]"}], " ", 
   InterpretationBox[
    SubscriptBox["\[Sigma]", "T"],
    $CellContext`thomsonScatteringCrossSection], " ", 
   RowBox[{"(", 
    RowBox[{
     InterpretationBox[
      SubscriptBox["V", "0"],
      $CellContext`initialVelocity], "-", 
     RowBox[{"A", " ", "t"}]}], ")"}]}]}]}], "Input",
 CellChangeTimes->{{3.9783761246251907`*^9, 3.9783761246251907`*^9}, 

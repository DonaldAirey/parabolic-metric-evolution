Cell[TextData[{
 "Using equation (7), the emission epoch ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["e", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_e$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dc59ad1e-a65b-4c4a-8bef-3eb99fa11916"],
 " is expressed in terms of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox[
        StyleBox["t", "TI"], 
        StyleBox["o", "TI"]], TraditionalForm], "errors" -> {}, "input" -> 
     "$t_o$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8ec30131-441b-1f45-89a0-2bdffeff367b"],
 " and the observed redshift ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["z", "TI"], TraditionalForm], "errors" -> {}, "input" -> 
     "$z$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b79d5880-ba3c-194d-9089-5d2363113011"],
 ","
}], "Text",
 CellChangeTimes->{{3.9873301926819897`*^9, 3.987330212728672*^9}, 
   3.987358642795723*^9},ExpressionUUID->"e195e073-7257-3440-8a32-\
56569a9144db"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["t", "TI"], 
          StyleBox["e", "TI"]], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["V", "TI"], "0"], 
            RowBox[{"(", 
              RowBox[{"1", "+", 
                StyleBox["z", "TI"]}], ")"}], "-", 
            SqrtBox[
             RowBox[{
               RowBox[{"(", 
                 RowBox[{"1", "+", 
                   StyleBox["z", "TI"]}], ")"}], 
               RowBox[{"[", 
                 RowBox[{
                   SuperscriptBox[
                    RowBox[{"(", 
                    RowBox[{
                    SubscriptBox[
                    StyleBox["V", "TI"], "0"], "-", 
                    StyleBox["A", "TI"], 
                    SubscriptBox[
                    StyleBox["t", "TI"], 
                    StyleBox["o", "TI"]]}], ")"}], "2"], "+", 
                   SubsuperscriptBox[
                    StyleBox["V", "TI"], "0", "2"], 
                   StyleBox["z", "TI"]}], "]"}]}]]}], 
          RowBox[{
            StyleBox["A", "TI"], "(", 
            RowBox[{"1", "+", 
              StyleBox["z", "TI"]}], ")"}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$t_e = \\frac{V_0(1+z) - \\sqrt{(1+z)\\big[(V_0 - A t_o)^2 + V_0^2 \
z\\big]}}{A(1+z)}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987330230718748*^9, 3.987330237034788*^9}, {
  3.98735935491798*^9, 
  3.98735935491798*^9}},ExpressionUUID->"02e3dd99-e3ad-8943-a87b-\
de1cd08db297"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["t", "z"],
    $CellContext`timeFromRedshift], "[", "z_", "]"}], "=", 
  RowBox[{"Simplify", "[", 
   RowBox[{"First", "[", 
    RowBox[{
     InterpretationBox[
      SubscriptBox["t", "e"],
      $CellContext`emissionTime], "/.", "\[VeryThinSpace]", 
     RowBox[{"Solve", "[", 
      RowBox[{
       RowBox[{"z", "\[Equal]", 
        FractionBox[
         RowBox[{
          RowBox[{"L", "[", 
           InterpretationBox[
            SubscriptBox["t", "o"],
            $CellContext`observationTime], "]"}], "-", 
          RowBox[{"L", "[", 
           InterpretationBox[
            SubscriptBox["t", "e"],
            $CellContext`emissionTime], "]"}]}], 
         RowBox[{"L", "[", 
          InterpretationBox[
           SubscriptBox["t", "e"],
           $CellContext`emissionTime], "]"}]]}], ",", 
       InterpretationBox[
        SubscriptBox["t", "e"],
        $CellContext`emissionTime]}], "]"}]}], "]"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.975584982966263*^9, 3.975585007501524*^9}, {
   3.975604906400345*^9, 3.975604913923189*^9}, {3.976135255831188*^9, 
   3.9761352579627895`*^9}, {3.976135489762558*^9, 3.976135560057169*^9}, 

354470900fa6"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"gravitationalConstant", "=", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\"gravitational constant\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"PhysicalConstant\"", ",", "\"GravitationalConstant\""}], 
          "]"}], "\"Entity[\\\"PhysicalConstant\\\", \
\\\"GravitationalConstant\\\"]\"", "\"physical constant\""},
       "Entity"], "[", "\"\<Value\>\"", "]"}], ",", "\"\<SIBase\>\""}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  InterpretationBox[
   SubscriptBox["\[Rho]", "b"],
   $CellContext`baryonDensity], "=", 
  RowBox[{
   InterpretationBox[
    SubscriptBox["\[Rho]", "b"],
    $CellContext`baryonDensity], "/.", "\[VeryThinSpace]", 
   RowBox[{"First", "[", 
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"A", "\[Equal]", 
         FractionBox[
          RowBox[{
           RowBox[{"M", "[", 
            RowBox[{"L", "[", 
             InterpretationBox[
              SubscriptBox["t", "o"],
              $CellContext`observationTime], "]"}], "]"}], " ", "G"}], 
          SuperscriptBox[
           RowBox[{"L", "[", 
            InterpretationBox[
             SubscriptBox["t", "o"],
             $CellContext`observationTime], "]"}], "2"]]}], "/.", 
        "\[VeryThinSpace]", "initialConditions"}], "/.", "\[VeryThinSpace]", 
       RowBox[{"{", 
        RowBox[{"G", "\[Rule]", "gravitationalConstant"}], "}"}]}], ",", 
      InterpretationBox[
       SubscriptBox["\[Rho]", "b"],
       $CellContext`baryonDensity]}], "]"}], "]"}]}]}]}], "Input",
 CellChangeTimes->{{3.9811160791821003`*^9, 3.9811161123653564`*^9}, {
   3.981116187335327*^9, 3.981116207552656*^9}, {3.9811162465070343`*^9, 
   3.9811162554439716`*^9}, {3.9811166505534744`*^9, 3.9811166627110577`*^9}, 
   3.981116704733324*^9, 3.981553934444689*^9, {3.981558908343462*^9, 
   3.9815589135503254`*^9}, {3.981562601421673*^9, 3.981562640655155*^9}, {
   3.9815643930724983`*^9, 3.9815643954836617`*^9}, {3.9839580967419662`*^9, 
   3.9839581159390965`*^9}},
 CellLabel->
  "In[199]:=",ExpressionUUID->"a2fe9009-fa1a-8a4e-9362-eda1467ed85e"],

Cell[BoxData[
 TemplateBox[{"9.487809745861167`*^-28", 
   RowBox[{"\"kg\"", "\[InvisibleSpace]", "\"/\"", "\[InvisibleSpace]", 
     SuperscriptBox["\"m\"", "3"]}], "kilograms per meter cubed", 
   FractionBox["\"Kilograms\"", 
    SuperscriptBox["\"Meters\"", "3"]]},
  "Quantity"]], "Output",
 CellChangeTimes->{3.987751830686886*^9},
 CellLabel->
  "Out[200]=",ExpressionUUID->"84c35dfd-ee85-1f4b-b4cb-e1ca120b0118"]
}, Open  ]],

Cell[TextData[{
 "This value is consistent with independent observational estimates of the \
present-day baryon density from primordial light-element abundances [",
 ButtonBox["13",
  BaseStyle->"Hyperlink",
  ButtonData->"Cooke2018"],
 "]."
}], "Text",
 CellChangeTimes->{{3.9876033710052032`*^9, 
  3.987603396793316*^9}},ExpressionUUID->"3dde1b8b-d5cf-a942-963e-\
843dc09d3b73"],

Cell[TextData[{
 "The photon density is determined from the measured CMB temperature ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["T", "TI"], "\[Gamma]"], "\[LongEqual]", "2.725 ", 
         StyleBox["K", FontSlant -> "Plain"]}], TraditionalForm], 
     "errors" -> {}, "input" -> "$T_\\gamma=2.725\\,\\mathrm{K}$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2a848c47-c2d5-ab41-9c78-cbc576b35ea5"],
 ". The mapping between temperature and photon density depends on the local \
geometric scale ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"(", 
         RowBox[{
           SubscriptBox[
            StyleBox["V", "TI"], "0"], "-", 
           StyleBox["A", "TI"], 
           StyleBox["t", "TI"]}], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$(V_0 - At)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "df2b84cd-e4ca-414b-a326-7c15b1f3e440"],
 ", so the photon density is treated as epoch dependent rather than a scaled \
constant. For a blackbody radiation field, the photon number density is"
}], "Text",
 CellChangeTimes->{{3.987603667348896*^9, 
  3.987603723285801*^9}},ExpressionUUID->"5bf52130-4631-9e4b-90ce-\
fdead25a50ae"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["n", "TI"], "\[Gamma]"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{"2", "\[Zeta]", 
            RowBox[{"(", "3", ")"}]}], 
          SuperscriptBox["\[Pi]", "2"]], 
         SuperscriptBox[
          RowBox[{"(", 
            FractionBox[
             RowBox[{
               SubscriptBox[
                StyleBox["k", "TI"], 
                StyleBox["B", "TI"]], 
               SubscriptBox[
                StyleBox["T", "TI"], "\[Gamma]"]}], 
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["V", "TI"], "0"], "-", 
                 StyleBox["A", "TI"], 
                 StyleBox["t", "TI"]}], ")"}]], ")"}], "3"]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "$n_\\gamma(t)=\\frac{2\\zeta(3)}{\\pi^2}\\left(\\frac{k_B \
T_\\gamma}{\\hbar (V_0-At)}\\right)^3$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.987603719806034*^9, 3.9876037304744377`*^9}, {
  3.98770552743816*^9, 
  3.987705527440672*^9}},ExpressionUUID->"a1e2e706-4e40-9c43-b80f-\
fbee5c1d2d76"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["k", 
     StyleBox["B",
      FontSlant->"Plain"]],
    $CellContext`boltzmannConstant], "=", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\"Boltzmann constant\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"PhysicalConstant\"", ",", "\"BoltzmannConstant\""}], 
          "]"}], "\"Entity[\\\"PhysicalConstant\\\", \
\\\"BoltzmannConstant\\\"]\"", "\"physical constant\""},
       "Entity"], "[", "\"\<Value\>\"", "]"}], ",", "\"\<SIBase\>\""}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   InterpretationBox[
    StyleBox["\[HBar]",
     FontSlant->"Italic"],
    $CellContext`reducedPlanckConstant], "=", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\"reduced Planck constant\"", 
        RowBox[{"Entity", "[", 
          RowBox[{"\"PhysicalConstant\"", ",", "\"ReducedPlanckConstant\""}], 
          "]"}], "\"Entity[\\\"PhysicalConstant\\\", \
\\\"ReducedPlanckConstant\\\"]\"", "\"physical constant\""},
       "Entity"], "[", "\"\<Value\>\"", "]"}], ",", "\"\<SIBase\>\""}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["T", "\[Gamma]"],
    $CellContext`photonTemperature], "=", 
   RowBox[{"UnitConvert", "[", 
    RowBox[{
     RowBox[{
      TemplateBox[{"\"cosmic microwave background radiation temperature\"", 
        RowBox[{"Entity", "[", 
          
          RowBox[{"\"PhysicalConstant\"", ",", 
            "\"CosmicMicrowaveBackgroundTemperature\""}], "]"}], 
        "\"Entity[\\\"PhysicalConstant\\\", \
\\\"CosmicMicrowaveBackgroundTemperature\\\"]\"", "\"physical constant\""},
       "Entity"], "[", "\"\<Value\>\"", "]"}], ",", "\"\<SIBase\>\""}], 
    "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    InterpretationBox[
     SubscriptBox["n", "\[Gamma]"],
     $CellContext`photonNumberDensity], "[", "t_", "]"}], ":=", 
   RowBox[{
    FractionBox[
     RowBox[{"2", " ", 
      RowBox[{"Zeta", "[", "3", "]"}], " "}], 
     SuperscriptBox["\[Pi]", "2"]], 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        InterpretationBox[
         SubscriptBox["k", 
          StyleBox["B",
           FontSlant->"Plain"]],
         $CellContext`boltzmannConstant], " ", 
        InterpretationBox[
         SubscriptBox["T", "\[Gamma]"],
         $CellContext`photonTemperature]}], 
       RowBox[{
        InterpretationBox[
         StyleBox["\[HBar]",
          FontSlant->"Italic"],
         $CellContext`reducedPlanckConstant], " ", 
        RowBox[{"(", 
         RowBox[{
          InterpretationBox[
           SubscriptBox["V", "0"],
           $CellContext`initialVelocity], "-", 
          RowBox[{"A", " ", "t"}]}], ")"}]}]], ")"}], "3"]}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.9876094680169506`*^9, 3.9876094739452057`*^9}, 
   3.9876214892682247`*^9},
 CellLabel->
  "In[201]:=",ExpressionUUID->"af153d13-57c0-5b44-b45f-b066de6aacf7"],

Cell["\<\
and, following the geometric sign convention of Eq. (58), the mean photon \
energy is\
\>", "Text",
 CellChangeTimes->{{3.987603740192568*^9, 3.987603749691868*^9}, {
  3.9877056002304134`*^9, 
  3.987705602541807*^9}},ExpressionUUID->"9886089e-217a-4c47-a233-\
40976481aaec"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         RowBox[{"\[LeftAngleBracket]", 
           SubscriptBox[
            StyleBox["E", "TI"], "\[Gamma]"], "\[RightAngleBracket]"}], 
         "\[LongEqual]", "-", 
         FractionBox[
          SuperscriptBox["\[Pi]", "4"], 
          RowBox[{"30", "\[Zeta]", 
            RowBox[{"(", "3", ")"}]}]], 
         SubscriptBox[
          StyleBox["k", "TI"], 
          StyleBox["B", "TI"]], 
         SubscriptBox[
          StyleBox["T", "TI"], "\[Gamma]"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\langle E_\\gamma\\rangle=-\\frac{\\pi^4}{30\\zeta(3)}k_B T_\\gamma$",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876037623644257`*^9, 3.987603766772743*^9}, {
  3.9877059719784203`*^9, 
  3.9877059719784203`*^9}},ExpressionUUID->"fd7b0346-f789-654d-8a9a-\
0a1012f1803c"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    RowBox[{"\[LeftAngleBracket]", 
     SubscriptBox["E", "\[Gamma]"], "\[RightAngleBracket]"}],
    $CellContext`meanPhotonEnergy], "=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[Pi]", "4"], " ", 
      InterpretationBox[
       SubscriptBox["k", 
        StyleBox["B",
         FontSlant->"Plain"]],
       $CellContext`boltzmannConstant], " ", 
      InterpretationBox[
       SubscriptBox["T", "\[Gamma]"],
       $CellContext`photonTemperature]}], 
     RowBox[{"30", " ", 
      RowBox[{"Zeta", "[", "3", "]"}]}]]}]}], ";"}]], "Input",
 CellChangeTimes->{3.9876222777801514`*^9},
 CellLabel->
  "In[205]:=",ExpressionUUID->"0306cd0b-2271-844b-b636-dd3fbbe7404a"],

Cell["The corresponding photon energy density is", "Text",
 CellChangeTimes->{
  3.987603776457411*^9},ExpressionUUID->"cc53d42d-5445-cb4a-adef-\
83caaff83d6f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["u", "TI"], "\[Gamma]"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["n", "TI"], "\[Gamma]"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], 
         RowBox[{"\[LeftAngleBracket]", 
           SubscriptBox[
            StyleBox["E", "TI"], "\[Gamma]"], "\[RightAngleBracket]"}]}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "$u_\\gamma(t)=n_\\gamma(t)\\langle E_\\gamma\\rangle$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876091570268383`*^9, 3.987609160816572*^9}, {
  3.98770600017861*^9, 
  3.987706000183344*^9}},ExpressionUUID->"084de3ee-c87e-e84c-b6e6-\
f90c26278447"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    InterpretationBox[
     SubscriptBox["u", "\[Gamma]"],
     $CellContext`photonEnergyDensity], "[", "t_", "]"}], ":=", 
   RowBox[{
    RowBox[{
     InterpretationBox[
      SubscriptBox["n", "\[Gamma]"],
      $CellContext`photonNumberDensity], "[", "t", "]"}], " ", 
    InterpretationBox[
     RowBox[{"\[LeftAngleBracket]", 
      SubscriptBox["E", "\[Gamma]"], "\[RightAngleBracket]"}],
     $CellContext`meanPhotonEnergy]}]}], ";"}]], "Input",
 CellChangeTimes->{{3.987609215835066*^9, 3.987609231723196*^9}, 
   3.987609338371311*^9, 3.987621481898491*^9},
 CellLabel->
  "In[206]:=",ExpressionUUID->"6d75e4b0-f206-fc4e-ba1a-a529ca47bf6e"],

Cell["so the mass-equivalent photon density becomes", "Text",
 CellChangeTimes->{
  3.987609177962969*^9},ExpressionUUID->"fe854ec3-8524-f449-aa5b-\
c8f1340545d0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Rho]", "\[Gamma]"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["u", "TI"], "\[Gamma]"], "(", 
            StyleBox["t", "TI"], ")"}], 
          RowBox[{"-", 
            SuperscriptBox[
             RowBox[{"(", 
               RowBox[{
                 SubscriptBox[
                  StyleBox["V", "TI"], "0"], "-", 
                 StyleBox["A", "TI"], 
                 StyleBox["t", "TI"]}], ")"}], "2"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\rho_\\gamma(t)=\\frac{u_\\gamma(t)}{-(V_0-At)^2}$", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], "."}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876037856162663`*^9, 3.987603788861561*^9}, {
  3.9877060084782543`*^9, 
  3.9877060084829006`*^9}},ExpressionUUID->"a2c447b9-0c9a-e848-8150-\
032d4da06495"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   InterpretationBox[
    SubscriptBox["\[Rho]", "\[Gamma]"],
    $CellContext`photonDensity], "[", "t_", "]"}], ":=", 
  RowBox[{"-", 
   FractionBox[
    RowBox[{
     InterpretationBox[
      SubscriptBox["u", "\[Gamma]"],
      $CellContext`photonEnergyDensity], "[", "t", "]"}], 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       InterpretationBox[
        SubscriptBox["V", "0"],
        $CellContext`initialVelocity], "-", 
       RowBox[{"A", " ", "t"}]}], ")"}], "2"]]}]}]], "Input",
 CellChangeTimes->{{3.9784482611319923`*^9, 3.9784482748337727`*^9}, {
   3.9784483192931404`*^9, 3.978448451281187*^9}, {3.9784553965495853`*^9, 
   3.9784553987091217`*^9}, {3.978455916738861*^9, 3.978455944326067*^9}, {
   3.978456019324787*^9, 3.9784560496480885`*^9}, 3.9784564086182423`*^9, 
   3.9786332740188637`*^9, {3.9811166872878265`*^9, 3.981116784817524*^9}, {
   3.981116817678915*^9, 3.9811168188656235`*^9}, {3.9811169139876633`*^9, 
   3.981116917038763*^9}, 3.981117093117628*^9, 3.9811179555218277`*^9, 
   3.9815680744339714`*^9, {3.981568105323633*^9, 3.981568105323633*^9}, 
   3.9815681683056183`*^9, {3.981568739634289*^9, 3.9815687713422203`*^9}, {
   3.981568838600172*^9, 3.9815688545806046`*^9}, {3.9815689314241123`*^9, 
   3.981568942642473*^9}, 3.9816141744162407`*^9, 3.981614242471941*^9, {
   3.9816143162288723`*^9, 3.9816143187949944`*^9}, {3.981615063431429*^9, 
   3.9816151554470425`*^9}, {3.98161538088472*^9, 3.98161540062109*^9}, {
   3.981616015010351*^9, 3.981616052881901*^9}, {3.9816171377451515`*^9, 
   3.9816171408842278`*^9}, {3.983613132709532*^9, 3.9836131458636913`*^9}, {
   3.9836131810183144`*^9, 3.9836131826823025`*^9}, {3.983613544000925*^9, 
   3.9836135519373455`*^9}, {3.9836135932388077`*^9, 3.983613663583683*^9}, {
   3.983620404246784*^9, 3.9836204394975224`*^9}, {3.9836208702339363`*^9, 
   3.9836208828860073`*^9}, {3.9836213482633915`*^9, 
   3.9836213931270256`*^9}, {3.987608822728256*^9, 3.987608849748329*^9}, {
   3.9876088887618217`*^9, 3.987608946224781*^9}, {3.987609200875469*^9, 
   3.987609207834364*^9}, 3.987609342179674*^9, 3.9876214680884113`*^9},
 CellLabel->
  "In[207]:=",ExpressionUUID->"69b2ffc4-9ccd-5b43-8843-f7527d827e4c"],

Cell["\<\
These densities determine the baryon-photon momentum ratio and the \
free-electron density entering the visibility function.\
\>", "Text",
 CellChangeTimes->{3.987603798760353*^9, 
  3.987607928412081*^9},ExpressionUUID->"3b87d99a-f294-2246-a755-\
a0a5d0aa3356"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Recombination Epoch", "Subsection",
 CellChangeTimes->{
  3.9876038106635094`*^9},ExpressionUUID->"c1e60191-c092-3e48-8d26-\
cbec59f93e56"],

Cell["\<\
The recombination epoch is the time of maximum photon visibility, i.e. the \
most probable last-scattering time in the baryon-photon plasma.\
\>", "Text",
 CellChangeTimes->{
  3.9876039515423203`*^9, {3.9876079461935177`*^9, 
   3.9876079477091427`*^9}},ExpressionUUID->"4efc86b9-2920-7948-8b14-\
08699d0ca395"],

Cell[TextData[{
 "To determine the ionization history, we evaluate the standard recombination \
rate equations using ",
 StyleBox["Recfast++",
  FontFamily->"Courier New",
  FontWeight->"Normal"],
 " with the PME expansion geometry. The background evolution is provided by \
the PME Hubble function (equation (71)) in place of the FLRW algorithm, with \
the expansion rate governed by the best-fit manifold parameters. The baryon \
sector is specified by the present-day baryon density derived above. The \
resulting ionization history is used to interpolate the free-electron \
fraction ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["e", "TI"]], "(", 
         StyleBox["z", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$x_e(z)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "c7f60aa0-bce4-e748-a420-9dc8c046702a"],
 " entering the visibility function. The free-electron number density ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["e", "TI"]], "(", 
         StyleBox["t", "TI"], ")"}], TraditionalForm], "errors" -> {}, 
     "input" -> "$n_e(t)$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f2c146b1-bcd5-6e41-b1d7-c5feda7066d8"],
 " is defined as"
}], "Text",
 CellChangeTimes->{{3.987603962692856*^9, 3.9876039704751606`*^9}, {
   3.987604004145439*^9, 3.9876040291616707`*^9}, 3.9876079585987854`*^9, {
   3.987705903268835*^9, 3.9877059042124157`*^9}, 
   3.9877059417027817`*^9},ExpressionUUID->"74ff1b14-06e7-0445-b6c3-\
b30863a671be"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["e", "TI"]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["e", "TI"]], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], " ", 
         FractionBox[
          SubscriptBox["\[Rho]", 
           StyleBox["b", "TI"]], 
          SubscriptBox[
           StyleBox["m", "TI"], 
           StyleBox["p", "TI"]]], " ", 
         StyleBox["a", "TI"], 
         SuperscriptBox[
          RowBox[{"(", 
            StyleBox["t", "TI"], ")"}], "-3"]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$n_e(t)=x_e(t)\\,\\frac{\\rho_b}{m_p}\\,a(t)^{-3}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellChangeTimes->{{3.9876040389889526`*^9, 3.987604042582054*^9}, {
  3.9877059550785446`*^9, 
  3.987705955088522*^9}},ExpressionUUID->"065ae3c9-815f-e14a-9a1e-\
e377601ff00d"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"pmeElectronFractionData", "=", 
   RowBox[{"Import", "[", 
    RowBox[{
     RowBox[{
     "CloudObject", 
      "[", "\"\<https://www.wolframcloud.com/obj/5ee0ade7-823c-4871-8a8e-\
9717bf289d35\>\"", "]"}], ",", "\"\<Table\>\""}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"{", 
    RowBox[{"redshiftMin", ",", "redshiftMax"}], "}"}], "=", 
   RowBox[{"MinMax", "[", 
    RowBox[{"pmeElectronFractionData", "\[LeftDoubleBracket]", 
     RowBox[{"All", ",", "1"}], "\[RightDoubleBracket]"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    InterpretationBox[
     SubscriptBox["t", "z"],
     $CellContext`timeFromRedshift], "[", "z_", "]"}], "=", 
   RowBox[{
    InterpretationBox[
     SubscriptBox["t", "e"],
     $CellContext`emissionTime], "/.", "\[VeryThinSpace]", 
    RowBox[{
     RowBox[{"Simplify", "[", 
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{"z", "\[Equal]", 
         FractionBox[
          RowBox[{
           RowBox[{"L", "[", 
            InterpretationBox[
             SubscriptBox["t", "o"],
             $CellContext`observationTime], "]"}], "-", 
           RowBox[{"L", "[", 
            InterpretationBox[
             SubscriptBox["t", "e"],
             $CellContext`emissionTime], "]"}]}], 
          RowBox[{"L", "[", 
           InterpretationBox[
            SubscriptBox["t", "e"],
            $CellContext`emissionTime], "]"}]]}], ",", 
        InterpretationBox[
         SubscriptBox["t", "e"],
         $CellContext`emissionTime]}], "]"}], "]"}], "\[LeftDoubleBracket]", 
     "1", "\[RightDoubleBracket]"}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    InterpretationBox[
     SubscriptBox["z", "t"],
     $CellContext`redshiftFromTime], "[", "t_", "]"}], "=", 
   RowBox[{"Simplify", "[", 
    RowBox[{
     FractionBox[
      RowBox[{"L", "[", 
       InterpretationBox[
        SubscriptBox["t", "o"],
        $CellContext`observationTime], "]"}], 
      RowBox[{"L", "[", "t", "]"}]], "-", "1"}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    InterpretationBox[
     SubscriptBox["a", "t"],
     $CellContext`scaleFactorFromTime], "[", "t_", "]"}], "=", 
   RowBox[{"Simplify", "[", 
    FractionBox[
     RowBox[{"L", "[", "t", "]"}], 

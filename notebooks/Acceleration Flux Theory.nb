       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          InterpretationBox[
           SubscriptBox["V", "0"],
           $CellContext`initialVelocity], ")"}], "2"], " ", "z"}]}], 
      ")"}]}]]}], 
  RowBox[{"A", "+", 
   RowBox[{"A", " ", "z"}]}]]], "Output",

                FractionBox["1", "2"], 
                StyleBox["A", "TI"], 
                SubsuperscriptBox[
                 StyleBox["t", "TI"], 
                 StyleBox["o", "TI"], "2"]}]]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "$\\Delta s^1 =\\frac{\\Delta x_o^1}{2}\\left(1 +\\frac{V_0 t_e - \
\\frac{1}{2} A t_e^2}{V_0 t_o - \\frac{1}{2} A t_o^2}\\right)$", "state" -> 

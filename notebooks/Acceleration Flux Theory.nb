Cell[CellGroupData[{

Cell["Hubble Function", "Subsection",
 CellChangeTimes->{{3.9771420752611046`*^9, 3.977142077921898*^9}, 
   3.9876011750198784`*^9},ExpressionUUID->"cfb4c606-c1a9-064d-ba49-\
b731533ec808"],

Cell[TextData[{
 "The Hubble expansion rate is defined by the fractional rate of change of \
the real spatial extent of the manifold, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["H", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[Congruent]", 
         OverscriptBox[
          StyleBox["L", "TI"], "."], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "/", 
         RowBox[{
           StyleBox["L", "TI"], "(", 
           StyleBox["t", "TI"], ")"}]}], TraditionalForm], "errors" -> {}, 
     "input" -> "$H(t) \\equiv \\dot{L}(t)/{L(t)}$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "0aa84251-2a75-fe47-9f4c-93db1e30057d"],
 ". Differentiating equation() gives ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         OverscriptBox[
          StyleBox["L", "TI"], "."], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["V", "TI"], "0"], "-", 
         StyleBox["A", "TI"], 
         StyleBox["t", "TI"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "$\\dot{L}(t)=V_0-At$", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "1369ff4d-26cf-5140-a4b1-c074db2e18df"],
 ", so"
}], "Text",
 CellChangeTimes->{{3.9771582679368553`*^9, 3.9771583183066235`*^9}, {
   3.977158359524206*^9, 3.977158494920002*^9}, {3.977158595151369*^9, 
   3.977158625331976*^9}, 3.9771598178915253`*^9, {3.977159886717268*^9, 
   3.977159979200741*^9}, 3.9772260272316875`*^9, {3.9773417058627796`*^9, 
   3.9773417091528873`*^9}, {3.97741290218165*^9, 3.977412902486431*^9}, 
   3.9793040647821465`*^9, {3.9876011843488045`*^9, 
   3.987601223191984*^9}},ExpressionUUID->"e5573ecd-0cf9-c24d-b0a2-\
38bbe67d4fe5"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["H", "TI"], 
         RowBox[{"(", 
           StyleBox["t", "TI"], ")"}], "\[LongEqual]", 
         FractionBox[
          RowBox[{
            SubscriptBox[
             StyleBox["V", "TI"], "0"], "-", 
            StyleBox["A", "TI"], 
            StyleBox["t", "TI"]}], 
          RowBox[{
            SubscriptBox[
             StyleBox["V", "TI"], "0"], 
            StyleBox["t", "TI"], "-", 
            FractionBox["1", "2"], 

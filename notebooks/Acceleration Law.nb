FormBox[TemplateBox[Association["boxes" -> FormBox[SuperscriptBox["\[Chi]","2"],TraditionalForm],
"errors" -> {},"input" -> "$\\chi^2$","state" -> "Boxes"],"TeXAssistantTemplate"],
TraditionalForm]],ExpressionUUID -> "291c303d-5d0c-5749-9537-adc5ec307801"]," statistic"}],

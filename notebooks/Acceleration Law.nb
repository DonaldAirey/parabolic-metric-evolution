{RowBox[{RowBox[{RowBox[{"chi2FromResiduals","[","res_","]"}],":=",RowBox[{"res",".",RowBox[
{"LinearSolve","[",RowBox[{"supernovaCovarianceMatrix",",","res"}],"]"}]}]}],";"}],"\n",RowBox[

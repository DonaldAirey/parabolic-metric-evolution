TextData[
{"For each candidate value of ",Cell[
BoxData[FormBox[TemplateBox[Association["boxes" -> FormBox[
SubscriptBox[StyleBox["t","TI"],StyleBox["o","TI"]],TraditionalForm],"errors" -> {},
"input" -> "$t_o$","state" -> "Boxes"],"TeXAssistantTemplate"],TraditionalForm]],
ExpressionUUID -> "0420f78c-498d-e14b-b383-f29ff14a793e"],", theoretical distance moduli ",Cell[
BoxData[
FormBox[TemplateBox[Association["boxes" -> FormBox[RowBox[{SubscriptBox["\[Mu]",StyleBox[
"th",FontSlant -> "Plain"]],"(",StyleBox["z","TI"],")"}],TraditionalForm],"errors" -> {},
"input" -> "$\\mu_{\\mathrm{th}}(z)$","state" -> "Boxes"],"TeXAssistantTemplate"],
TraditionalForm]],ExpressionUUID -> "019ed523-f638-9a4e-8817-e29008c4dbaf"]," are evaluated at the calibration-set redshifts and compared with the observed values ",Cell[
BoxData[
FormBox[TemplateBox[Association["boxes" -> FormBox[RowBox[{SubscriptBox["\[Mu]",StyleBox[
"obs",FontSlant -> "Plain"]],"(",StyleBox["z","TI"],")"}],TraditionalForm],"errors" -> {},
"input" -> "$\\mu_{\\mathrm{obs}}(z)$","state" -> "Boxes"],"TeXAssistantTemplate"],
TraditionalForm]],ExpressionUUID -> "0a4626f0-7c81-6c4b-ab03-288d3e1afa14"],", defining the residual vector"}],

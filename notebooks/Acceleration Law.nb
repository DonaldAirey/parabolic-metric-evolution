TextData[
{"With the acceleration scale ",Cell[
BoxData[FormBox[TemplateBox[Association["boxes" -> FormBox[
StyleBox["A","TI"],TraditionalForm],"errors" -> {},"input" -> "$A$","state" -> "Boxes"],
"TeXAssistantTemplate"],TraditionalForm]],ExpressionUUID -> "fc4875e6-a7b7-3f4e-bd23-b95b7297d68d"]," determined from the baryonic Tully--Fisher analysis, the Cepheid-calibrated Pantheon+ subset is used to determine the temporal scale ",Cell[
BoxData[
FormBox[TemplateBox[Association["boxes" -> FormBox[SubscriptBox[StyleBox["t","TI"],
StyleBox["o","TI"]],TraditionalForm],"errors" -> {},"input" -> "$t_o$","state" -> "Boxes"],
"TeXAssistantTemplate"],TraditionalForm]],ExpressionUUID -> "e33478db-db45-b54d-966b-08ea8722dc2f"],", while velocity scale ",Cell[
BoxData[
FormBox[TemplateBox[Association["boxes" -> FormBox[SubscriptBox[StyleBox["V","TI"],
"0"],TraditionalForm],"errors" -> {},"input" -> "$V_0$","state" -> "Boxes"],"TeXAssistantTemplate"],
TraditionalForm]],ExpressionUUID -> "944362b9-7221-a345-93a1-9ad6965043ca"]," is fixed algebraically by the equation above. The calibration therefore involves a single free parameter, ",Cell[
BoxData[
FormBox[TemplateBox[Association["boxes" -> FormBox[SubscriptBox[StyleBox["t","TI"],
StyleBox["o","TI"]],TraditionalForm],"errors" -> {},"input" -> "$t_o$","state" -> "Boxes"],
"TeXAssistantTemplate"],TraditionalForm]],ExpressionUUID -> "6ffcc8de-cbff-eb44-931f-b1de013ad223"],"."}],

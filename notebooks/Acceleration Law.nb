BoxData[
FormBox[SuperscriptBox["\[Chi]","2"],TraditionalForm]],ExpressionUUID -> "a457e95a-74ff-7b4c-9a41-39fad052fe45"]," values are computed from the covariance-weighted residuals using the full STAT+SYS matrix."}],
"Text",CellChangeTimes -> {{3.977140561245487`*^9,3.9771405953866787`*^9},{3.9772557550990067`*^9,3.977255791070303`*^9},{3.977256080169689`*^9,3.977256081786312`*^9},{3.9800887012037086`*^9,3.980088731727186`*^9}},

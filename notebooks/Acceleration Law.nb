FormBox[TemplateBox[Association["boxes" -> FormBox[SubscriptBox[StyleBox["t","TI"],
StyleBox["o","TI"]],TraditionalForm],"errors" -> {},"input" -> "$t_o$","state" -> "Boxes"],
